<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:XeniaManager.ViewModels.Controls"
             xmlns:fluent="using:FluentIcons.Avalonia.Fluent"
             xmlns:ic="using:FluentIcons.Avalonia.Fluent"
             xmlns:cards="using:XeniaManager.Controls.Cards"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="400"
             x:Class="XeniaManager.Controls.ManageProfilesDialog"
             x:DataType="vm:ManageProfilesDialogViewModel"
             Width="500"
             Height="400">
    <UserControl.Styles>
        <!-- Profile card style -->
        <Style Selector="Border.profile-card">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,8" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <!-- Profile Selection ComboBox -->
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="{DynamicResource ManageProfilesDialog.SelectProfile.Label}"
                       FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ComboBox ItemsSource="{Binding Gamertags}"
                          SelectedItem="{Binding SelectedGamertag, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"
                          MinWidth="300" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button Command="{Binding CreateAccountCommand}"
                            ToolTip.Tip="{DynamicResource ManageProfilesDialog.CreateAccount.Button.Tooltip}">
                        <Button.Content>
                            <ic:SymbolIcon Symbol="Add" />
                        </Button.Content>
                    </Button>
                    <Button Command="{Binding DeleteAccountCommand}"
                            ToolTip.Tip="{DynamicResource ManageProfilesDialog.DeleteAccount.Button.Tooltip}"
                            IsEnabled="{Binding SelectedGamertag, Converter={StaticResource NotNullConverter}}">
                        <Button.Content>
                            <ic:SymbolIcon Symbol="Delete" />
                        </Button.Content>
                    </Button>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Profile Edit Section -->
        <Border Grid.Row="1"
                Margin="0,16,0,0"
                BorderThickness="1"
                CornerRadius="6"
                Classes="profile-card"
                HorizontalAlignment="Stretch">
            <Border.Background>
                <DynamicResource ResourceKey="CardBackgroundFillColorSecondaryBrush" />
            </Border.Background>
            <StackPanel Spacing="8"
                        HorizontalAlignment="Stretch">
                <!-- Gamertag Edit -->
                <cards:TextBoxCard Title="{DynamicResource ManageProfilesDialog.Edit.Gamertag.Label}"
                                   Text="{Binding EditGamertag, Mode=TwoWay}"
                                   Icon="Edit"
                                   ShowIconBackground="True"
                                   HorizontalAlignment="Stretch"
                                   ToolTip.Tip="{Binding GamertagErrorMessage}" />

                <!-- Country Edit -->
                <cards:ComboBoxCard Title="{DynamicResource ManageProfilesDialog.Edit.Country.Label}"
                                    Items="{Binding Countries}"
                                    SelectedItem="{Binding SelectedCountry, Mode=TwoWay}"
                                    Icon="Globe"
                                    ShowIconBackground="True"
                                    ComboBoxMinWidth="180"
                                    HorizontalAlignment="Stretch" />

                <!-- Language Edit -->
                <cards:ComboBoxCard Title="{DynamicResource ManageProfilesDialog.Edit.Language.Label}"
                                    Items="{Binding Languages}"
                                    SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                    Icon="Translate"
                                    ShowIconBackground="True"
                                    ComboBoxMinWidth="180"
                                    HorizontalAlignment="Stretch" />
            </StackPanel>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button Content="{DynamicResource ManageProfilesDialog.Save.Button}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding CanSave}"
                    MinWidth="100" />
        </StackPanel>
    </Grid>
</UserControl>