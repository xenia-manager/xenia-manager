    <sys:String x:Key="AboutPage.Credits.XeniaNetplay.ToolTip"> - Multiplayer gaming support</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaMousehook.Title">Xenia Mousehook</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaMousehook.ToolTip"> - Keyboard &amp; Mouse support</sys:String>
