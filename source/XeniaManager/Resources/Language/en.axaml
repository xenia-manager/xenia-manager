    <sys:String x:Key="CompatibilityRating.Gameplay">Gameplay</sys:String>
    <sys:String x:Key="CompatibilityRating.Playable">Playable</sys:String>

    <!-- Manage Page -->
    <sys:String x:Key="ManagePage.Emulator.Manage.Title">Emulator Management</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Description">Install and manage different Xenia emulator versions</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Canary.Title">Xenia Canary</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.NotInstalled">Not Installed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.Failure.Title">Installation of Xenia {0} failed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.Failure.Message">Xenia {0} failed to install.&#10;Full Error:&#10;{1}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.Success.Title">Installation successful</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.Success.Message">Xenia {0} is installed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Failure.Title">Update of Xenia {0} failed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Failure.Message">Xenia {0} failed to update.&#10;Full Error:&#10;{1}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Success.Title">Update successful</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Success.Message">Xenia {0} is updated to version {1}.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.CheckUpdateFailed.Title">Check Update Failed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.CheckUpdateFailed.Message">Failed to check for updates.&#10;{0}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Confirmation.Title">Uninstall confirmation</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Confirmation.Message">Do you want to uninstall Xenia {0}?&#10;This will remove all save files and updates alongside the emulator.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Failure.Title">Uninstallation of Xenia {0} failed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Failure.Message">Xenia {0} failed to uninstall.&#10;Full Error:&#10;{1}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Success.Title">Uninstallation successful</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Success.Message">Xenia {0} is uninstalled</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Downloading">Downloading Xenia {0}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.SDL.Downloading">Downloading SDL Game Controller Database</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.UpdateAvailable.Title">Update Available</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.UpdateAvailable.Message">A new version of Xenia Canary is available.&#10;Current: {0}&#10;Latest: {1}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.UpToDate.Title">Up to Date</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.UpToDate.Message">Xenia is up to date</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Button.Install">Install</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Button.Update">Update</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Button.CheckForUpdates">Check for Updates</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Button.Uninstall">Uninstall</sys:String>
    <sys:String x:Key="ManagePage.Content.Management.Title">Content Management</sys:String>
    <sys:String x:Key="ManagePage.Content.Management.Description">Manage content and profiles</sys:String>
    <sys:String x:Key="ManagePage.Content.AutomaticSaveBackup.Title">Automatic Save Backup</sys:String>
    <sys:String x:Key="ManagePage.Content.AutomaticSaveBackup.Description">Automatically backs up the save for the selected profile</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Title">Unified content folder</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Description">Makes all Xenia versions have same content folder</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Tooltip">NOTE: This requires Xenia Manager to be run as Administrator while installing Xenia</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.AdminRequired.Title">Administrator Required</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.AdminRequired.Message">This action requires Xenia Manager to be run as Administrator.&#10;Please restart Xenia Manager with administrative privileges.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Separate.Title">Separate Content Folders</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Separate.Message">Do you want to separate the content folders?&#10;Each Xenia version will have its own independent content directory.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Unify.Title">Unify Content Folders</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Unify.Message">Do you want to unify the content folders?&#10;All Xenia versions will share the same content directory.&#10;&#10;Select which version's content to use as the base.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Unify.Success.Title">Content Folder Unification Successful</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Unify.Success.Message">Content folders have been unified successfully.&#10;All Xenia versions now share the same content directory.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Separate.Success.Title">Content Folder Separation Successful</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Separate.Success.Message">Content folders have been separated successfully.&#10;Each Xenia version now has its own independent content directory.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Operation.Failed.Title">Content Folder Operation Failed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Operation.Failed.Message">Failed to unify/separate content folders.&#10;Error: {0}</sys:String>

    <!-- Install Content Section -->
    <sys:String x:Key="ManagePage.Content.ManageProfiles.Title">Manage Profiles</sys:String>
    <sys:String x:Key="ManagePage.Content.ManageProfiles.Description">Allows the user to modify Xenia Profiles</sys:String>
    <sys:String x:Key="ManagePage.ManageProfiles.Button">Manage</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.Title">Install Content</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.Description">Install DLC, updates, and other content for Xenia</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.Button">Install Content</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.NoEmulator.Title">No Emulator Installed</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.NoEmulator.Message">Please install at least one version of Xenia before installing content.</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.Failed.Title">Content Installation Failed</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.Failed.Message">Failed to install content.&#10;Error: {0}</sys:String>

    <!-- Settings Page -->
    <sys:String x:Key="SettingsPage.Ui.Title">UI Settings</sys:String>
    <sys:String x:Key="SettingsPage.Ui.Description">Customize the UI of Xenia Manager</sys:String>
    <sys:String x:Key="SettingsPage.Ui.Language.Title">Language</sys:String>
    <sys:String x:Key="SettingsPage.Ui.Language.Description">Change the language of Xenia Manager User Interface</sys:String>
    <sys:String x:Key="SettingsPage.Ui.Language.Tooltip">NOTE: Some UI will stay in the original language until the app is reopened.</sys:String>
    <sys:String x:Key="SettingsPage.Ui.Theme.Title">Theme</sys:String>
