    <sys:String x:Key="AboutPage.Credits.AvaloniaUi.ToolTip"> - Cross-platform UI framework with Fluent Design</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentAvalonia.Title">FluentAvalonia</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentAvalonia.ToolTip"> - Fluent Design controls and themes for Avalonia</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentIcons.Title">FluentIcons</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentIcons.ToolTip"> - Framework for using Fluent Symbol Icons</sys:String>
    <sys:String x:Key="AboutPage.Credits.NLog.Title">NLog</sys:String>
    <sys:String x:Key="AboutPage.Credits.NLog.ToolTip"> - Flexible logging framework for .NET</sys:String>
