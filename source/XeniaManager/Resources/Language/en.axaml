    <sys:String x:Key="GameButton.ContextFlyout.Patches.Configure.Success.Title">Configuration Saved</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.Configure.Success.Message">Patch configuration has been saved successfully.</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.Configure.Error.Title">Configuration Error</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.Configure.Error.Message">There was an issue while configuring patches.&#10;{0}</sys:String>
