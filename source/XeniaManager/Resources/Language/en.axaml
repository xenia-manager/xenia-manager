    <sys:String x:Key="GameButton.ContextFlyout.Content.SaveBackup.Error.Message">There was an error while opening the save backup folder.&#10;{0}</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Content.Screenshots.Header">Screenshots</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Content.Screenshots.Tooltip">Opens the folder containing all of the screenshots taken from the game using Xenia</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Content.Screenshots.NoScreenshots.Title">No Screenshots Found</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Content.Screenshots.NoScreenshots.Message">No screenshots found for {0}.</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Content.Screenshots.Error.Title">Failed to Open Folder</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Content.Screenshots.Error.Message">There was an error while opening the screenshots folder.&#10;{0}</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.Header">Patches</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.Download.Header">Download</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.Download.Tooltip">Download patches from repository</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.Download.Failed.Title">Patch Download Failed</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.Download.Failed.Message">There was an issue while downloading the patch.&#10;{0}</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.Download.Success.Title">Patch Downloaded</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.Download.Success.Message">Successfully downloaded and installed patch:&#10;{0}</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.InstallLocal.Header">Install Local</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.InstallLocal.Tooltip">Install Patches from local .TOML files</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.InstallLocal.FilePicker.Title">Select Patches File</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.InstallLocal.FilePicker.MissingStorageProvider.Title">Missing Storage Provider</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.InstallLocal.FilePicker.MissingStorageProvider.Message">Storage provider is not available.&#10;{0}</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.InstallLocal.MismatchConfirmation.Title">Patch Title ID Mismatch</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.InstallLocal.MismatchConfirmation.Message">The selected patch is for Title ID: {0} ({1})&#10;but the current game has Title ID: {2}&#10;&#10;Do you want to continue installing this patch?</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.InstallLocal.Success.Title">Patch Installed</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.InstallLocal.Success.Message">Successfully installed patch:&#10;{0}</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.InstallLocal.Error.Title">Failed patch installation</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.InstallLocal.Error.Message">There was an issue while installing the patch.&#10;{0}</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.Header">Add</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.Tooltip">Add patches from local .TOML files on top of the already installed patches</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.NoPatchInstalled.Title">No Patch Installed</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.NoPatchInstalled.Message">You need to install a patch file first before adding additional patches.</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.FilePicker.Title">Select Patch File to Merge</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.FilePicker.MissingStorageProvider.Title">Missing Storage Provider</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.FilePicker.MissingStorageProvider.Message">Storage provider is not available.&#10;{0}</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.Success.Title">Patches Added</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.Success.Message">Successfully added patches from:&#10;{0}</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.Incompatible.Title">Incompatible Patch File</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.Incompatible.Message">The selected patch file is incompatible with the currently installed patch.&#10;Patch files must have matching hashes to merge patches.&#10;&#10;{0}</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.FileNotFound.Message">The selected patch file was not found.</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.Error.Title">Error Adding Patches</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.AddAdditional.Error.Message">There was an issue while adding additional patches.&#10;{0}</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.Configure.Header">Configure</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.Configure.Tooltip">Enable or disable patches</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Patches.Configure.NoPatchInstalled.Title">No Patch Installed</sys:String>
