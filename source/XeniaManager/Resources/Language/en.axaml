    <sys:String x:Key="GameButton.ContextFlyout.RemoveGame.Tooltip">Removes the game from Xenia Manager&#10;NOTE: This won't delete the game from the system</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.RemoveGame.Confirmation.Title">Remove Game</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.RemoveGame.Confirmation.Message">Do you want to remove the {0}?</sys:String>
