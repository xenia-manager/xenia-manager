<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- App global -->
    <sys:String x:Key="App.Title">Xenia Manager</sys:String>

    <!-- Main View -->
    <sys:String x:Key="MainView.Navigation.OpenXenia">Open Xenia</sys:String>
    <sys:String x:Key="MainView.Navigation.Library">Game Library</sys:String>
    <sys:String x:Key="MainView.Navigation.XeniaSettings">Xenia Settings</sys:String>
    <sys:String x:Key="MainView.Navigation.ManagePage">Manage Xenia</sys:String>
    <sys:String x:Key="MainView.Navigation.About">About</sys:String>
    <sys:String x:Key="MainView.Navigation.Settings">Settings</sys:String>
    <sys:String x:Key="MainView.Navigation.Error.Title">Error Navigating</sys:String>
    <sys:String x:Key="MainView.Navigation.Error.Message">Failed to navigate to designated page.&#10;{0}</sys:String>

    <!-- Library Page -->
    <sys:String x:Key="LibraryPage.Search.Watermark">Search...</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.Header">Edit Grid View</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.ToolTip">Show/Hide extra information on box arts</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.Title.Header">Game Title</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.CompatibilityRating.Header">Compatibility Rating</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.XeniaVersion.Header">Xenia Version</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.XeniaVersion.ToolTip">Show the Xenia version icon for each game</sys:String>
    <sys:String x:Key="LibraryPage.Options.DoubleClickLaunch.Header">Launch on Double-Click</sys:String>
    <sys:String x:Key="LibraryPage.Options.DoubleClickLaunch.ToolTip">Toggle between single and double-click to launch games</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Header">Scan Directory</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.ToolTip">Scans the selected directory for games&#10;Check Wiki for more details on how this feature works</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.MissingStorageProvider.Title">Missing Storage Provider</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.MissingStorageProvider.Message">Storage provider is not available.&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoXeniaInstalled.Title">No Xenia Installed</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoXeniaInstalled.Message">No version of Xenia is currently installed.&#10;Please install Xenia before continuing.</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.XeniaSelectionError.Title">Xenia Selection Error</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.XeniaSelectionError.Message">Failed to select Xenia version.&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.FolderPicker.Title">Select Folder to Scan</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Success.Title">Scan Complete</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Success.Message">Successfully added {0} game(s) to your library.</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoGamesFound.Title">Scan Complete</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoGamesFound.Message">No new games were found in the selected directory.&#10;&#10;The folder may not contain any compatible game files, or the games may already be in your library.</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Error.Title">Scan Failed</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Error.Message">An error occurred while scanning the directory:&#10;&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.ScanError.Title">Scan Error</sys:String>

    <!-- Folder Scan Progress Dialog -->
    <sys:String x:Key="FolderScanProgressDialog.Title">Scanning for Games</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Subtitle">Please wait while we search for game files</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Starting">Starting scan...</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Scanning">Scanning: {0}</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Complete">Scan complete! Found {0} game(s)</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Cancelled">Scan cancelled</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Initializing">Initializing...</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Error">Error: {0}</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Statistics.Folders">Folders</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Statistics.GamesFound">Games Found</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Button.Cancel">Cancel</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Button.Close">Close</sys:String>

    <!-- Add Games Progress Dialog -->
    <sys:String x:Key="AddGamesProgressDialog.Title">Adding Games to Library</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Subtitle">Processing discovered game files</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Statistics.Processed">Processed</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Statistics.Added">Added</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Statistics.Skipped">Skipped</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Statistics.Failed">Failed</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Button.Close">Close</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Status.Complete">Complete! Added {0} game(s)</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Status.Initializing">Initializing</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Status.Error">Error: {0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.Header">Add Game</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.ToolTip">Adds the selected game file to Xenia Manager</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.MissingStorageProvider.Title">Missing Storage Provider</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.MissingStorageProvider.Message">Storage provider is not available.&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.MissingXenia.Title">Missing Xenia</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.MissingXenia.Message">No version of Xenia is currently installed.&#10;Please install Xenia before continuing.</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.Failed.Title">Failed to add the game</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.Failed.Message">There was an error while adding {0}.&#10;{1}</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.FailedDetection.Title">Game Detection Failed</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.FailedDetection.Message">Failed to detect game details for {0}.&#10;Do you still want to add this game with limited information?</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.FilePicker.Title">Select Game to Add</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Progress.Processing">Processing: {0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Progress.SkippingDuplicate">Skipping duplicate: {0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Progress.SkippingInvalid">Skipping invalid game: {0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Progress.Processed">Processed: {0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Header">Bulk Export</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ToolTip">Bulk export all games in Xenia Manager to designated folder</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.MissingStorageProvider.Title">Missing Storage Provider</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.MissingStorageProvider.Message">Storage provider is not available.</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.FolderPicker.Title">Select Export Folder</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Success.Title">Shortcuts Exported</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Success.Message">Successfully exported {0} game shortcut(s).&#10;Failed: {1}&#10;&#10;Successful exports:&#10;{2}&#10;&#10;Failed exports:&#10;{3}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Error.Title">Export Failed</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Error.Message">There was an error while exporting game shortcuts.&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Title">Export Game Shortcuts</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Message">Where would you like to export the game shortcuts?</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Folder">Folder</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Steam">Steam</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Cancel">Cancel</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.SteamSuccess.Title">Steam Shortcuts Exported</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.SteamSuccess.Message">Successfully exported {0} Steam shortcut(s).&#10;Failed: {1}&#10;&#10;Successful exports:&#10;{2}&#10;&#10;Failed exports:&#10;{3}</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Header">Update Compatibility Ratings</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.ToolTip">Updates compatibility ratings for all games in the library from the online database</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Success.Title">Update Complete</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Success.Message">Successfully updated {0} game(s).&#10;Unchanged: {1}&#10;Failed: {2}&#10;&#10;Updated games:&#10;{3}&#10;&#10;Unchanged games:&#10;{4}&#10;&#10;Failed updates:&#10;{5}</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Error.Title">Update Failed</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Error.Message">There was an error while updating compatibility ratings.&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Header">Optimize Games</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.ToolTip">Applies optimized settings from the online database to all games in the library</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Success.Title">Optimization Complete</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Success.Message">Successfully optimized {0} game(s).&#10;Unchanged: {1}&#10;Not Found: {2}&#10;Failed: {3}&#10;&#10;Optimized games:&#10;{4}&#10;&#10;Unchanged games:&#10;{5}&#10;&#10;Games with no optimized settings:&#10;{6}&#10;&#10;Failed optimizations:&#10;{7}</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Error.Title">Optimization Failed</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Error.Message">There was an error while optimizing game settings.&#10;{0}</sys:String>

    <!-- Library Game Button - Playtime -->
    <sys:String x:Key="LibraryPage.GameButton.Playtime.Label">Time Played: </sys:String>
    <sys:String x:Key="LibraryPage.GameButton.Playtime.NeverPlayed">Never played</sys:String>
    <sys:String x:Key="LibraryPage.GameButton.Playtime.Minutes">{0} min</sys:String>
    <sys:String x:Key="LibraryPage.GameButton.Playtime.Hours">{0} hrs</sys:String>

    <!-- Library Multiselect Delete -->
    <sys:String x:Key="LibraryPage.DeleteSelected.Button">Delete Selected</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.OneGameSelected">1 game selected</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.MultipleGamesSelected">{0} games selected</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.Confirmation.Title">Delete Selected Games</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.Confirmation.Message">Do you want to remove {0}?</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.Confirmation.MultipleMessage">Do you want to remove {0} selected games?</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelectedWithContent.Confirmation.Title">Delete Game Content</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelectedWithContent.Confirmation.Message">Do you want to remove game content for all selected games?&#10;This will remove all save files and downloadable content.</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.Success.Title">Games Deleted</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.Success.Message">Successfully deleted {0} game(s).</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.PartialSuccess.Title">Partial Success</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.PartialSuccess.Message">Deleted {0} game(s), failed to delete {1} game(s).&#10;&#10;Failed games:&#10;{2}</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.Error.Title">Delete Failed</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.Error.Message">Failed to delete selected games:&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.ClearSelection.Button">Clear Selection</sys:String>

    <!-- Compatibility Rating -->
    <sys:String x:Key="CompatibilityRating.Unknown">Unknown</sys:String>
    <sys:String x:Key="CompatibilityRating.Unplayable">Unplayable</sys:String>
    <sys:String x:Key="CompatibilityRating.Loads">Loads</sys:String>
    <sys:String x:Key="CompatibilityRating.Gameplay">Gameplay</sys:String>
    <sys:String x:Key="CompatibilityRating.Playable">Playable</sys:String>

    <!-- Manage Page -->
    <sys:String x:Key="ManagePage.Emulator.Manage.Title">Emulator Management</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Description">Install and manage different Xenia emulator versions</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Canary.Title">Xenia Canary</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Netplay.Title">Xenia Netplay</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Mousehook.Title">Xenia Mousehook</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.NightlyBuild.ToolTip">Use Nightly Build</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.NotInstalled">Not Installed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.Failure.Title">Installation of Xenia {0} failed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.Failure.Message">Xenia {0} failed to install.&#10;Full Error:&#10;{1}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.Success.Title">Installation successful</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.Success.Message">Xenia {0} is installed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.AdminRequired.Title">Administrator Required</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.AdminRequired.Message">This action requires Xenia Manager to be run as Administrator.&#10;Please restart Xenia Manager with administrative privileges.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Failure.Title">Update of Xenia {0} failed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Failure.Message">Xenia {0} failed to update.&#10;Full Error:&#10;{1}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Success.Title">Update successful</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Success.Message">Xenia {0} is updated to version {1}.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.ProcessRunning.Title">Xenia {0} is running</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.ProcessRunning.Message">Cannot update Xenia {0} while it is running.&#10;Please close Xenia {0} and try again.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.CheckUpdateFailed.Title">Check Update Failed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.CheckUpdateFailed.Message">Failed to check for updates.&#10;{0}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Confirmation.Title">Uninstall confirmation</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Confirmation.Message">Do you want to uninstall Xenia {0}?&#10;This will remove all save files and updates alongside the emulator.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Failure.Title">Uninstallation of Xenia {0} failed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Failure.Message">Xenia {0} failed to uninstall.&#10;Full Error:&#10;{1}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Success.Title">Uninstallation successful</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Success.Message">Xenia {0} is uninstalled</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Downloading">Downloading Xenia {0}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.SDL.Downloading">Downloading SDL Game Controller Database</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.UpdateAvailable.Title">Update Available</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.UpdateAvailable.Message">A new version of Xenia is available.&#10;Current: {0}&#10;Latest: {1}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.UpToDate.Title">Up to Date</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.UpToDate.Message">Xenia is up to date</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Button.Install">Install</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Button.Update">Update</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Button.CheckForUpdates">Check for Updates</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Button.Uninstall">Uninstall</sys:String>
    <sys:String x:Key="ManagePage.Content.Management.Title">Content Management</sys:String>
    <sys:String x:Key="ManagePage.Content.Management.Description">Manage content and profiles</sys:String>
    <sys:String x:Key="ManagePage.Content.AutomaticSaveBackup.Title">Automatic Save Backup</sys:String>
    <sys:String x:Key="ManagePage.Content.AutomaticSaveBackup.Description">Automatically backs up the save for the selected profile</sys:String>
    <sys:String x:Key="ManagePage.Content.AutomaticSaveBackup.NoProfiles.Title">No Profiles Available</sys:String>
    <sys:String x:Key="ManagePage.Content.AutomaticSaveBackup.NoProfiles.Message">No profiles found to enable Automatic Save Backup.&#10;Please create or import a profile first.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Title">Unified content folder</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Description">Makes all Xenia versions have same content folder</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.ToolTip">NOTE: This requires Xenia Manager to be run as Administrator while installing Xenia</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.AdminRequired.Title">Administrator Required</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.AdminRequired.Message">This action requires Xenia Manager to be run as Administrator.&#10;Please restart Xenia Manager with administrative privileges.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Separate.Title">Separate Content Folders</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Separate.Message">Do you want to separate the content folders?&#10;Each Xenia version will have its own independent content directory.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Unify.Title">Unify Content Folders</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Unify.Message">Do you want to unify the content folders?&#10;All Xenia versions will share the same content directory.&#10;&#10;Select which version's content to use as the base.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Unify.Success.Title">Content Folder Unification Successful</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Unify.Success.Message">Content folders have been unified successfully.&#10;All Xenia versions now share the same content directory.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Separate.Success.Title">Content Folder Separation Successful</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Separate.Success.Message">Content folders have been separated successfully.&#10;Each Xenia version now has its own independent content directory.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Operation.Failed.Title">Content Folder Operation Failed</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Operation.Failed.Message">Failed to unify/separate content folders.&#10;Error: {0}</sys:String>

    <!-- Install Content Section -->
    <sys:String x:Key="ManagePage.Content.ManageProfiles.Title">Manage Profiles</sys:String>
    <sys:String x:Key="ManagePage.Content.ManageProfiles.Description">Allows the user to modify Xenia Profiles</sys:String>
    <sys:String x:Key="ManagePage.ManageProfiles.Button">Manage</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.Title">Install Content</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.Description">Install DLC, updates, and other content for Xenia</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.Button">Install Content</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.NoEmulator.Title">No Emulator Installed</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.NoEmulator.Message">Please install at least one version of Xenia before installing content.</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.Failed.Title">Content Installation Failed</sys:String>
    <sys:String x:Key="ManagePage.Content.Install.Failed.Message">Failed to install content.&#10;Error: {0}</sys:String>
    <sys:String x:Key="ManagePage.Content.RedownloadXenia.Title">Redownload Xenia</sys:String>
    <sys:String x:Key="ManagePage.Content.RedownloadXenia.Description">Redownload and reinstall the selected Xenia version</sys:String>
    <sys:String x:Key="ManagePage.Content.RedownloadXenia.Button">Redownload</sys:String>
    <sys:String x:Key="ManagePage.Content.RedownloadXenia.NoEmulator.Title">No Emulator Installed</sys:String>
    <sys:String x:Key="ManagePage.Content.RedownloadXenia.NoEmulator.Message">Please install at least one version of Xenia before redownloading.</sys:String>
    <sys:String x:Key="ManagePage.Content.RedownloadXenia.Confirmation.Title">Redownload Confirmation</sys:String>
    <sys:String x:Key="ManagePage.Content.RedownloadXenia.Confirmation.Message">Do you want to redownload Xenia {0}?&#10;This will delete the current installation and download a fresh copy.&#10;&#10;NOTE: This will NOT delete your content, saves, or configuration files.</sys:String>
    <sys:String x:Key="ManagePage.Content.RedownloadXenia.Success.Title">Redownload Complete</sys:String>
    <sys:String x:Key="ManagePage.Content.RedownloadXenia.Success.Message">Xenia {0} has been successfully redownloaded and installed.</sys:String>
    <sys:String x:Key="ManagePage.Content.RedownloadXenia.Failed.Title">Redownload Failed</sys:String>
    <sys:String x:Key="ManagePage.Content.RedownloadXenia.Failed.Message">Failed to redownload Xenia.&#10;Error: {0}</sys:String>
    <sys:String x:Key="ManagePage.Content.ExportLogs.Title">Export Logs</sys:String>
    <sys:String x:Key="ManagePage.Content.ExportLogs.Description">Export Xenia log file to a specified location</sys:String>
    <sys:String x:Key="ManagePage.Content.ExportLogs.Button">Export Logs</sys:String>
    <sys:String x:Key="ManagePage.Content.ExportLogs.NoEmulator.Title">No Emulator Installed</sys:String>
    <sys:String x:Key="ManagePage.Content.ExportLogs.NoEmulator.Message">Please install at least one version of Xenia before exporting logs.</sys:String>
    <sys:String x:Key="ManagePage.Content.ExportLogs.MissingStorageProvider.Title">Missing Storage Provider</sys:String>
