    <!-- Game Button -->
    <sys:String x:Key="GameButton.ContextFlyout.Content.Header">Content</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Content.InstalledContent.Header">View Installed Content</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Content.SaveBackup.Header">Save Backups</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Content.SaveBackup.Tooltip">Opens the folder containing all of the save backups made by Xenia Manager</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Content.SaveBackup.NoBackups.Title">No Save Backups Found</sys:String>
    <sys:String x:Key="GameButton.ContextFlyout.Content.SaveBackup.NoBackups.Message">No automatic save backups found for this game.</sys:String>
