    <sys:String x:Key="MousehookControlsEditorDialog.Key.ToolTip">Odaberite tipku tipkovnice za kontrolu</sys:String>
    <sys:String x:Key="MousehookControlsEditorDialog.Value.ToolTip">Odaberite unos kontrolera za kontrolu</sys:String>
