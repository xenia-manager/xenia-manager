    <sys:String x:Key="MousehookControlsEditorDialog.NoBindingsFound">Kontrole nisu pronađene</sys:String>
    <sys:String x:Key="MousehookControlsEditorDialog.RemoveEntry.ToolTip">Ukloni ovu kontrolu</sys:String>
    <sys:String x:Key="MousehookControlsEditorDialog.DetectInput.ToolTip">Prepoznaj unos</sys:String>
    <sys:String x:Key="MousehookControlsEditorDialog.DetectInput.SubToolTip">Pritisnite tipku ili gumb miša za prepoznavanje</sys:String>
    <sys:String x:Key="MousehookControlsEditorDialog.DetectInput.NoInputDetected.Title">Unos nije prepoznat</sys:String>
    <sys:String x:Key="MousehookControlsEditorDialog.DetectInput.NoInputDetected.Message">Unos tipkovnice ili miša nije prepoznat unutar 10 sekundi.</sys:String>
    <sys:String x:Key="MousehookControlsEditorDialog.DetectInput.Error.Title">Greška pri prepoznavanju unosa</sys:String>
    <sys:String x:Key="MousehookControlsEditorDialog.DetectInput.Error.Message">Došlo je do greške prilikom prepoznavanja unosa. Molimo pokušajte ponovno.</sys:String>
