    <!-- Config UI Settings - APU Options -->
    <sys:String x:Key="ConfigUiSettings.APU.apu.Title">Zvučni sustav</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.Comment">Zvučni sustav</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.any">Automatski</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.nop">Bez zvuka</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.sdl">SDL</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.xaudio2">XAudio2</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu_max_queued_frames.Title">Maksimalni broj audio okvira u redu</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu_max_queued_frames.Comment">Omogućuje promjenu maksimalnog broja spremljenih audio okvira za smanjenje kašnjenja zvuka&#10;Smanjenje ove vrijednosti može uzrokovati probleme s performansama</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.mute.Title">Isključi zvuk</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.mute.Comment">Isključuje sav zvučni izlaz</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.enable_xmp.Title">XMP</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.enable_xmp.Comment">Omogućuje reprodukciju glazbenog playera&#10;Ovo može popraviti glazbu u nekim igrama</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xmp_default_volume.Title">Zadana glasnoća XMP-a</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xmp_default_volume.Comment">Zadana glasnoća glazbe ako igra ne postavi vlastitu</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_dedicated_xma_thread.Title">Namjenska XMA nit</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_dedicated_xma_thread.Comment">Omogućuje XMA dekodiranje na zasebnoj niti&#10;S ovom opcijom onemogućenom, očekujte bolje rezultate, ali niže performanse</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_new_decoder.Title">XMA audio dekoder</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_new_decoder.Comment">Omogućuje korištenje novog XMA audio dekodera</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.Title">XMA dekoder</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.Comment">fake: Zvuk se neće dekodirati&#10;master: Verzija dekodera identična osnovnoj verziji Xenia&#10;old: Dekoder temeljen na master verziji s nekoliko poboljšanja&#10;new: Nova verzija dekodera. Pruža najvišu stabilnost, ali još nije završena</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.fake">Lažni</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.master">Master</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.old">Stari</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.new">Novi</sys:String>

    <!-- Config UI Settings - Content Options -->
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.Title">Maska licence</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.Comment">- Bez licence: Demo način rada&#10;- Prva licenca: Općenito puna verzija licence u Xbox Live Arcade naslovima&#10;- Sve licence: Sve moguće licence omogućene, ali može dovesti do neočekivanog ponašanja</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.0">Bez licence</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.1">Prva licenca</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.-1">Sve licence</sys:String>

    <!-- Config UI Settings - CPU Options -->
    <sys:String x:Key="ConfigUiSettings.CPU.break_on_unimplemented_instructions.Title">Prekini na neimplementiranim instrukcijama</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.break_on_unimplemented_instructions.Comment">Prekini na host debugger (ili sruši se ako debugger nije spojen) ako se naiđe na neimplementiranu PowerPC instrukciju</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disable_context_promotion.Title">Onemogući promociju konteksta</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disable_context_promotion.Comment">Onemogućuje optimizacije promocije konteksta&#10;Ovo može biti potrebno za neke sportske igre, ali će smanjiti performanse</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disassemble_functions.Title">Disasembliraj funkcije</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disassemble_functions.Comment">Disasembliraj funkcije tijekom generiranja</sys:String>

    <!-- Config UI Settings - D3D12 Options -->
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_allow_variable_refresh_rate_and_tearing.Title">Dopusti promjenjivu stopu osvježavanja i tearing</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_allow_variable_refresh_rate_and_tearing.Comment">U načinu punog zaslona, dopusti korištenje promjenjive stope osvježavanja na zaslonima koji to podržavaju&#10;Na zaslonima koji ne podržavaju VRR, tearing se može pojaviti u određenim slučajevima</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.Title">Prioritet reda čekanja</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.Comment">Prioritet raspoređivanja reda čekanja grafičkih (direktnih) naredbi&#10;0 - Normalan&#10;1 - Visok&#10;2 - Globalni prioritet u stvarnom vremenu koji zahtijeva administratorske ovlasti i može utjecati na odzivnost sustava</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.0">Normalan</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.1">Visok</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.2">Globalni prioritet u stvarnom vremenu</sys:String>

    <!-- Config UI Settings - Display Options -->
    <sys:String x:Key="ConfigUiSettings.Display.fullscreen.Title">Puni zaslon</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.fullscreen.Comment">Pokreni emulator u načinu punog zaslona</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.present_letterbox.Title">Letterbox prikaz</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.present_letterbox.Comment">Održavaj omjer slike pri rastezanju prikazivanjem crnih traka oko slike kada nema više overscan područja za izrezivanje</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.Title">Izglađivanje rubova</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.Comment">Efekt izglađivanja rubova koji se primjenjuje na izlaznu sliku igre</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.none">Bez</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.fxaa">FXAA</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.fxaa_extreme">FXAA ekstremno</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.Title">Skaliranje i izoštravanje</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.Comment">Efekt za korištenje za ponovno uzorkovanje i/ili izoštravanje konačnog izlaza prikaza</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.bilinear">Bilinearno</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.cas">CAS</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.fsr">FSR</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_sharpness_reduction.Title">FSR smanjenje oštrine</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_sharpness_reduction.Comment">Smanjenje oštrine za AMD FidelityFX Super Resolution 1.0 (FSR)&#10;Niža vrijednost je oštrija</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_cas_additional_sharpness.Title">CAS dodatno izoštravanje</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_cas_additional_sharpness.Comment">Dodatno izoštravanje za AMD FidelityFX Contrast Adaptive Sharpening (CAS), od 0 do 1&#10;Viša vrijednost je oštrija</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_max_upsampling_passes.Title">FSR maksimalni broj prolaza povećanja</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_max_upsampling_passes.Comment">Maksimalni broj prolaza povećanja u AMD FidelityFX Super Resolution 1.0 (FSR) prije prelaska na bilinearno rastezanje nakon završnog prolaza</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_dither.Title">Dithering</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_dither.Comment">Primijeni dithering na konačnu izlaznu sliku iz interne preciznosti na 8 bita po kanalu kako bi prijelazi boja bili glađi</sys:String>

    <!-- Config UI Settings - General Options -->
    <sys:String x:Key="ConfigUiSettings.General.allow_plugins.Title">Dopusti dodatke</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.allow_plugins.Comment">Omogućuje učitavanje dodataka/trenera iz plugins\\title_id\\plugin.xex&#10;Dodaci su homebrew xex moduli koji se mogu koristiti za izradu modifikacija&#10;Ova značajka je eksperimentalna</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.discord.Title">Discord Rich Presence</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.discord.Comment">Omogući Discord Rich Presence</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.apply_patches.Title">Primijeni zakrpe</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.apply_patches.Comment">Omogućuje funkcionalnost prilagođenih zakrpa</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.controller_hotkeys.Title">Prečaci kontrolera</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.controller_hotkeys.Comment">Prečaci za Xbox i PS kontrolere</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.launch_module.Title">Modul za pokretanje</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.launch_module.Comment">Izvršna datoteka za pokretanje iz .iso datoteke ili paketa umjesto default.xex ili modula koji igra specificira&#10;Ostavite prazno za pokretanje zadanog modula</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.notification_sound_path.Title">Putanja zvuka obavijesti</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.notification_sound_path.Comment">Putanja (uključujući naziv datoteke) do odabranog zvuka obavijesti&#10;NAPOMENA: Zvuk MORA biti u wav formatu!</sys:String>

    <!-- Config UI Settings - GPU Options -->
    <sys:String x:Key="ConfigUiSettings.GPU.vsync.Title">VSync</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.vsync.Comment">Omogući vertikalnu sinkronizaciju</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.framerate_limit.Title">Ograničenje broja sličica</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.framerate_limit.Comment">Maksimalni broj sličica u sekundi&#10;0 = Neograničeno&#10;Zadano je 60 kada je postavljeno na 0 i VSync je omogućen</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.Title">Grafički sustav</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.Comment">Grafički sustav za korištenje</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.any">Automatski</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.d3d12">D3D12</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.vulkan">Vulkan</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.null">Bez grafike</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.Title">Putanja ciljeva renderiranja (D3D12)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.Comment">Putanja emulacije ciljeva renderiranja za korištenje na Direct3D 12&#10;RTV - Host ciljevi renderiranja&#10;ROV - Rasterizer-ordered views</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.any">Automatski</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.rtv">RTV</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.rov">ROV</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.Title">Putanja ciljeva renderiranja (Vulkan)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.Comment">Putanja emulacije ciljeva renderiranja za korištenje na Vulkan&#10;FBO - Host framebufferi&#10;FSI - Fragment shader interlock</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.any">Automatski</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.fbo">FBO</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.fsi">FSI</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.Title">Readback resolve</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.Comment">Kontrolira CPU readback rezultata render-to-texture resolve&#10;None - onemogući readback&#10;Fast - kašnjenje od 1 sličice&#10;Full - točno ali sporo</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.none">Bez</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.fast">Brzo</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.full">Potpuno</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_x.Title">Skaliranje rezolucije crtanja X</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_x.Comment">Cjelobrojno skaliranje širine piksela koje se koristi za skaliranje rezolucije renderiranja transparentno za igru</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_y.Title">Skaliranje rezolucije crtanja Y</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_y.Comment">Cjelobrojno skaliranje visine piksela koje se koristi za skaliranje rezolucije renderiranja transparentno za igru</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu_allow_invalid_fetch_constants.Title">Dopusti nevažeće fetch konstante</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu_allow_invalid_fetch_constants.Comment">Dopusti teksturne i vertex fetch konstante s nevažećim tipom&#10;Općenito nesigurno, ali se može koristiti za zaobilaženje grešaka fetch konstanti u određenim igrama</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gamma_render_target_as_srgb.Title">Gamma cilj renderiranja kao sRGB</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gamma_render_target_as_srgb.Comment">Kada host ne može izravno pisati po dijelovima linearnu gamu s ispravnim miješanjem, koristi sRGB izlaz na hostu za konceptualno ispravno miješanje u linearnom prostoru boja</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_lower_threshold.Title">Donji prag uzorka okluzije</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_lower_threshold.Comment">Ako je postavljeno na -1, brojevi uzoraka se ne zapisuju, igre se mogu zamrznuti&#10;Inače, broj uzoraka svake pločice bit će povećan za ovaj broj na svakom EVENT_WRITE_ZPD</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_upper_threshold.Title">Gornji prag uzorka okluzije</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_upper_threshold.Comment">Postavite na veći broj od query_occlusion_sample_lower_threshold&#10;Ova vrijednost se ignorira ako je query_occlusion_sample_lower_threshold postavljen na -1</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.use_fuzzy_alpha_epsilon.Title">Koristi približnu alfa epsilon</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.use_fuzzy_alpha_epsilon.Comment">Koristi približnu usporedbu za alfa vrijednosti kako bi se spriječilo treperenje na NVIDIA grafičkim karticama</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.clear_memory_page_state.Title">Očisti stanje memorijske stranice</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.clear_memory_page_state.Comment">Osvježi stanje memorijskih stranica kako bi se omogućili podaci koje je GPU zapisao</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.Title">Prisilno anizotropno filtriranje</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.Comment">Forsira anizotropno filtriranje (AF) za odgovarajuće teksture&#10;Više vrijednosti održavaju teksture oštrije pod kosim kutovima uz cijenu GPU propusnosti&#10;U rijetkim slučajevima, forsiranje AF može uvesti vizualne artefakte</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.-1">Bez prisiljavanja (Zadano)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.0">Onemogući anizotropno filtriranje</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.1">1x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.2">2x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.3">4x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.4">8x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.5">16x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.async_shader_compilation.Title">Asinkrona kompilacija shadera</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.async_shader_compilation.Comment">Kompiliraj shadere i stvaraj pipeline-ove asinkrono u pozadinskim nitima&#10;Eliminira zastajkivanje zbog kompilacije shadera, ali može uzrokovati kratke artefakte renderiranja dok se pipeline-ovi stvaraju&#10;Kada je onemogućeno, pipeline-ovi se stvaraju sinkrono što uzrokuje zastajkivanje ali bez vizualnih artefakata</sys:String>

    <!-- Config UI Settings - HID Options -->
    <sys:String x:Key="ConfigUiSettings.HID.hid.Title">Ulazni sustav</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.Comment">Ulazni sustav za korištenje</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.any">Automatski</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.nop">Bez unosa</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.sdl">SDL</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.winkey">WinKey</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.xinput">XInput</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.Title">Način rada tipkovnice</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.Comment">Omogućuje određivanje načina rada tipkovnice:&#10;0 - Onemogućeno&#10;1 - Omogućeno&#10;2 - Passthrough koji zahtijeva spojeni kontroler</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.0">Onemogućeno</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.1">Omogućeno</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.2">Passthrough</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_user_index.Title">Indeks korisnika tipkovnice</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_user_index.Comment">Port kontrolera koji tipkovnica emulira (0-3)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.left_stick_deadzone_percentage.Title">Mrtva zona lijeve palice</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.left_stick_deadzone_percentage.Comment">Definira razinu mrtve zone za lijevu palicu (0-100%)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.right_stick_deadzone_percentage.Title">Mrtva zona desne palice</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.right_stick_deadzone_percentage.Comment">Definira razinu mrtve zone za desnu palicu (0-100%)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.vibration.Title">Vibracija</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.vibration.Comment">Uključi/isključi vibraciju kontrolera</sys:String>

    <!-- Config UI Settings - Kernel Options -->
    <sys:String x:Key="ConfigUiSettings.Kernel.apply_title_update.Title">Primijeni ažuriranje naslova</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.apply_title_update.Comment">Primijeni ažuriranja naslova</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.cl.Title">Naredbeni redak</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.cl.Comment">Navedite dodatni naredbeni redak koji se prosljeđuje gostu</sys:String>

    <!-- Config UI Settings - Memory Options -->
    <sys:String x:Key="ConfigUiSettings.Memory.protect_zero.Title">Zaštiti nultu stranicu</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.protect_zero.Comment">Zaštiti nultu stranicu od čitanja i pisanja</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.scribble_heap.Title">Scribble heap</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.scribble_heap.Comment">Upiši specifičnu ili nasumičnu vrijednost u svu dodijeljenu heap memoriju</sys:String>

    <!-- Config UI Settings - Storage Options -->
    <sys:String x:Key="ConfigUiSettings.Storage.mount_cache.Title">Montiraj predmemoriju</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_cache.Comment">Omogući montiranje predmemorije</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_scratch.Title">Montiraj scratch</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_scratch.Comment">Omogući scratch montiranje</sys:String>

    <!-- Config UI Settings - UI Options -->
    <sys:String x:Key="ConfigUiSettings.UI.show_achievement_notification.Title">Prikaži obavijest o postignuću</sys:String>
    <sys:String x:Key="ConfigUiSettings.UI.show_achievement_notification.Comment">Prikaži obavijest o postignuću na zaslonu</sys:String>

    <!-- Config UI Settings - Video Options -->
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.Title">Interna rezolucija prikaza</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.Comment">Omogući igrama koje podržavaju različite rezolucije da se renderiraju u određenoj rezoluciji</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.0">640x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.1">640x576</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.2">720x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.3">720x576</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.4">800x600</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.5">848x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.6">1024x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.7">1152x864</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.8">1280x720</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.9">1280x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.10">1280x960</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.11">1280x1024</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.12">1360x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.13">1440x900</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.14">1680x1050</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.15">1920x540</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.16">1920x1080</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.17">Prilagođeno (X/Y)</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_x.Title">Prilagođena širina rezolucije</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_x.Comment">Prilagođena širina za internu rezoluciju prikaza</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_y.Title">Prilagođena visina rezolucije</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_y.Comment">Prilagođena visina za internu rezoluciju prikaza</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.widescreen.Title">Široki zaslon</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.widescreen.Comment">Prebacuj između omjera slike 16:9 i 4:3</sys:String>

    <!-- Config UI Settings - Vulkan Options -->
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_immediate.Title">Dopusti način trenutnog prikaza</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_immediate.Comment">Kada je dostupno, dopusti način trenutnog prikaza (1. prioritet), koji nudi najniže kašnjenje s mogućnošću tearinga u određenim slučajevima</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_mailbox.Title">Dopusti mailbox način prikaza</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_mailbox.Comment">Kada je dostupno, dopusti mailbox način prikaza (2. prioritet), koji nudi nisko kašnjenje bez mogućnosti tearinga</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_fifo_relaxed.Title">Dopusti opušteni FIFO način prikaza</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_fifo_relaxed.Comment">Kada je dostupno, dopusti opušteni first-in-first-out način prikaza (3. prioritet), koji uzrokuje čekanje na vertikalnu sinkronizaciju host zaslona, ali može prikazivati s tearingom ako sličice ne zadovoljavaju stopu osvježavanja host zaslona</sys:String>

    <!-- Config UI Settings - Live/Netplay Options -->
    <sys:String x:Key="ConfigUiSettings.Live.api_address.Title">API adresa</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.api_address.Comment">Adresa Xenia servera (npr. IP:PORT)</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.discord_presence_user_index.Title">Discord Rich Presence indeks korisnika</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.discord_presence_user_index.Comment">Indeks korisničkog profila koji se koristi za Discord Rich Presence [0-3]</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.Title">Mrežni način rada</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.Comment">Mrežni način rada&#10;0 - Izvanmrežno&#10;1 - Systemlink&#10;2 - Xbox Live</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.0">Izvanmrežno</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.1">Systemlink</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.2">Xbox Live</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.upnp.Title">UPnP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.upnp.Comment">Automatski proslijedi port koristeći UPnP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xhttp.Title">XHTTP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xhttp.Comment">Uključi/isključi XHTTP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xlink_kai_systemlink_hack.Title">XLink Kai SystemLink hack</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xlink_kai_systemlink_hack.Comment">Omogući hackove za XLink Kai podršku&#10;Može pokvariti neke igre</sys:String>

    <!-- Config UI Settings - MouseHook Options -->
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_autoaim.Title">Onemogući automatsko ciljanje</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_autoaim.Comment">Onemogući automatsko ciljanje u igrama koje to podržavaju (GoldenEye, Perfect Dark, Saints Row, COD)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_fullscreen_esc_bind.Title">Onemogući ESC za izlaz iz punog zaslona</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_fullscreen_esc_bind.Comment">Onemogućuje izlaz iz punog zaslona pritiskom na Escape kada je u punom zaslonu</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.fov_sensitivity.Title">FOV osjetljivost</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.fov_sensitivity.Comment">Skaliranje miša kada je FOV smanjen (COD, DR, RDR i UE3 igre)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_aim_turn_distance.Title">(GoldenEye/Perfect Dark)&#10;Udaljenost okreta ciljanja</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_aim_turn_distance.Comment">(GoldenEye/Perfect Dark) Udaljenost koju nišan može prijeći u načinu ciljanja prije okretanja kamere</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_debug_menu.Title">(GoldenEye)&#10;Debug izbornik</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_debug_menu.Comment">(GoldenEye) Omogućuje debug izbornik, dostupan s LB/1</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_gun_sway.Title">(GoldenEye/Perfect Dark)&#10;Njihanje oružja</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_gun_sway.Comment">(GoldenEye/Perfect Dark) Omogući njihanje oružja dok se kamera okreće</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_remove_blur.Title">(GoldenEye)&#10;Ukloni zamućenje</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_remove_blur.Comment">(GoldenEye) Uklanja zamućenje niske rezolucije u načinu klasične grafike</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.internal_hook.Title">Interni hook</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.internal_hook.Comment">Koristi bolju tehniku hookanja za bolje rezultate ubrizgavanja miša (Saints Row 1)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_x.Title">Invertiraj X os</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_x.Comment">Invertiraj X os miša</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_y.Title">Invertiraj Y os</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_y.Comment">Invertiraj Y os miša</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.menu_sensitivity.Title">(GoldenEye/Saints Row 1)&#10;Osjetljivost u izbornicima</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.menu_sensitivity.Comment">(GoldenEye/Saints Row 1) Osjetljivost miša u izbornicima</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_snappy_wheel.Title">(Red Dead Redemption)&#10;Brzi kotač</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_snappy_wheel.Comment">(Red Dead Redemption) Zaključava kotač oružja u koracima od 45 stupnjeva</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_turbo_gallop_horse.Title">(Red Dead Redemption)&#10;Turbo galop</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_turbo_gallop_horse.Comment">(Red Dead Redemption) Omogućuje turbo galopiranje za konje i kočije</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sensitivity.Title">Osjetljivost miša</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sensitivity.Comment">Osjetljivost miša</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.source_sniper_sensitivity.Title">Source sniper osjetljivost</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.source_sniper_sensitivity.Comment">Osjetljivost snajperskog nišana u Source engineu</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr1_increase_vehicle_rotation_limit.Title">(Saints Row 1)&#10;Ograničenje rotacije vozila</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr1_increase_vehicle_rotation_limit.Comment">(Saints Row 1) Zakrpa ograničenja vertikalne rotacije vozila da bude uglavnom isto kao pješice</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_better_handbrake_cam.Title">(Saints Row 2)&#10;Bolja kamera pri ručnoj kočnici</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_better_handbrake_cam.Comment">(Saints Row 2) Odvaja X rotaciju od vozila pri korištenju ručne kočnice slično SR1</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_hold_fine_aim.Title">(Saints Row 2)&#10;Drži za precizno ciljanje</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_hold_fine_aim.Comment">(Saints Row 2) Prebacuje precizno ciljanje (ADS) s prekidača na držanje</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_better_drive_cam.Title">(Saints Row 1 i 2)&#10;Bolja kamera pri vožnji</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_better_drive_cam.Comment">(Saints Row 1 i 2) Odvaja X rotaciju od vozila kada je automatsko centriranje onemogućeno</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_disable_shared_reload.Title">(Saints Row 1)&#10;Onemogući dijeljeno ponovno punjenje</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_disable_shared_reload.Comment">(Saints Row 1) Onemogućuje ponovno punjenje oružja pritiskom na internu (A) tipku</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.swap_wheel.Title">(Saints Row 1)&#10;Zamijeni kotač</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.swap_wheel.Comment">Zamjenjuje postavke vezanja za kotač oružja i smjer zumiranja mape u Saints Row 1</sys:String>

    <!-- About Page -->
    <sys:String x:Key="AboutPage.App.Description">Sveobuhvatan alat za upravljanje Xenia emulatorom. Jednostavno instalirajte, ažurirajte i upravljajte različitim verzijama Xenia emulatora s intuitivnim sučeljem.</sys:String>
    <sys:String x:Key="AboutPage.WebsiteButton.Text">Web stranica</sys:String>
    <sys:String x:Key="AboutPage.GithubButton.Text">GitHub</sys:String>
