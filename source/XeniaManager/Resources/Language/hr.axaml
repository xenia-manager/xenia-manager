    <sys:String x:Key="MousehookControlsEditorDialog.Validation.Key.None">Tipka ne može biti "None" za postavku vezanja "{0}". Molimo odaberite valjanu tipku.</sys:String>
    <sys:String x:Key="MousehookControlsEditorDialog.Validation.Value.None">Vrijednost ne može biti "None" za postavku vezanja "{0}". Molimo odaberite valjani unos kontrolera.</sys:String>

