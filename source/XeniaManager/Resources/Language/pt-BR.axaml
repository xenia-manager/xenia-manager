    <!-- Config UI Settings - APU Options -->
    <sys:String x:Key="ConfigUiSettings.APU.apu.Title">Audio System</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.Comment">Sistema de Áudio</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.any">Any</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.nop">Nop</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.sdl">SDL</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.xaudio2">XAudio2</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu_max_queued_frames.Title">Audio Max Queued Frames</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu_max_queued_frames.Comment">Permite alterar o número máximo de quadros de áudio em buffer para reduzir o atraso de áudio.&#10;Diminuir esse valor pode causar problemas de desempenho.</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.mute.Title">Mute Audio</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.mute.Comment">Silencia toda a saída de áudio.</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.enable_xmp.Title">XMP</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.enable_xmp.Comment">Ativa a reprodução do reprodutor de música.&#10;Isso pode corrigir problemas de música em alguns jogos.</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xmp_default_volume.Title">XMP Default Volume</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xmp_default_volume.Comment">Volume padrão da música se o jogo não o definir.</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_dedicated_xma_thread.Title">Dedicated XMA Thread</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_dedicated_xma_thread.Comment">Ativa a decodificação XMA em uma thread separada.&#10;Com essa opção desativada, espere melhores resultados, mas menor desempenho.</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_new_decoder.Title">XMA Audio Decoder</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_new_decoder.Comment">Ativa o uso da nova decodificação de áudio XMA.</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.Title">XMA Decoder</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.Comment">fake: Nenhum áudio será reproduzido&#10;master: Versão do decodificador exatamente igual à versão base do Xenia&#10;old: Decodificador baseado na versão mestre do decodificador com algumas melhorias&#10;new: Nova versão do decodificador. Oferece a maior estabilidade, mas ainda não está finalizado</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.fake">Fake</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.master">Master</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.old">Old</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.new">New</sys:String>

    <!-- Config UI Settings - Content Options -->
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.Title">License Mask</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.Comment">- No License: Modo Demo&#10;- First License: Geralmente a licença da versão completa em títulos do Xbox Live Arcade&#10;- All Licenses: Todas as licenças possíveis habilitadas, mas isso pode levar a comportamentos indefinidos</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.0">No Licenses</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.1">First License</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.-1">All Licenses</sys:String>

    <!-- Config UI Settings - CPU Options -->
    <sys:String x:Key="ConfigUiSettings.CPU.break_on_unimplemented_instructions.Title">Break on Unimplemented Instructions</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.break_on_unimplemented_instructions.Comment">Interromper para o depurador do host (ou travar se nenhum depurador estiver conectado) se uma instrução PowerPC não implementada for encontrada</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disable_context_promotion.Title">Disable Context Promotion</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disable_context_promotion.Comment">Disables Context Promotion optimizations&#10;Isso pode ser necessário para alguns jogos de esportes, mas reduzirá o desempenho</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disassemble_functions.Title">Disassemble Functions</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disassemble_functions.Comment">Desmontar funções durante a geração</sys:String>

    <!-- Config UI Settings - D3D12 Options -->
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_allow_variable_refresh_rate_and_tearing.Title">Allow Variable Refresh Rate and Tearing</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_allow_variable_refresh_rate_and_tearing.Comment">Em tela cheia, permitir o uso de taxa de atualização variável em monitores que a suportam&#10;Em monitores que não suportam VRR, a quebra de tela pode ocorrer em certos casos</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.Title">Queue Priority</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.Comment">Prioridade de agendamento da fila de comandos gráficos (diretos)&#10;0 - Normal&#10;1 - High&#10;2 - Global Realtime which requires administrator privileges and may impact system responsibility</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.0">Normal</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.1">High</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.2">Global Realtime</sys:String>

    <!-- Config UI Settings - Display Options -->
    <sys:String x:Key="ConfigUiSettings.Display.fullscreen.Title">Fullscreen</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.fullscreen.Comment">Indica se o emulador deve ser iniciado em tela cheia</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.present_letterbox.Title">Present Letterbox</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.present_letterbox.Comment">Manter a proporção da imagem ao esticar, exibindo barras ao redor da imagem quando não houver mais área de sobreposição para cortar</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.Title">Anti-Aliasing</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.Comment">Efeito de antisserrilhamento de pós-processamento a ser aplicado à saída de imagem do jogo</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.none">None</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.fxaa">FXAA</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.fxaa_extreme">FXAA Extreme</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.Title">Scaling and Sharpening</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.Comment">Efeito de pós-processamento usado para reamostragem e/ou nitidez da saída de exibição final</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.bilinear">Bilinear</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.cas">CAS</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.fsr">FSR</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_sharpness_reduction.Title">FSR Sharpness Reduction</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_sharpness_reduction.Comment">Redução de nitidez para AMD FidelityFX Super Resolution 1.0 (FSR), em pontos&#10;Quanto menor, mais nítido</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_cas_additional_sharpness.Title">CAS Additional Sharpness</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_cas_additional_sharpness.Comment">Nitidez adicional para AMD FidelityFX Contrast Adaptive Sharpening (CAS), de 0 a 1&#10;Quanto maior, melhor Mais nítido</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_max_upsampling_passes.Title">FSR Max Upsampling Passes</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_max_upsampling_passes.Comment">Número máximo de passagens de upsampling realizadas no AMD FidelityFX Super Resolution 1.0 (FSR) antes de retornar ao alongamento bilinear após a passagem final</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_dither.Title">Dither</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_dither.Comment">Aplica dithering à imagem final, da precisão interna para 8 bits por canal, para que os gradientes fiquem mais suaves</sys:String>

    <!-- Config UI Settings - General Options -->
    <sys:String x:Key="ConfigUiSettings.General.allow_plugins.Title">Allow Plugins</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.allow_plugins.Comment">Permite o carregamento de plugins/trainers de plugins\\title_id\\plugin.xex.&#10;Plugins são módulos xex caseiros que podem ser usados ​​para criar mods. Este recurso é experimental</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.discord.Title">Discord Rich Presence</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.discord.Comment">Enable Discord rich presence</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.apply_patches.Title">Apply Patches</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.apply_patches.Comment">Ativar a funcionalidade de aplicação de patches personalizados</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.controller_hotkeys.Title">Controller Hotkeys</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.controller_hotkeys.Comment">Teclas de atalho para controles de Xbox e PS</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.launch_module.Title">Launch Module</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.launch_module.Comment">Executável para iniciar a partir do arquivo .iso ou do pacote, em vez de default.xex ou do módulo Especificado pelo jogo;&#10;Deixe em branco para iniciar o módulo padrão</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.notification_sound_path.Title">Notification Sound Path</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.notification_sound_path.Comment">Caminho (incluindo o nome do arquivo) para o som de notificação selecionado;&#10;OBSERVAÇÃO: O som DEVE estar no formato WAV!</sys:String>

    <!-- Config UI Settings - GPU Options -->
    <sys:String x:Key="ConfigUiSettings.GPU.vsync.Title">VSync</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.vsync.Comment">Habilitar VSYNC</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.framerate_limit.Title">Framerate Limit</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.framerate_limit.Comment">Quadros máximos por segundo.&#10;0 = Quadros ilimitados.&#10;O padrão é 60 quando definido como 0 e o VSync está habilitado.</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.Title">Graphics System</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.Comment">Sistema gráfico a ser usado</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.any">Any</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.d3d12">D3D12</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.vulkan">Vulkan</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.null">Null</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.Title">Render Target Path (D3D12)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.Comment">Caminho de emulação do destino de renderização a ser usado no Direct3D 12.&#10;RTV - Destinos de renderização do host.&#10;ROV - Visualizações ordenadas pelo rasterizador.</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.any">Auto</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.rtv">RTV</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.rov">ROV</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.Title">Render Target Path (Vulkan)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.Comment">Caminho de emulação do destino de renderização a ser usado no Vulkan.&#10;FBO - Framebuffers do host.&#10;FSI - Intertravamento do shader de fragmento.</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.any">Auto</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.fbo">FBO</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.fsi">FSI</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.Title">Readback Resolve</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.Comment">Controla a leitura da CPU dos resultados da resolução de renderização para textura.&#10;None - desabilitar leitura&#10;Fast - atraso de 1 quadro&#10;Full - preciso, mas Lento</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.none">None</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.fast">Fast</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.full">Full</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_x.Title">Draw Resolution Scale X</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_x.Comment">Escala de largura em pixels (inteiros) usada para dimensionar a resolução de renderização de forma opaca ao jogo</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_y.Title">Draw Resolution Scale Y</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_y.Comment">Escala de altura em pixels (inteiros) usada para dimensionar a resolução de renderização de forma opaca ao jogo</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu_allow_invalid_fetch_constants.Title">Allow Invalid Fetch Constants</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu_allow_invalid_fetch_constants.Comment">Permite constantes de busca de textura e vértice com tipo inválido.&#10;Geralmente inseguro, mas pode ser usado para contornar erros de tipo de constante de busca em certos jogos.</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gamma_render_target_as_srgb.Title">Gamma Render Target as sRGB</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gamma_render_target_as_srgb.Comment">Quando o host não consegue gravar gama linear por partes diretamente com a mistura correta, use a saída sRGB no host para uma mistura conceitualmente correta no espaço de cores linear.</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_lower_threshold.Title">Query Occlusion Lower Threshold</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_lower_threshold.Comment">Se definido como -1, nenhuma contagem de amostras será gravada; os jogos podem travar.&#10;Caso contrário, a contagem de amostras de cada bloco será incrementada a cada EVENT_WRITE_ZPD por este número.</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_upper_threshold.Title">Query Occlusion Upper Threshold</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_upper_threshold.Comment">Definido para um número maior que query_occlusion_sample_lower_threshold&#10;Este valor é ignorado se query_occlusion_sample_lower_threshold estiver definido como -1</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.use_fuzzy_alpha_epsilon.Title">Use Fuzzy Alpha Epsilon</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.use_fuzzy_alpha_epsilon.Comment">Use comparação aproximada para valores alfa para evitar oscilações em placas gráficas NVIDIA</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.clear_memory_page_state.Title">Clear Memory Page State</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.clear_memory_page_state.Comment">Atualiza o estado das páginas de memória para habilitar dados gravados pela GPU</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.Title">Anisotropic Filtering Override</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.Comment">Força a filtragem anisotrópica (AF) para texturas elegíveis.&#10;Valores mais altos mantêm as texturas mais nítidas em ângulos oblíquos, ao custo de largura de banda da GPU.&#10;Em casos raros, forçar AF pode introduzir artefatos visuais.</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.-1">No Override (Default)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.0">Disable Anisotropic Filtering</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.1">1x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.2">2x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.3">4x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.4">8x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.5">16x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.async_shader_compilation.Title">Async Shader Compilation</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.async_shader_compilation.Comment">Compila shaders e cria pipelines de forma assíncrona em threads em segundo plano.&#10;Elimina a instabilidade na compilação de shaders, mas pode causar breves artefatos de renderização enquanto os pipelines estão sendo criados.&#10;Quando desativado, os pipelines são criados. Sincronamente, o que causa travamentos, mas sem artefatos visuais.</sys:String>

    <!-- Config UI Settings - HID Options -->
    <sys:String x:Key="ConfigUiSettings.HID.hid.Title">Input System</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.Comment">Sistema de entrada a ser usado</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.any">Any</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.nop">Nop</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.sdl">SDL</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.winkey">WinKey</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.xinput">XInput</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.Title">Keyboard Mode</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.Comment">Permite que o usuário especifique o modo de funcionamento do teclado:&#10;0 - Desativado&#10;1 - Ativado&#10;2 - Passagem direta, que requer que o controle esteja conectado</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.0">Disabled</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.1">Enabled</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.2">Passthrough</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_user_index.Title">Keyboard User Index</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_user_index.Comment">Porta do controle que o teclado emula (0-3)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.left_stick_deadzone_percentage.Title">Left Stick Deadzone</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.left_stick_deadzone_percentage.Comment">Define o nível de zona morta para o analógico esquerdo (0-100%)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.right_stick_deadzone_percentage.Title">Right Stick Deadzone</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.right_stick_deadzone_percentage.Comment">Define o nível de zona morta para o analógico direito (0-100%)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.vibration.Title">Vibration</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.vibration.Comment">Alterna a vibração do controle</sys:String>

    <!-- Config UI Settings - HID.WinKey Options -->
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_a.Title">A Button</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_a.Comment">List of keys to bind to A, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "Q I" binds both Q and I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_b.Title">B Button</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_b.Comment">List of keys to bind to B, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "Q I" binds both Q and I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_back.Title">BACK Button</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_back.Comment">List of keys to bind to BACK, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "Q I" binds both Q and I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_down.Title">D-Pad Down</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_down.Comment">List of keys to bind to DPAD_DOWN, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "^S" means Shift+S</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_left.Title">D-Pad Left</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_left.Comment">List of keys to bind to DPAD_LEFT, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "^A" means Shift+A</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_right.Title">D-Pad Right</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_right.Comment">List of keys to bind to DPAD_RIGHT, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "^D" means Shift+D</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_up.Title">D-Pad Up</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_up.Comment">List of keys to bind to DPAD_UP, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "^W" means Shift+W</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_guide.Title">Guide Button</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_guide.Comment">List of keys to bind to GUIDE, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "0x08" is Backspace</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_shoulder.Title">Left Shoulder</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_shoulder.Comment">List of keys to bind to LEFT_SHOULDER, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "Q I" binds both Q and I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb.Title">Left Thumbstick Press</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb.Comment">List of keys to bind to LEFT_THUMB_PRESSED, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "Q I" binds both Q and I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_down.Title">Left Thumbstick Down</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_down.Comment">List of keys to bind to LEFT_THUMB_DOWN, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "_S" means S without Shift</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_left.Title">Left Thumbstick Left</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_left.Comment">List of keys to bind to LEFT_THUMB_LEFT, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "_A" means A without Shift</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_right.Title">Left Thumbstick Right</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_right.Comment">List of keys to bind to LEFT_THUMB_RIGHT, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "_D" means D without Shift</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_up.Title">Left Thumbstick Up</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_up.Comment">List of keys to bind to LEFT_THUMB_UP, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "_W" means W without Shift</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_trigger.Title">Left Trigger</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_trigger.Comment">List of keys to bind to LEFT_TRIGGER, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "Q I" binds both Q and I to the same trigger</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_shoulder.Title">Right Shoulder</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_shoulder.Comment">List of keys to bind to RIGHT_SHOULDER, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "Q I" binds both Q and I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb.Title">Right Thumbstick Press</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb.Comment">List of keys to bind to RIGHT_THUMB_PRESSED, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "Q I" binds both Q and I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_down.Title">Right Thumbstick Down</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_down.Comment">List of keys to bind to RIGHT_THUMB_DOWN, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "0x28" is Down Arrow</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_left.Title">Right Thumbstick Left</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_left.Comment">List of keys to bind to RIGHT_THUMB_LEFT, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "0x25" is Left Arrow</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_right.Title">Right Thumbstick Right</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_right.Comment">List of keys to bind to RIGHT_THUMB_RIGHT, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "0x27" is Right Arrow</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_up.Title">Right Thumbstick Up</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_up.Comment">List of keys to bind to RIGHT_THUMB_UP, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "0x26" is Up Arrow</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_trigger.Title">Right Trigger</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_trigger.Comment">List of keys to bind to RIGHT_TRIGGER, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "E O" binds both E and O to the same trigger</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_start.Title">START Button</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_start.Comment">List of keys to bind to START, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "Q I" binds both Q and I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_x.Title">X Button</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_x.Comment">List of keys to bind to X, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "Q I" binds both Q and I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_y.Title">Y Button</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_y.Comment">List of keys to bind to Y, separated by spaces. Format: Virtual key code (0x26), single character (A-Z, 0-9), with modifiers (^ requires Shift, _ requires no Shift). Example: "Q I" binds both Q and I</sys:String>

    <!-- Config UI Settings - Kernel Options -->
    <sys:String x:Key="ConfigUiSettings.Kernel.apply_title_update.Title">Aplicar Atualização do Jogo</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.apply_title_update.Comment">Aplicar atualizações de título</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.cl.Title">Command Line</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.cl.Comment">Especificar linha de comando adicional fornecida ao convidado</sys:String>

    <!-- Config UI Settings - Logging Options -->
    <sys:String x:Key="ConfigUiSettings.Logging.enable_console.Title">Enable Console</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.enable_console.Comment">Abrir uma janela de console com a janela principal</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.Title">Log Level</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.Comment">Nível máximo de registro</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.option.0">Erro</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.option.1">Aviso</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.option.2">Info</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.option.3">Debug</sys:String>

    <!-- Config UI Settings - Memory Options -->
    <sys:String x:Key="ConfigUiSettings.Memory.protect_zero.Title">Protect Zero</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.protect_zero.Comment">Proteger a página zero contra leituras e gravações</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.scribble_heap.Title">Scribble Heap</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.scribble_heap.Comment">Escrever um valor específico ou aleatório em toda a memória heap alocada</sys:String>

    <!-- Config UI Settings - Storage Options -->
    <sys:String x:Key="ConfigUiSettings.Storage.mount_cache.Title">Mount Cache</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_cache.Comment">Habilitar a montagem do cache</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_scratch.Title">Mount Scratch</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_scratch.Comment">Habilitar a montagem do scratch</sys:String>

    <!-- Config UI Settings - UI Options -->
    <sys:String x:Key="ConfigUiSettings.UI.show_achievement_notification.Title">Show Achievement Notification</sys:String>
    <sys:String x:Key="ConfigUiSettings.UI.show_achievement_notification.Comment">Exibir notificação de conquista na tela</sys:String>

    <!-- Config UI Settings - Video Options -->
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.Title">Internal Display Resolution</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.Comment">Permitir que jogos que suportam diferentes resoluções sejam renderizados em uma resolução específica Resolução</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.0">640x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.1">640x576</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.2">720x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.3">720x576</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.4">800x600</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.5">848x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.6">1024x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.7">1152x864</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.8">1280x720</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.9">1280x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.10">1280x960</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.11">1280x1024</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.12">1360x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.13">1440x900</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.14">1680x1050</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.15">1920x540</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.16">1920x1080</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.17">Custom (X/Y)</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_x.Title">Custom Resolution Width</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_x.Comment">Largura personalizada para a resolução da tela interna &#10;OBSERVAÇÃO: Requer que a Resolução da Tela Interna esteja definida como "Personalizada (X/Y)" para que a alteração tenha efeito.</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_y.Title">Custom Resolution Height</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_y.Comment">Altura personalizada para a resolução da tela interna&#10;OBSERVAÇÃO: Requer que a Resolução da Tela Interna esteja definida como "Personalizada (X/Y)" para que a alteração tenha efeito.</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.widescreen.Title">Widescreen</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.widescreen.Comment">Alterna entre as proporções de tela 16:9 e 4:3</sys:String>

    <!-- Config UI Settings - Vulkan Options -->
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_immediate.Title">Allow Immediate Present Mode</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_immediate.Comment">Quando disponível, permite a apresentação imediata (1st priority), oferecendo a menor latência com possibilidade de tearing em certos casos.</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_mailbox.Title">Allow Mailbox Present Mode</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_mailbox.Comment">Quando disponível, permite o modo de apresentação da caixa de correio (2ª prioridade), oferecendo baixa latência sem possibilidade de tearing.</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_fifo_relaxed.Title">Allow FIFO Relaxed Present Mode</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_fifo_relaxed.Comment">Quando disponível, permite o modo de apresentação relaxado FIFO (primeiro a entrar, primeiro a sair) (3ª prioridade), que causa espera pela sincronização vertical da tela do host, mas pode apresentar tearing se os frames não atenderem à taxa de atualização da tela do host.</sys:String>

    <!-- Config UI Settings - Live/Netplay Options -->
    <sys:String x:Key="ConfigUiSettings.Live.api_address.Title">API Address</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.api_address.Comment">Endereço do servidor Xenia (ex.: IP:PORTA)</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.discord_presence_user_index.Title">Discord Rich Presence User Index</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.discord_presence_user_index.Comment">Índice do perfil do usuário usado para o Discord Rich Presence [0-3]</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.Title">Network Mode</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.Comment">Modo de rede&#10;0 - Offline&#10;1 - Systemlink&#10;2 - Xbox Live</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.0">Offline</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.1">Systemlink</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.2">Xbox Live</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.upnp.Title">UPnP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.upnp.Comment">Encaminhamento automático de portas usando UPnP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xhttp.Title">XHTTP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xhttp.Comment">Ativa/desativa XHTTP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xlink_kai_systemlink_hack.Title">XLink Kai SystemLink Hack</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xlink_kai_systemlink_hack.Comment">Habilita hacks para suporte a XLink Kai&#10;(Pode causar problemas em alguns casos) Jogos</sys:String>

    <!-- Config UI Settings - MouseHook Options -->
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_autoaim.Title">Disable Autoaim</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_autoaim.Comment">Desativa a mira automática em jogos que a suportam (GoldenEye, Perfect Dark, Saints Row, COD)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_fullscreen_esc_bind.Title">Disable Fullscreen ESC Bind</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_fullscreen_esc_bind.Comment">Desativa a tecla Esc para sair do modo tela cheia quando estiver em tela cheia</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.fov_sensitivity.Title">FOV Sensitivity</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.fov_sensitivity.Comment">Escala do mouse quando o FOV é reduzido (COD, DR, RDR e jogos da UE3)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_aim_turn_distance.Title">(GoldenEye/Perfect Dark)&#10;Aim Turn Distance</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_aim_turn_distance.Comment">(GoldenEye/Perfect Dark) Distância que a mira pode se mover no modo de mira antes de girar a câmera</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_debug_menu.Title">(GoldenEye)&#10;Debug Menu</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_debug_menu.Comment">(GoldenEye) Ativa o menu de depuração, acessível com LB/1</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_gun_sway.Title">(GoldenEye/Perfect Dark)&#10;Gun Sway</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_gun_sway.Comment">(GoldenEye/Perfect Dark) Ativa o balanço da arma ao girar a câmera</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_remove_blur.Title">(GoldenEye)&#10;Remove Blur</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_remove_blur.Comment">(GoldenEye) Remove o desfoque de baixa resolução quando em Modo gráfico clássico</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.internal_hook.Title">Internal Hook</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.internal_hook.Comment">Usa uma técnica de hook melhor para melhores resultados de injeção do mouse (Saints Row 1)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_x.Title">Invert X Axis</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_x.Comment">Inverte o eixo X do mouse</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_y.Title">Invert Y Axis</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_y.Comment">Inverte o eixo Y do mouse</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.menu_sensitivity.Title">(GoldenEye/Saints Row 1)&#10;Menu Sensitivity</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.menu_sensitivity.Comment">(GoldenEye/Saints Row 1) Sensibilidade do mouse nos menus</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_snappy_wheel.Title">(Red Dead Redemption)&#10;Snappy Wheel</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_snappy_wheel.Comment">(Red Dead Redemption) Ajusta a roda de seleção de armas em incrementos de 45 graus</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_turbo_gallop_horse.Title">(Red Dead Redemption)&#10;Turbo Gallop</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_turbo_gallop_horse.Comment">(Red Dead Redemption) Habilita o galope turbo para cavalos e carruagens</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sensitivity.Title">Mouse Sensitivity</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sensitivity.Comment">Sensibilidade do mouse</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.source_sniper_sensitivity.Title">Source Sniper Sensitivity</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.source_sniper_sensitivity.Comment">Sensibilidade da mira de sniper do Source engine</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr1_increase_vehicle_rotation_limit.Title">(Saints Row 1)&#10;Vehicle Rotation Limit</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr1_increase_vehicle_rotation_limit.Comment">(Saints Row 1) Corrige o limite de rotação vertical do veículo para ser praticamente o mesmo que a pé</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_better_handbrake_cam.Title">(Saints Row 2)&#10;Better Handbrake Cam</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_better_handbrake_cam.Comment">(Saints Row 2) Desvincula a rotação do eixo X dos veículos ao frear com a mão, semelhante ao SR1</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_hold_fine_aim.Title">(Saints Row 2)&#10;Hold Fine Aim</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_hold_fine_aim.Comment">(Saints Row 2) Altera a mira precisa (ADS) de alternância para pressionar e segurar</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_better_drive_cam.Title">(Saints Row 1 &amp; 2)&#10;Better Drive Cam</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_better_drive_cam.Comment">(Saints Row 1 e 2) Desvincula a rotação do eixo X dos veículos quando a centralização automática está desativada</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_disable_shared_reload.Title">(Saints Row 1)&#10;Disable Shared Reload</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_disable_shared_reload.Comment">(Saints Row 1) Desativa a recarga de armas ao pressionar o botão interno (A)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.swap_wheel.Title">(Saints Row 1)&#10;Swap Wheel</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.swap_wheel.Comment">Troca as configurações da roda de armas e da direção do zoom do mapa em Saints Row 1</sys:String>

    <!-- About Page -->
    <sys:String x:Key="AboutPage.App.Description">Uma ferramenta de gerenciamento completa para o emulador Xenia. Instale, atualize e gerencie facilmente diferentes versões do emulador Xenia com uma interface intuitiva.</sys:String>
    <sys:String x:Key="AboutPage.WebsiteButton.Text">Website</sys:String>
    <sys:String x:Key="AboutPage.GithubButton.Text">GitHub</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesButton.Text">Verificar atualizações</sys:String>
    <sys:String x:Key="AboutPage.UpdateXeniaManagerButton.Text">Atualizar Xenia Manager</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesFailed.Title">Falha na verificação de atualizações</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesFailed.Message">Ocorreu um erro ao verificar atualizações:&#10;{0}</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.Title">Falha na atualização</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.Message">Ocorreu um erro ao atualizar o Xenia Manager:&#10;{0}</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.NoReleaseInfo">Falha ao obter informações da versão. Tente novamente mais tarde.</sys:String>
    <sys:String x:Key="AboutPage.DownloadingUpdate">Baixando atualização</sys:String>
    <sys:String x:Key="AboutPage.ExtractingUpdate">Extraindo atualização</sys:String>
    <sys:String x:Key="AboutPage.LicenseCredits.Text">Licença e Créditos</sys:String>
    <sys:String x:Key="AboutPage.LicenseCredits.SideText">Informações legais e agradecimentos</sys:String>
    <sys:String x:Key="AboutPage.License.Text">Este software é licenciado sob a Licença BSD-3-Clause.</sys:String>
    <sys:String x:Key="AboutPage.Xbox360Emulation.Header">Emulação do Xbox 360</sys:String>
    <sys:String x:Key="AboutPage.Libraries.Header">Bibliotecas</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaProject.Title">Xenia Project</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaProject.ToolTip"> - Emulador original do Xbox 360</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaCanary.Title">Xenia Canary</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaCanary.ToolTip"> - Versão experimental com os recursos mais recentes</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaNetplay.Title">Xenia Netplay</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaNetplay.ToolTip"> - Suporte para jogos multiplayer</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaMousehook.Title">Xenia Mousehook</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaMousehook.ToolTip"> - Suporte para Teclado e Mouse</sys:String>
    <sys:String x:Key="AboutPage.Credits.AvaloniaUi.Title">Avalonia UI</sys:String>
    <sys:String x:Key="AboutPage.Credits.AvaloniaUi.ToolTip"> - Framework de interface de usuário multiplataforma com Fluent Design</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentAvalonia.Title">FluentAvalonia</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentAvalonia.ToolTip"> - Controles e temas Fluent Design para Avalonia</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentIcons.Title">FluentIcons</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentIcons.ToolTip"> - Framework para usar ícones Fluent Symbol</sys:String>
    <sys:String x:Key="AboutPage.Credits.NLog.Title">NLog</sys:String>
    <sys:String x:Key="AboutPage.Credits.NLog.ToolTip"> - Framework de registro flexível para .NET</sys:String>
    <sys:String x:Key="AboutPage.Credits.Xbox360Toolkit.Title">Xbox 360 Toolkit</sys:String>
    <sys:String x:Key="AboutPage.Credits.Xbox360Toolkit.ToolTip"> - Análise de detalhes de jogos</sys:String>
    <sys:String x:Key="AboutPage.Credits.SharpCompress.Title">SharpCompress</sys:String>
    <sys:String x:Key="AboutPage.Credits.SharpCompress.ToolTip"> - Manipulação de arquivos e compressão</sys:String>
    <sys:String x:Key="AboutPage.Credits.ZstdSharp.Title">#NOTTRANSLATED#</sys:String>
    <sys:String x:Key="AboutPage.Credits.ZstdSharp.ToolTip">#NOTTRANSLATED#</sys:String>
    <sys:String x:Key="AboutPage.FooterNote.Text">Este aplicativo não é afiliado, endossado ou patrocinado pela Microsoft Corporation ou pelo Projeto Xenia de forma alguma. Todas as marcas registradas, logotipos e nomes de marcas são propriedade de seus respectivos proprietários. "Xbox 360 é uma marca registrada da Microsoft Corporation nos Estados Unidos e/ou em outros países." "Xenia é uma marca registrada do Projeto Xenia." Quaisquer referências a essas ou outras marcas registradas são feitas exclusivamente com o objetivo de identificar compatibilidade ou funcionalidade e não implicam qualquer associação ou endosso pelos detentores das marcas registradas. "Este software destina-se apenas a fins educacionais e informativos." Este software não contém nem distribui qualquer conteúdo protegido por direitos autorais pertencente à Microsoft Corporation ou a terceiros. Os usuários são os únicos responsáveis ​​por garantir que o uso deste software esteja em conformidade com todas as leis aplicáveis, incluindo leis de direitos autorais e de licenciamento. Qualquer uso deste aplicativo para executar ou interagir com software ou firmware proprietário deve ser realizado com a devida autorização dentro dos limites dos contratos de licença de usuário final (EULAs) relevantes. Os desenvolvedores e distribuidores deste aplicativo não toleram nem apoiam a pirataria de nenhuma forma. Este aplicativo é fornecido "como está", sem garantia de qualquer tipo, expressa ou implícita. Use por sua conta e risco.</sys:String>
    <sys:String x:Key="AboutPage.UseExperimentalBuild.Title">Usar versão experimental</sys:String>
    <sys:String x:Key="AboutPage.UseExperimentalBuild.Description">Ative para receber atualizações de recursos experimentais e acesso antecipado a novos recursos</sys:String>
    <sys:String x:Key="AboutPage.WebsiteButton.ToolTip">Abre o site do Xenia Manager</sys:String>
    <sys:String x:Key="AboutPage.GithubButton.ToolTip">Abre o repositório GitHub do Xenia Manager</sys:String>
    <sys:String x:Key="AboutPage.InfoBar.XeniaManagerUpdateAvailable.Message">Há uma versão mais recente do Xenia Manager disponível.</sys:String>
    <sys:String x:Key="AboutPage.InfoBar.NoXeniaManagerUpdateAvailable.Message">Você está usando a versão mais recente do Xenia Manager.</sys:String>

