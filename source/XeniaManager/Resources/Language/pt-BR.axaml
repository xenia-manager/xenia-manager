    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Confirmation.Message">Deseja desinstalar o Xenia {0}?&#10;Isso removerá todos os arquivos de salvamento e atualizações, juntamente com o emulador.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Failure.Title">A desinstalação do Xenia {0} falhou</sys:String>
