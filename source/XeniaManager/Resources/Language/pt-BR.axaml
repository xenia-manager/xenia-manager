    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Failure.Title">Atualização do Xenia {0} falhou</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Failure.Message">Xenia {0} não pôde ser atualizado.&#10;Erro completo:&#10;{1}</sys:String>
