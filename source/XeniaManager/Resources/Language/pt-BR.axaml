    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Success.Title">Desinstalação bem-sucedida</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Success.Message">Xenia {0} foi desinstalado</sys:String>
