<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- App global -->
    <sys:String x:Key="App.Title">Xenia Manager</sys:String>

    <!-- Welcome Dialog -->
    <sys:String x:Key="WelcomeDialog.Title">Bem Vindo ao Xenia Manager</sys:String>
    <sys:String x:Key="WelcomeDialog.Description">Por favor selecione o seu tema preferido para a Interface:</sys:String>
    <sys:String x:Key="WelcomeDialog.ContinueButton">Continuar</sys:String>

    <!-- Main View -->
    <sys:String x:Key="MainView.Navigation.OpenXenia">Abrir Xenia</sys:String>
    <sys:String x:Key="MainView.Navigation.Library">Biblioteca de Jogos</sys:String>
    <sys:String x:Key="MainView.Navigation.XeniaSettings">Configurações Xenia</sys:String>
    <sys:String x:Key="MainView.Navigation.ManagePage">Gerenciar Xenia</sys:String>
    <sys:String x:Key="MainView.Navigation.About">Sobre</sys:String>
    <sys:String x:Key="MainView.Navigation.Settings">Configurações</sys:String>
    <sys:String x:Key="MainView.Navigation.Error.Title">Erro de Navegação</sys:String>
    <sys:String x:Key="MainView.Navigation.Error.Message">Falha ao navegar para página designada.&#10;{0}</sys:String>

    <!-- Library Page -->
    <sys:String x:Key="LibraryPage.Search.Watermark">Buscar...</sys:String>
    <sys:String x:Key="LibraryPage.Refresh.ToolTip">#NOTTRANSLATED#</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.Header">Editar Visão de Grade</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.ToolTip">Exibir/Ocultar informação adicional na arte da caixa</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.Title.Header">Título do Jogo</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.CompatibilityRating.Header">Avaliação de Compatibilidade</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.XeniaVersion.Header">Versão Xenia</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.XeniaVersion.ToolTip">Exibir o ícone da versão do Xenia para cada jogo</sys:String>
    <sys:String x:Key="LibraryPage.Options.DoubleClickLaunch.Header">Iniciar com clique duplo</sys:String>
    <sys:String x:Key="LibraryPage.Options.DoubleClickLaunch.ToolTip">Alternar entre clique único e clique duplo para iniciar jogos</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Header">Escanear Pasta</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.ToolTip">Analisa a pasta selecionada em busca de jogos&#10;Consulte a Wiki para obter mais detalhes sobre como essa função funciona.</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.MissingStorageProvider.Title">Fornecedor de Armazenamento Ausente</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.MissingStorageProvider.Message">Fornecedor de Armazenamento não disponível.&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoXeniaInstalled.Title">Nenhuma versão do Xenia Instalada</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoXeniaInstalled.Message">Nenhuma versão do Xenia Instalada atualmente.&#10;Por favor, instale o Xenia antes de continuar.</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.XeniaSelectionError.Title">Erro de Seleção Xenia</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.XeniaSelectionError.Message">Falha ao selecionar a versão do Xenia.&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.FolderPicker.Title">Selecione Pasta para Escanear</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Success.Title">Escaneamento Concluído</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Success.Message">{0} jogo(s) foram adicionados à sua biblioteca com sucesso.</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoGamesFound.Title">Escaneamento Concluído</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoGamesFound.Message">Nenhum jogo novo foi encontrado na pasta selecionada.&#10;&#10;A pasta pode não conter arquivos de jogos compatíveis, ou os jogos podem já estar na sua biblioteca.</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Error.Title">Falha no Escaneamento</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Error.Message">Ocorreu um erro ao escanear a pasta:&#10;&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.ScanError.Title">Erro de Escaneamento</sys:String>

    <!-- Folder Scan Progress Dialog -->
    <sys:String x:Key="FolderScanProgressDialog.Title">Procurando Jogos</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Subtitle">Por favor aguarde enquanto nós buscamos os jogos</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Starting">Iniciando Escaneamento...</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Scanning">Escaneando: {0}</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Complete">Escaneamento concluído! {0} jogo(s) encontrado(s)</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Cancelled">Escaneamento cancelado</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Initializing">Inicializando...</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Error">Erro: {0}</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Statistics.Folders">Pastas</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Statistics.GamesFound">Jogos Encontrados</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Button.Cancel">Cancelar</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Button.Close">Fechar</sys:String>

    <!-- Add Games Progress Dialog -->
    <sys:String x:Key="AddGamesProgressDialog.Title">Adicionando Jogos à Biblioteca</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Subtitle">Processando arquivos de jogos encontrados</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Statistics.Processed">Processado</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Statistics.Added">Adicionado</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Statistics.Skipped">Pulado</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Statistics.Failed">Falhado</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Button.Close">Fechar</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Status.Complete">Concluído! {0} jogo(s) adicionado(s)</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Status.Initializing">Inicializando</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Status.Error">Erro: {0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.Header">Adicionar Jogo</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.ToolTip">Adiciona o arquivo de jogo selecionado ao Xenia Manager</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.MissingStorageProvider.Title">Provedor de Armazenamento Ausente</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.MissingStorageProvider.Message">O provedor de armazenamento não está disponível.&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.MissingXenia.Title">Xenia Ausente</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.MissingXenia.Message">Nenhuma versão do Xenia está instalada.&#10;Instale o Xenia antes de continuar.</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.Failed.Title">Falha ao adicionar o jogo</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.Failed.Message">Ocorreu um erro ao adicionar {0}.&#10;{1}</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.FailedDetection.Title">Falha na Detecção do Jogo</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.FailedDetection.Message">Falha ao detectar os detalhes do jogo {0}.&#10;Deseja adicionar este jogo com informações limitadas mesmo assim?</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.FilePicker.Title">Selecionar Jogo para Adicionar</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Progress.Processing">Processando: {0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Progress.SkippingDuplicate">Ignorando duplicados: {0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Progress.SkippingInvalid">Ignorando jogos inválidos: {0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Progress.Processed">Processados: {0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Header">Exportação em Massa</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ToolTip">Exporta todos os jogos do Xenia Manager para a pasta designada</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.MissingStorageProvider.Title">Provedor de Armazenamento Ausente</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.MissingStorageProvider.Message">O provedor de armazenamento não está disponível.</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.FolderPicker.Title">Selecione a Pasta de Exportação</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Success.Title">Atalhos Exportados</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Success.Message">Atalhos de jogo exportados com sucesso: {0}.&#10;Falhou: {1}&#10;&#10;Exportações bem-sucedidas: &#10;{2}&#10;&#10;Exportações com falha:&#10;{3}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Error.Title">Falha na Exportação</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Error.Message">Ocorreu um erro ao exportar os atalhos do jogo.&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Title">Exportar Atalhos dos Jogos</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Message">Onde você gostaria de exportar os atalhos do jogo?</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Folder">Pasta</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Steam">Steam</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Cancel">Cancelar</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.SteamSuccess.Title">Atalhos do Steam Exportados</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.SteamSuccess.Message">Atalhos do Steam exportados com sucesso: {0}.&#10;Falha: {1}&#10;&#10;Exportações bem-sucedidas: &#10;{2}&#10;&#10;Exportações com falha: &#10;{3}</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Header">Atualizar Classificações de Compatibilidade</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.ToolTip">Atualiza as classificações de compatibilidade para todos os jogos da biblioteca a partir do banco de dados online.</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Success.Title">Atualizar Completo</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Success.Message">Jogos atualizados com sucesso: {0}.&#10;Sem alterações: {1}&#10;Falha: {2}&#10;&#10;Atualizar jogos: &#10;{3}&#10;&#10;Jogos sem alterações: &#10;{4}&#10;&#10;Atualizações com falha: &#10;{5}</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Error.Title">Falha ao Atualizar</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Error.Message">Ocorreu um erro ao atualizar as classificações de compatibilidade.&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Header">Otimizar Jogos</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.ToolTip">Aplica configurações otimizadas do banco de dados online a todos os jogos da biblioteca</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Success.Title">Otimização concluída</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Success.Message">Otimizado com sucesso {0} jogo(s).&#10;Inalterado: {1}&#10;Não encontrado: {2}&#10;Falha: {3}&#10;&#10;Jogos otimizados: &#10;{4}&#10;&#10;Jogos inalterados:&#10;{5}&#10;&#10;Jogos sem configurações otimizadas: &#10;{6}&#10;&#10;Otimizações com falha: &#10;{7}</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Error.Title">Otimização falhou</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Error.Message">Ocorreu um erro ao otimizar as configurações do jogo. &#10;{0}</sys:String>

