    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.ProcessRunning.Message">Não é possível atualizar Xenia {0} enquanto ele estiver em execução.&#10;Feche Xenia {0} e tente novamente.</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.CheckUpdateFailed.Title">Verificação de atualização falhou</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.CheckUpdateFailed.Message">Falha ao verificar atualizações.&#10;{0}</sys:String>
