    <sys:String x:Key="LibraryPage.DeleteSelected.Confirmation.Message">是否移除 {0}？</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.Confirmation.MultipleMessage">是否移除选定的 {0} 个游戏？</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelectedWithContent.Confirmation.Title">删除游戏内容</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelectedWithContent.Confirmation.Message">是否删除所有选定游戏的内容？&#10;这将删除所有存档文件和可下载内容。</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.Success.Title">游戏已删除</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.Success.Message">已成功删除 {0} 个游戏。</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.PartialSuccess.Title">部分成功</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.PartialSuccess.Message">已删除 {0} 个游戏，{1} 个游戏删除失败。&#10;&#10;失败游戏：&#10;{2}</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.Error.Title">删除失败</sys:String>
    <sys:String x:Key="LibraryPage.DeleteSelected.Error.Message">删除选定游戏失败：&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.ClearSelection.Button">清除选择</sys:String>

    <!-- Library Game ToolTips -->
    <sys:String x:Key="LibraryPage.Game.ToolTip.Path.Invalid">游戏路径无效</sys:String>

    <!-- Compatibility Rating -->
    <sys:String x:Key="CompatibilityRating.Unknown">未知</sys:String>
    <sys:String x:Key="CompatibilityRating.Unplayable">无法运行</sys:String>
    <sys:String x:Key="CompatibilityRating.Loads">可加载</sys:String>
    <sys:String x:Key="CompatibilityRating.Gameplay">可游玩</sys:String>
    <sys:String x:Key="CompatibilityRating.Playable">可通关</sys:String>

    <!-- Manage Page -->
    <sys:String x:Key="ManagePage.Emulator.Manage.Title">模拟器管理</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Description">安装和管理不同的 Xenia 模拟器版本</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Canary.Title">Xenia Canary</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Netplay.Title">Xenia Netplay</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Mousehook.Title">Xenia Mousehook</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.NightlyBuild.ToolTip">使用 Nightly 构建</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.NotInstalled">未安装</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.Failure.Title">Xenia {0} 安装失败</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.Failure.Message">Xenia {0} 安装失败。&#10;完整错误：&#10;{1}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.Success.Title">安装成功</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.Success.Message">Xenia {0} 已安装</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.AdminRequired.Title">需要管理员权限</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Install.AdminRequired.Message">此操作需要以管理员身份运行 Xenia Manager。&#10;请以管理员权限重新启动 Xenia Manager。</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Failure.Title">Xenia {0} 更新失败</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Failure.Message">Xenia {0} 更新失败。&#10;完整错误：&#10;{1}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Success.Title">更新成功</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.Success.Message">Xenia {0} 已更新到版本 {1}。</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.ProcessRunning.Title">Xenia {0} 正在运行</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Update.ProcessRunning.Message">无法在 Xenia {0} 运行时进行更新。&#10;请关闭 Xenia {0} 后重试。</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.CheckUpdateFailed.Title">检查更新失败</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.CheckUpdateFailed.Message">检查更新失败。&#10;{0}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Confirmation.Title">卸载确认</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Confirmation.Message">是否卸载 Xenia {0}？&#10;这将同时删除所有存档文件和更新数据。</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Failure.Title">Xenia {0} 卸载失败</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Failure.Message">Xenia {0} 卸载失败。&#10;完整错误：&#10;{1}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Success.Title">卸载成功</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Uninstall.Success.Message">Xenia {0} 已卸载</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.Downloading">正在下载 Xenia {0}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.SDL.Downloading">正在下载 SDL 游戏控制器数据库</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.UpdateAvailable.Title">有可用更新</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.UpdateAvailable.Message">有新版本的 Xenia 可用。&#10;当前：{0}&#10;最新：{1}</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.UpToDate.Title">已是最新</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Xenia.UpToDate.Message">Xenia 已是最新版本</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Button.Install">安装</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Button.Update">更新</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Button.CheckForUpdates">检查更新</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Manage.Button.Uninstall">卸载</sys:String>
    <sys:String x:Key="ManagePage.Content.Management.Title">内容管理</sys:String>
    <sys:String x:Key="ManagePage.Content.Management.Description">管理内容和配置文件</sys:String>
    <sys:String x:Key="ManagePage.Content.AutomaticSaveBackup.Title">自动存档备份</sys:String>
    <sys:String x:Key="ManagePage.Content.AutomaticSaveBackup.Description">自动备份所选配置文件的存档</sys:String>
    <sys:String x:Key="ManagePage.Content.AutomaticSaveBackup.NoProfiles.Title">无可用配置文件</sys:String>
    <sys:String x:Key="ManagePage.Content.AutomaticSaveBackup.NoProfiles.Message">未找到任何配置文件以启用自动存档备份。&#10;请先创建或导入一个配置文件。</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Title">统一内容文件夹</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Description">使所有 Xenia 版本使用相同的内容文件夹</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.ToolTip">注意：安装 Xenia 时需要以管理员身份运行 Xenia Manager 才能启用此功能</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.AdminRequired.Title">需要管理员权限</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.AdminRequired.Message">此操作需要以管理员身份运行 Xenia Manager。&#10;请以管理员权限重新启动 Xenia Manager。</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Separate.Title">分离内容文件夹</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Separate.Message">是否要分离内容文件夹？&#10;每个 Xenia 版本将拥有自己独立的内容目录。</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Unify.Title">统一内容文件夹</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Unify.Message">是否要统一内容文件夹？&#10;所有 Xenia 版本将共享相同的内容目录。&#10;&#10;选择要以哪个版本的内容作为基础。</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Unify.Success.Title">内容文件夹统一成功</sys:String>
    <sys:String x:Key="ManagePage.Emulator.Settings.UnifiedContentFolder.Unify.Success.Message">内容文件夹已成功统一。&#10;所有 Xenia 版本现在共享相同的内容目录。</sys:String>
