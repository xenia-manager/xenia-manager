<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- App global -->
    <sys:String x:Key="App.Title">Xenia Manager</sys:String>

    <!-- Main View -->
    <sys:String x:Key="MainView.Navigation.OpenXenia">打开 Xenia</sys:String>
    <sys:String x:Key="MainView.Navigation.Library">游戏库</sys:String>
    <sys:String x:Key="MainView.Navigation.XeniaSettings">Xenia 设置</sys:String>
    <sys:String x:Key="MainView.Navigation.ManagePage">管理 Xenia</sys:String>
    <sys:String x:Key="MainView.Navigation.About">关于</sys:String>
    <sys:String x:Key="MainView.Navigation.Settings">设置</sys:String>
    <sys:String x:Key="MainView.Navigation.Error.Title">导航错误</sys:String>
    <sys:String x:Key="MainView.Navigation.Error.Message">无法导航到指定页面。&#10;{0}</sys:String>

    <!-- Library Page -->
    <sys:String x:Key="LibraryPage.Search.Watermark">搜索...</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.Header">编辑网格视图</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.ToolTip">显示/隐藏封面上的额外信息</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.Title.Header">游戏标题</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.CompatibilityRating.Header">兼容性评级</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.XeniaVersion.Header">Xenia 版本</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.XeniaVersion.ToolTip">为每个游戏显示 Xenia 版本图标</sys:String>
    <sys:String x:Key="LibraryPage.Options.DoubleClickLaunch.Header">双击启动</sys:String>
    <sys:String x:Key="LibraryPage.Options.DoubleClickLaunch.ToolTip">切换单击或双击启动游戏</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Header">扫描目录</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.ToolTip">扫描选定文件夹中的游戏&#10;查看 Wiki 了解此功能的更多详情</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.MissingStorageProvider.Title">缺少存储提供程序</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.MissingStorageProvider.Message">存储提供程序不可用。&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoXeniaInstalled.Title">未安装 Xenia</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoXeniaInstalled.Message">当前未安装任何版本的 Xenia。&#10;请先安装 Xenia 再继续。</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.XeniaSelectionError.Title">Xenia 选择错误</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.XeniaSelectionError.Message">选择 Xenia 版本失败。&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.FolderPicker.Title">选择要扫描的文件夹</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Success.Title">扫描完成</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Success.Message">已成功向游戏库添加 {0} 个游戏。</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoGamesFound.Title">扫描完成</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoGamesFound.Message">在选定目录中未发现新游戏。&#10;&#10;该文件夹可能不包含任何兼容的游戏文件，或者游戏已在您的库中。</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Error.Title">扫描失败</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Error.Message">扫描目录时发生错误：&#10;&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.ScanError.Title">扫描错误</sys:String>

    <!-- Folder Scan Progress Dialog -->
    <sys:String x:Key="FolderScanProgressDialog.Title">正在扫描游戏</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Subtitle">请稍候，我们正在搜索游戏文件</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Starting">开始扫描...</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Scanning">正在扫描：{0}</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Complete">扫描完成！找到 {0} 个游戏</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Cancelled">扫描已取消</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Initializing">正在初始化...</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Error">错误：{0}</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Statistics.Folders">文件夹</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Statistics.GamesFound">已找到游戏</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Button.Cancel">取消</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Button.Close">关闭</sys:String>

    <!-- Add Games Progress Dialog -->
    <sys:String x:Key="AddGamesProgressDialog.Title">正在向库中添加游戏</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Subtitle">正在处理已发现的游戏文件</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Statistics.Processed">已处理</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Statistics.Added">已添加</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Statistics.Skipped">已跳过</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Statistics.Failed">失败</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Button.Close">关闭</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Status.Complete">完成！已添加 {0} 个游戏</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Status.Initializing">正在初始化</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Status.Error">错误：{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.Header">添加游戏</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.ToolTip">将选定的游戏文件添加到 Xenia Manager</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.MissingStorageProvider.Title">缺少存储提供程序</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.MissingStorageProvider.Message">存储提供程序不可用。&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.MissingXenia.Title">缺少 Xenia</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.MissingXenia.Message">当前未安装任何版本的 Xenia。&#10;请先安装 Xenia 再继续。</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.Failed.Title">添加游戏失败</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.Failed.Message">添加 {0} 时出错。&#10;{1}</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.FailedDetection.Title">游戏检测失败</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.FailedDetection.Message">无法检测 {0} 的游戏详情。&#10;是否仍要添加此游戏（信息可能不全）？</sys:String>
    <sys:String x:Key="LibraryPage.Options.AddGame.FilePicker.Title">选择要添加的游戏</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Progress.Processing">正在处理：{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Progress.SkippingDuplicate">正在跳过重复项：{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Progress.SkippingInvalid">正在跳过无效游戏：{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Progress.Processed">已处理：{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Header">批量导出</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ToolTip">将 Xenia Manager 中的所有游戏批量导出到指定文件夹</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.MissingStorageProvider.Title">缺少存储提供程序</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.MissingStorageProvider.Message">存储提供程序不可用。</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.FolderPicker.Title">选择导出文件夹</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Success.Title">快捷方式已导出</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Success.Message">已成功导出 {0} 个游戏快捷方式。&#10;失败：{1}&#10;&#10;成功导出项：&#10;{2}&#10;&#10;导出失败项：&#10;{3}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Error.Title">导出失败</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Error.Message">导出游戏快捷方式时出错。&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Title">导出游戏快捷方式</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Message">您想将游戏快捷方式导出到哪里？</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Folder">文件夹</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Steam">Steam</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.ChooseTarget.Cancel">取消</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.SteamSuccess.Title">Steam 快捷方式已导出</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.SteamSuccess.Message">已成功导出 {0} 个 Steam 快捷方式。&#10;失败：{1}&#10;&#10;成功导出项：&#10;{2}&#10;&#10;导出失败项：&#10;{3}</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Header">更新兼容性评级</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.ToolTip">从在线数据库更新库中所有游戏的兼容性评级</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Success.Title">更新完成</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Success.Message">成功更新 {0} 个游戏。&#10;未更改：{1}&#10;失败：{2}&#10;&#10;已更新游戏：&#10;{3}&#10;&#10;未更改游戏：&#10;{4}&#10;&#10;更新失败项：&#10;{5}</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Error.Title">更新失败</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Error.Message">更新兼容性评级时出错。&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Header">优化游戏</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.ToolTip">从在线数据库将优化设置应用到库中的所有游戏</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Success.Title">优化完成</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Success.Message">成功优化 {0} 个游戏。&#10;未更改：{1}&#10;未找到：{2}&#10;失败：{3}&#10;&#10;已优化游戏：&#10;{4}&#10;&#10;未更改游戏：&#10;{5}&#10;&#10;无优化设置的游戏：&#10;{6}&#10;&#10;优化失败项：&#10;{7}</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Error.Title">优化失败</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Error.Message">优化游戏设置时出错。&#10;{0}</sys:String>

    <!-- Library Game Button - Playtime -->
    <sys:String x:Key="LibraryPage.GameButton.Playtime.Label">游戏时间：</sys:String>
    <sys:String x:Key="LibraryPage.GameButton.Playtime.NeverPlayed">从未玩过</sys:String>
    <sys:String x:Key="LibraryPage.GameButton.Playtime.Minutes">{0} 分钟</sys:String>
    <sys:String x:Key="LibraryPage.GameButton.Playtime.Hours">{0} 小时</sys:String>

