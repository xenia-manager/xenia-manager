    <!-- Config UI Settings - APU Options -->
    <sys:String x:Key="ConfigUiSettings.APU.apu.Title">音频系统</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.Comment">音频系统</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.any">任意</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.nop">无</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.sdl">SDL</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.xaudio2">XAudio2</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu_max_queued_frames.Title">音频最大排队帧数</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu_max_queued_frames.Comment">允许更改最大缓冲音频帧数以减少音频延迟&#10;降低此值可能会导致性能问题</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.mute.Title">静音</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.mute.Comment">静音所有音频输出</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.enable_xmp.Title">XMP</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.enable_xmp.Comment">启用音乐播放器播放&#10;这可以修复某些游戏中的音乐问题</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xmp_default_volume.Title">XMP 默认音量</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xmp_default_volume.Comment">如果游戏未设置，则使用默认音乐音量</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_dedicated_xma_thread.Title">专用 XMA 线程</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_dedicated_xma_thread.Comment">在单独线程上启用 XMA 解码&#10;禁用此选项预期效果更好，但性能较低</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_new_decoder.Title">XMA 音频解码器</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_new_decoder.Comment">启用新的 XMA 音频解码</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.Title">XMA 解码器</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.Comment">fake：不解码音频&#10;master：与 Xenia 基础版本完全相同的解码器版本&#10;old：基于 master 版本解码器，有少量改进&#10;new：新版本解码器。提供最高稳定性，但尚未完成</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.fake">Fake</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.master">Master</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.old">Old</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.new">New</sys:String>

    <!-- Config UI Settings - Content Options -->
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.Title">许可证掩码</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.Comment">- 无许可证：试玩模式&#10;- 第一个许可证：通常是 Xbox Live Arcade 游戏中的完整版许可证&#10;- 所有许可证：启用所有可能的许可证，但可能导致某些未定义的行为</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.0">无许可证</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.1">第一个许可证</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.-1">所有许可证</sys:String>

    <!-- Config UI Settings - CPU Options -->
    <sys:String x:Key="ConfigUiSettings.CPU.break_on_unimplemented_instructions.Title">遇到未实现指令时中断</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.break_on_unimplemented_instructions.Comment">如果遇到未实现的 PowerPC 指令，中断到主机调试器（如果未连接调试器则崩溃）</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disable_context_promotion.Title">禁用上下文提升</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disable_context_promotion.Comment">禁用上下文提升优化&#10;某些体育游戏可能需要此选项，但会降低性能</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disassemble_functions.Title">反汇编函数</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disassemble_functions.Comment">在生成期间反汇编函数</sys:String>

    <!-- Config UI Settings - D3D12 Options -->
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_allow_variable_refresh_rate_and_tearing.Title">允许可变刷新率和撕裂</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_allow_variable_refresh_rate_and_tearing.Comment">在全屏模式下，允许在支持 VRR 的显示器上使用可变刷新率&#10;在不支持 VRR 的显示器上，某些情况下可能会出现屏幕撕裂</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.Title">队列优先级</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.Comment">图形（直接）命令队列调度优先级&#10;0 - 正常&#10;1 - 高&#10;2 - 全局实时，需要管理员权限并可能影响系统响应性</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.0">正常</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.1">高</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.2">全局实时</sys:String>

    <!-- Config UI Settings - Display Options -->
    <sys:String x:Key="ConfigUiSettings.Display.fullscreen.Title">全屏</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.fullscreen.Comment">是否以全屏模式启动模拟器</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.present_letterbox.Title">显示黑边</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.present_letterbox.Comment">当没有更多过扫描区域可裁剪时，通过在图像周围显示黑边来在拉伸时保持宽高比</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.Title">抗锯齿</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.Comment">应用于游戏图像输出的后处理抗锯齿效果</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.none">无</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.fxaa">FXAA</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.fxaa_extreme">FXAA Extreme</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.Title">缩放与锐化</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.Comment">用于最终显示输出的重采样和/或锐化的后处理效果</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.bilinear">双线性</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.cas">CAS</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.fsr">FSR</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_sharpness_reduction.Title">FSR 锐度降低</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_sharpness_reduction.Comment">AMD FidelityFX 超级分辨率 1.0 (FSR) 的锐度降低量，以档位计算&#10;数值越低越锐利</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_cas_additional_sharpness.Title">CAS 额外锐度</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_cas_additional_sharpness.Comment">AMD FidelityFX 对比度自适应锐化 (CAS) 的额外锐度，范围 0 到 1&#10;数值越高越锐利</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_max_upsampling_passes.Title">FSR 最大上采样次数</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_max_upsampling_passes.Comment">AMD FidelityFX 超级分辨率 1.0 (FSR) 中执行的最大上采样次数，超过后最终阶段将回退到双线性拉伸</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_dither.Title">抖动</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_dither.Comment">将最终图像输出从内部精度抖动到每通道 8 位，使渐变更平滑</sys:String>

    <!-- Config UI Settings - General Options -->
    <sys:String x:Key="ConfigUiSettings.General.allow_plugins.Title">允许插件</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.allow_plugins.Comment">允许从 plugins\\title_id\\plugin.xex 加载插件/修改器&#10;插件是可用于制作模组的自制 xex 模块&#10;此功能为实验性功能</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.discord.Title">Discord 丰富状态</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.discord.Comment">启用 Discord 丰富状态</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.apply_patches.Title">应用补丁</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.apply_patches.Comment">启用自定义补丁功能</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.controller_hotkeys.Title">控制器热键</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.controller_hotkeys.Comment">Xbox 和 PS 控制器的热键</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.launch_module.Title">启动模块</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.launch_module.Comment">从 .iso 或包中启动的可执行文件，而不是 default.xex 或游戏指定的模块&#10;留空以启动默认模块</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.notification_sound_path.Title">通知声音路径</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.notification_sound_path.Comment">所选通知声音的路径（包含文件名）&#10;注意：声音必须是 wav 格式！</sys:String>

    <!-- Config UI Settings - GPU Options -->
    <sys:String x:Key="ConfigUiSettings.GPU.vsync.Title">垂直同步</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.vsync.Comment">启用垂直同步</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.framerate_limit.Title">帧率限制</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.framerate_limit.Comment">每秒最大帧数&#10;0 = 无限制帧数&#10;当设置为 0 且启用垂直同步时默认为 60</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.Title">图形系统</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.Comment">要使用的图形系统</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.any">任意</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.d3d12">D3D12</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.vulkan">Vulkan</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.null">空</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.Title">渲染目标路径 (D3D12)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.Comment">在 Direct3D 12 上使用的渲染目标模拟路径&#10;RTV - 主机渲染目标&#10;ROV - 光栅化顺序视图</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.any">自动</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.rtv">RTV</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.rov">ROV</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.Title">渲染目标路径 (Vulkan)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.Comment">在 Vulkan 上使用的渲染目标模拟路径&#10;FBO - 主机帧缓冲&#10;FSI - 片段着色器互锁</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.any">自动</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.fbo">FBO</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.fsi">FSI</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.Title">回读解析</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.Comment">控制渲染到纹理解析结果的 CPU 回读&#10;None - 禁用回读&#10;Fast - 1 帧延迟&#10;Full - 精确但较慢</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.none">无</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.fast">快速</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.full">完整</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_x.Title">绘制分辨率缩放 X</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_x.Comment">用于对游戏不透明地缩放渲染分辨率的整数像素宽度缩放比例</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_y.Title">绘制分辨率缩放 Y</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_y.Comment">用于对游戏不透明地缩放渲染分辨率的整数像素高度缩放比例</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu_allow_invalid_fetch_constants.Title">允许无效获取常量</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu_allow_invalid_fetch_constants.Comment">允许类型无效的纹理和顶点获取常量&#10;通常不安全，但可用于绕过某些游戏中的获取常量类型错误</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gamma_render_target_as_srgb.Title">将 Gamma 渲染目标作为 sRGB</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gamma_render_target_as_srgb.Comment">当主机无法直接以正确的混合写入分段线性 gamma 时，在主机上使用 sRGB 输出以在线性颜色空间中实现概念上正确的混合</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_lower_threshold.Title">查询遮挡采样下限阈值</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_lower_threshold.Comment">如果设置为 -1，则不写入任何采样计数，游戏可能会挂起&#10;否则，每个图块的采样计数将在每次 EVENT_WRITE_ZPD 时增加此数值</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_upper_threshold.Title">查询遮挡采样上限阈值</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_upper_threshold.Comment">设置为比 query_occlusion_sample_lower_threshold 更高的数字&#10;如果 query_occlusion_sample_lower_threshold 设置为 -1，则忽略此值</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.use_fuzzy_alpha_epsilon.Title">使用模糊 Alpha Epsilon</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.use_fuzzy_alpha_epsilon.Comment">对 alpha 值使用近似比较，以防止 NVIDIA 显卡上的闪烁</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.clear_memory_page_state.Title">清除内存页状态</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.clear_memory_page_state.Comment">刷新内存页状态以启用 GPU 写入的数据</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.Title">各向异性过滤覆盖</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.Comment">对符合条件的纹理强制使用各向异性过滤 (AF)&#10;较高的值可在倾斜角度下保持纹理更清晰，但会消耗 GPU 带宽&#10;极少数情况下，强制 AF 可能会引入视觉伪影</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.-1">不覆盖（默认）</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.0">禁用各向异性过滤</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.1">1x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.2">2x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.3">4x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.4">8x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.5">16x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.async_shader_compilation.Title">异步着色器编译</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.async_shader_compilation.Comment">在后台线程中异步编译着色器并创建管线&#10;消除着色器编译卡顿，但在管线创建期间可能会导致短暂的渲染伪影&#10;禁用时，管线同步创建，会导致卡顿但无视觉伪影</sys:String>

    <!-- Config UI Settings - HID Options -->
    <sys:String x:Key="ConfigUiSettings.HID.hid.Title">输入系统</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.Comment">要使用的输入系统</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.any">任意</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.nop">无</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.sdl">SDL</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.winkey">WinKey</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.xinput">XInput</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.Title">键盘模式</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.Comment">允许用户指定键盘工作模式：&#10;0 - 禁用&#10;1 - 启用&#10;2 - 直通，需要连接控制器</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.0">禁用</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.1">启用</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.2">直通</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_user_index.Title">键盘用户索引</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_user_index.Comment">键盘模拟的控制器端口 (0-3)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.left_stick_deadzone_percentage.Title">左摇杆死区</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.left_stick_deadzone_percentage.Comment">定义左摇杆的死区级别 (0-100%)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.right_stick_deadzone_percentage.Title">右摇杆死区</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.right_stick_deadzone_percentage.Comment">定义右摇杆的死区级别 (0-100%)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.vibration.Title">振动</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.vibration.Comment">切换控制器振动</sys:String>

    <!-- Config UI Settings - HID.WinKey Options -->
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_a.Title">A 按钮</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_a.Comment">要绑定到 A 的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："Q I" 将 Q 和 I 都绑定</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_b.Title">B 按钮</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_b.Comment">要绑定到 B 的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："Q I" 将 Q 和 I 都绑定</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_back.Title">BACK 按钮</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_back.Comment">要绑定到 BACK 的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："Q I" 将 Q 和 I 都绑定</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_down.Title">方向键下</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_down.Comment">要绑定到方向键下的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："^S" 表示 Shift+S</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_left.Title">方向键左</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_left.Comment">要绑定到方向键左的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："^A" 表示 Shift+A</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_right.Title">方向键右</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_right.Comment">要绑定到方向键右的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："^D" 表示 Shift+D</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_up.Title">方向键上</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_up.Comment">要绑定到方向键上的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："^W" 表示 Shift+W</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_guide.Title">Guide 按钮</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_guide.Comment">要绑定到 GUIDE 的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："0x08" 是退格键</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_shoulder.Title">左肩键</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_shoulder.Comment">要绑定到左肩键的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："Q I" 将 Q 和 I 都绑定</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb.Title">左摇杆按下</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb.Comment">要绑定到左摇杆按下的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："Q I" 将 Q 和 I 都绑定</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_down.Title">左摇杆向下</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_down.Comment">要绑定到左摇杆向下的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："_S" 表示不带 Shift 的 S</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_left.Title">左摇杆向左</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_left.Comment">要绑定到左摇杆向左的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："_A" 表示不带 Shift 的 A</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_right.Title">左摇杆向右</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_right.Comment">要绑定到左摇杆向右的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："_D" 表示不带 Shift 的 D</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_up.Title">左摇杆向上</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_up.Comment">要绑定到左摇杆向上的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："_W" 表示不带 Shift 的 W</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_trigger.Title">左扳机</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_trigger.Comment">要绑定到左扳机的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："Q I" 将 Q 和 I 都绑定到同一扳机</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_shoulder.Title">右肩键</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_shoulder.Comment">要绑定到右肩键的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："Q I" 将 Q 和 I 都绑定</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb.Title">右摇杆按下</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb.Comment">要绑定到右摇杆按下的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："Q I" 将 Q 和 I 都绑定</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_down.Title">右摇杆向下</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_down.Comment">要绑定到右摇杆向下的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："0x28" 是向下箭头</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_left.Title">右摇杆向左</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_left.Comment">要绑定到右摇杆向左的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："0x25" 是向左箭头</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_right.Title">右摇杆向右</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_right.Comment">要绑定到右摇杆向右的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："0x27" 是向右箭头</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_up.Title">右摇杆向上</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_up.Comment">要绑定到右摇杆向上的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："0x26" 是向上箭头</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_trigger.Title">右扳机</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_trigger.Comment">要绑定到右扳机的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："E O" 将 E 和 O 都绑定到同一扳机</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_start.Title">START 按钮</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_start.Comment">要绑定到 START 的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："Q I" 将 Q 和 I 都绑定</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_x.Title">X 按钮</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_x.Comment">要绑定到 X 的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："Q I" 将 Q 和 I 都绑定</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_y.Title">Y 按钮</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_y.Comment">要绑定到 Y 的按键列表，以空格分隔。格式：虚拟键码 (0x26)、单个字符 (A-Z, 0-9)，可带修饰符（^ 需要 Shift，_ 不需要 Shift）。示例："Q I" 将 Q 和 I 都绑定</sys:String>

    <!-- Config UI Settings - Kernel Options -->
    <sys:String x:Key="ConfigUiSettings.Kernel.apply_title_update.Title">应用标题更新</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.apply_title_update.Comment">应用标题更新</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.cl.Title">命令行</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.cl.Comment">指定提供给客户端的额外命令行参数</sys:String>
    
    <!-- Config UI Settings - Logging Options -->
	<sys:String x:Key="ConfigUiSettings.Logging.enable_console.Title">启用控制台</sys:String>
	<sys:String x:Key="ConfigUiSettings.Logging.enable_console.Comment">随主窗口打开控制台窗口</sys:String>
	<sys:String x:Key="ConfigUiSettings.Logging.log_level.Title">日志级别</sys:String>
	<sys:String x:Key="ConfigUiSettings.Logging.log_level.Comment">要记录的最高日志级别</sys:String>
	<sys:String x:Key="ConfigUiSettings.Logging.log_level.option.0">错误</sys:String>
	<sys:String x:Key="ConfigUiSettings.Logging.log_level.option.1">警告</sys:String>
	<sys:String x:Key="ConfigUiSettings.Logging.log_level.option.2">信息</sys:String>
	<sys:String x:Key="ConfigUiSettings.Logging.log_level.option.3">调试</sys:String>

    <!-- Config UI Settings - Memory Options -->
    <sys:String x:Key="ConfigUiSettings.Memory.protect_zero.Title">保护零页</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.protect_zero.Comment">保护零页免受读取和写入</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.scribble_heap.Title">填充堆</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.scribble_heap.Comment">将所有分配的堆内存填充为特定或随机值</sys:String>

    <!-- Config UI Settings - Storage Options -->
    <sys:String x:Key="ConfigUiSettings.Storage.mount_cache.Title">挂载缓存</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_cache.Comment">启用缓存挂载</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_scratch.Title">挂载临时存储</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_scratch.Comment">启用临时存储挂载</sys:String>

    <!-- Config UI Settings - UI Options -->
    <sys:String x:Key="ConfigUiSettings.UI.show_achievement_notification.Title">显示成就通知</sys:String>
    <sys:String x:Key="ConfigUiSettings.UI.show_achievement_notification.Comment">在屏幕上显示成就通知</sys:String>

    <!-- Config UI Settings - Video Options -->
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.Title">内部显示分辨率</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.Comment">允许支持不同分辨率的游戏以特定分辨率渲染</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.0">640x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.1">640x576</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.2">720x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.3">720x576</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.4">800x600</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.5">848x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.6">1024x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.7">1152x864</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.8">1280x720</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.9">1280x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.10">1280x960</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.11">1280x1024</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.12">1360x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.13">1440x900</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.14">1680x1050</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.15">1920x540</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.16">1920x1080</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.17">自定义 (X/Y)</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_x.Title">自定义分辨率宽度</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_x.Comment">内部显示分辨率的自定义宽度&#10;注意：需要将内部显示分辨率设置为"自定义 (X/Y)"才能生效</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_y.Title">自定义分辨率高度</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_y.Comment">内部显示分辨率的自定义高度&#10;注意：需要将内部显示分辨率设置为"自定义 (X/Y)"才能生效</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.widescreen.Title">宽屏</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.widescreen.Comment">在 16:9 和 4:3 宽高比之间切换</sys:String>

    <!-- Config UI Settings - Vulkan Options -->
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_immediate.Title">允许即时呈现模式</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_immediate.Comment">可用时，允许即时呈现模式（第一优先级），提供最低延迟，但在某些情况下可能出现撕裂</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_mailbox.Title">允许邮箱呈现模式</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_mailbox.Comment">可用时，允许邮箱呈现模式（第二优先级），提供低延迟且无撕裂</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_fifo_relaxed.Title">允许 FIFO 宽松呈现模式</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_fifo_relaxed.Comment">可用时，允许宽松的先入先出呈现模式（第三优先级），会等待主机显示器垂直同步，但如果帧率未达到主机显示器刷新率，可能会出现撕裂</sys:String>

    <!-- Config UI Settings - Live/Netplay Options -->
    <sys:String x:Key="ConfigUiSettings.Live.api_address.Title">API 地址</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.api_address.Comment">Xenia 服务器地址（例如：IP:端口）</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.discord_presence_user_index.Title">Discord 丰富状态用户索引</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.discord_presence_user_index.Comment">用于 Discord 丰富状态的用户配置文件索引 [0-3]</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.Title">网络模式</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.Comment">网络模式&#10;0 - 离线&#10;1 - 系统联机&#10;2 - Xbox Live</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.0">离线</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.1">系统联机</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.2">Xbox Live</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.upnp.Title">UPnP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.upnp.Comment">使用 UPnP 自动进行端口转发</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xhttp.Title">XHTTP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xhttp.Comment">切换 XHTTP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xlink_kai_systemlink_hack.Title">XLink Kai SystemLink Hack</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xlink_kai_systemlink_hack.Comment">启用以支持 XLink Kai SystemLink Hack&#10;可能会破坏某些游戏</sys:String>

    <!-- Config UI Settings - MouseHook Options -->
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_autoaim.Title">禁用自动瞄准</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_autoaim.Comment">在支持自动瞄准的游戏中禁用它（GoldenEye、Perfect Dark、Saints Row、COD）</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_fullscreen_esc_bind.Title">禁用全屏 ESC 绑定</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_fullscreen_esc_bind.Comment">在全屏时禁用 ESC 退出全屏</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.fov_sensitivity.Title">FOV 灵敏度</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.fov_sensitivity.Comment">FOV 降低时的鼠标缩放比例（COD、DR、RDR 和 UE3 游戏）</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_aim_turn_distance.Title">（GoldenEye/Perfect Dark）&#10;瞄准转向距离</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_aim_turn_distance.Comment">（GoldenEye/Perfect Dark）在瞄准模式下准星移动多远后才会转动镜头</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_debug_menu.Title">（GoldenEye）&#10;调试菜单</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_debug_menu.Comment">（GoldenEye）启用调试菜单，可通过 LB/1 访问</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_gun_sway.Title">（GoldenEye/Perfect Dark）&#10;枪械晃动</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_gun_sway.Comment">（GoldenEye/Perfect Dark）在转动镜头时启用枪械晃动</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_remove_blur.Title">（GoldenEye）&#10;移除模糊</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_remove_blur.Comment">（GoldenEye）在经典图形模式下移除低分辨率模糊</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.internal_hook.Title">内部钩子</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.internal_hook.Comment">使用更好的钩子技术以获得更好的鼠标注入效果（Saints Row 1）</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_x.Title">反转 X 轴</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_x.Comment">反转鼠标 X 轴</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_y.Title">反转 Y 轴</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_y.Comment">反转鼠标 Y 轴</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.menu_sensitivity.Title">（GoldenEye/Saints Row 1）&#10;菜单灵敏度</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.menu_sensitivity.Comment">（GoldenEye/Saints Row 1）菜单中的鼠标灵敏度</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_snappy_wheel.Title">（Red Dead Redemption）&#10;快速切换轮盘</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_snappy_wheel.Comment">（Red Dead Redemption）将武器轮盘以 45 度增量进行吸附</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_turbo_gallop_horse.Title">（Red Dead Redemption）&#10;加速奔驰</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_turbo_gallop_horse.Comment">（Red Dead Redemption）为马匹和马车启用加速奔驰</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sensitivity.Title">鼠标灵敏度</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sensitivity.Comment">鼠标灵敏度</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.source_sniper_sensitivity.Title">起源引擎狙击镜灵敏度</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.source_sniper_sensitivity.Comment">起源引擎狙击镜灵敏度</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr1_increase_vehicle_rotation_limit.Title">（Saints Row 1）&#10;载具旋转限制</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr1_increase_vehicle_rotation_limit.Comment">（Saints Row 1）修补载具垂直旋转限制，使其基本与步行时相同</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_better_handbrake_cam.Title">（Saints Row 2）&#10;更好的手刹镜头</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_better_handbrake_cam.Comment">（Saints Row 2）在手刹时解除 X 轴旋转与载具的绑定，类似于 SR1</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_hold_fine_aim.Title">（Saints Row 2）&#10;按住精细瞄准</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_hold_fine_aim.Comment">（Saints Row 2）将精细瞄准（ADS）从切换模式改为按住模式</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_better_drive_cam.Title">（Saints Row 1 和 2）&#10;更好的驾驶镜头</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_better_drive_cam.Comment">（Saints Row 1 和 2）在禁用自动回正时解除 X 轴旋转与载具的绑定</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_disable_shared_reload.Title">（Saints Row 1）&#10;禁用共享装弹</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_disable_shared_reload.Comment">（Saints Row 1）禁用在按下内部（A）按钮时装填武器</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.swap_wheel.Title">（Saints Row 1）&#10;交换轮盘</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.swap_wheel.Comment">在 Saints Row 1 中交换武器轮盘和地图缩放方向的绑定</sys:String>

    <!-- About Page -->
    <sys:String x:Key="AboutPage.App.Description">Xenia 模拟器的综合管理工具。通过直观的界面轻松安装、更新和管理不同版本的 Xenia 模拟器。</sys:String>
    <sys:String x:Key="AboutPage.WebsiteButton.Text">网站</sys:String>
    <sys:String x:Key="AboutPage.GithubButton.Text">GitHub</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesButton.Text">检查更新</sys:String>
    <sys:String x:Key="AboutPage.UpdateXeniaManagerButton.Text">更新 Xenia Manager</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesFailed.Title">检查更新失败</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesFailed.Message">检查更新时发生错误：&#10;{0}</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.Title">更新失败</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.Message">更新 Xenia Manager 时发生错误：&#10;{0}</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.NoReleaseInfo">获取发布信息失败。请稍后重试。</sys:String>
    <sys:String x:Key="AboutPage.DownloadingUpdate">正在下载更新</sys:String>
    <sys:String x:Key="AboutPage.ExtractingUpdate">正在解压更新</sys:String>
    <sys:String x:Key="AboutPage.LicenseCredits.Text">许可证与致谢</sys:String>
    <sys:String x:Key="AboutPage.LicenseCredits.SideText">法律信息和鸣谢</sys:String>
    <sys:String x:Key="AboutPage.License.Text">本软件根据 BSD-3-Clause 许可证授权。</sys:String>
    <sys:String x:Key="AboutPage.Xbox360Emulation.Header">Xbox 360 模拟</sys:String>
    <sys:String x:Key="AboutPage.Libraries.Header">库</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaProject.Title">Xenia Project</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaProject.ToolTip"> - 原始 Xbox 360 模拟器</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaCanary.Title">Xenia Canary</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaCanary.ToolTip"> - 包含最新功能的实验性构建</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaNetplay.Title">Xenia Netplay</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaNetplay.ToolTip"> - 多人游戏支持</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaMousehook.Title">Xenia Mousehook</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaMousehook.ToolTip"> - 键盘和鼠标支持</sys:String>
    <sys:String x:Key="AboutPage.Credits.AvaloniaUi.Title">Avalonia UI</sys:String>
    <sys:String x:Key="AboutPage.Credits.AvaloniaUi.ToolTip"> - 跨平台 UI 框架，采用 Fluent Design</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentAvalonia.Title">FluentAvalonia</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentAvalonia.ToolTip"> - 为 Avalonia 提供的 Fluent Design 控件和主题</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentIcons.Title">FluentIcons</sys:String>
