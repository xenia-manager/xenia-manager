    <!-- Config UI Settings - APU Options -->
    <sys:String x:Key="ConfigUiSettings.APU.apu.Title">Sistema Audio</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.Comment">Sistema Audio</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.any">Qualsiasi</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.nop">Nop</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.sdl">SDL</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.xaudio2">XAudio2</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu_max_queued_frames.Title">Frame Audio Max in Coda</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu_max_queued_frames.Comment">Permette di cambiare il max di frame audio in buffer per ridurre il ritardo audio&#10;Abbassare questo valore potrebbe causare problemi di prestazioni</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.mute.Title">Silenzia Audio</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.mute.Comment">Silenzia tutto l'output audio</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.enable_xmp.Title">XMP</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.enable_xmp.Comment">Abilita la riproduzione del Music Player&#10;Può risolvere la musica in alcuni giochi</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xmp_default_volume.Title">Volume Predefinito XMP</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xmp_default_volume.Comment">Volume musica predefinito se il gioco non lo imposta</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_dedicated_xma_thread.Title">Thread XMA Dedicato</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_dedicated_xma_thread.Comment">Abilita la decodifica XMA su thread separato&#10;Con questa opzione disabilitata, aspettati risultati migliori ma prestazioni inferiori</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_new_decoder.Title">Decoder Audio XMA</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_new_decoder.Comment">Abilita l'uso del nuovo decoder audio XMA</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.Title">Decoder XMA</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.Comment">fake: Nessun audio verrà decodificato&#10;master: Versione del decoder identica alla versione base di Xenia&#10;old: Decoder basato sulla versione master con alcuni miglioramenti&#10;new: Nuova versione del decoder. Offre la massima stabilità, ma non è ancora finita</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.fake">Fake</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.master">Master</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.old">Vecchio</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.new">Nuovo</sys:String>

    <!-- Config UI Settings - Content Options -->
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.Title">Maschera Licenza</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.Comment">- Nessuna Licenza: Modalità Demo&#10;- Prima Licenza: Generalmente la licenza versione completa nei titoli Xbox Live Arcade&#10;- Tutte le Licenze: Tutte le possibili licenze abilitate, ma potrebbe causare comportamenti inattesi</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.0">Nessuna Licenza</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.1">Prima Licenza</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.-1">Tutte le Licenze</sys:String>

    <!-- Config UI Settings - CPU Options -->
    <sys:String x:Key="ConfigUiSettings.CPU.break_on_unimplemented_instructions.Title">Interrompi su Istruzioni Non Implementate</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.break_on_unimplemented_instructions.Comment">Interrompi nel debugger host se si incontra un'istruzione PowerPC non implementata</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disable_context_promotion.Title">Disabilita Promozione Contesto</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disable_context_promotion.Comment">Disabilita le ottimizzazioni Context Promotion&#10;Potrebbe essere necessario per alcuni giochi sportivi, ma ridurrà le prestazioni</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disassemble_functions.Title">Disassembla Funzioni</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disassemble_functions.Comment">Disassembla le funzioni durante la generazione</sys:String>

    <!-- Config UI Settings - D3D12 Options -->
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_allow_variable_refresh_rate_and_tearing.Title">Consenti Frequenza Variabile e Tearing</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_allow_variable_refresh_rate_and_tearing.Comment">In schermo intero, consenti la frequenza di aggiornamento variabile su display che la supportano&#10;Su display senza VRR, potrebbe verificarsi tearing in certi casi</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.Title">Priorità Coda</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.Comment">Priorità di pianificazione della coda comandi grafica&#10;0 - Normale&#10;1 - Alta&#10;2 - Global Realtime (richiede privilegi admin)</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.0">Normale</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.1">Alta</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.2">Global Realtime</sys:String>

    <!-- Config UI Settings - Display Options -->
    <sys:String x:Key="ConfigUiSettings.Display.fullscreen.Title">Schermo Intero</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.fullscreen.Comment">Se avviare l'emulatore a schermo intero</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.present_letterbox.Title">Letterbox</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.present_letterbox.Comment">Mantieni le proporzioni durante lo stretching mostrando barre attorno all'immagine</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.Title">Anti-Aliasing</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.Comment">Effetto anti-aliasing di post-processing da applicare all'output del gioco</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.none">Nessuno</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.fxaa">FXAA</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.fxaa_extreme">FXAA Estremo</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.Title">Scalatura e Nitidezza</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.Comment">Effetto di post-processing per il ricampionamento e/o la nitidezza dell'output finale</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.bilinear">Bilineare</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.cas">CAS</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.fsr">FSR</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_sharpness_reduction.Title">Riduzione Nitidezza FSR</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_sharpness_reduction.Comment">Riduzione nitidezza per FSR, in stop&#10;Più basso = più nitido</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_cas_additional_sharpness.Title">Nitidezza Aggiuntiva CAS</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_cas_additional_sharpness.Comment">Nitidezza aggiuntiva per CAS, da 0 a 1&#10;Più alto = più nitido</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_max_upsampling_passes.Title">Passaggi Massimi Upsampling FSR</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_max_upsampling_passes.Comment">Numero massimo di passaggi di upsampling FSR prima di passare allo stretching bilineare</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_dither.Title">Dithering</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_dither.Comment">Applica dithering all'output finale per gradienti più uniformi</sys:String>

    <!-- Config UI Settings - General Options -->
    <sys:String x:Key="ConfigUiSettings.General.allow_plugins.Title">Consenti Plugin</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.allow_plugins.Comment">Consente il caricamento di plugin/trainer&#10;I plugin sono moduli xex homebrew per creare mod&#10;Funzione sperimentale</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.discord.Title">Discord Rich Presence</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.discord.Comment">Abilita Discord rich presence</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.apply_patches.Title">Applica Patch</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.apply_patches.Comment">Abilita la funzionalità di patch personalizzate</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.controller_hotkeys.Title">Tasti Rapidi Controller</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.controller_hotkeys.Comment">Tasti rapidi per controller Xbox e PS</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.launch_module.Title">Modulo di Avvio</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.launch_module.Comment">Eseguibile da avviare invece del default.xex&#10;Lascia vuoto per avviare il modulo predefinito</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.notification_sound_path.Title">Percorso Suono Notifica</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.notification_sound_path.Comment">Percorso del suono di notifica selezionato&#10;NOTA: Il suono DEVE essere in formato wav!</sys:String>

    <!-- Config UI Settings - GPU Options -->
    <sys:String x:Key="ConfigUiSettings.GPU.vsync.Title">VSync</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.vsync.Comment">Abilita VSYNC</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.framerate_limit.Title">Limite Framerate</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.framerate_limit.Comment">Frame per secondo massimi&#10;0 = Illimitati&#10;Predefinito a 60 con VSYNC abilitato</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.Title">Sistema Grafico</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.Comment">Sistema grafico da usare</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.any">Qualsiasi</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.d3d12">D3D12</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.vulkan">Vulkan</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.null">Null</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.Title">Percorso Render Target (D3D12)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.Comment">Percorso emulazione render target su Direct3D 12&#10;RTV - Render target host&#10;ROV - Rasterizer-ordered views</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.any">Auto</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.rtv">RTV</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.rov">ROV</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.Title">Percorso Render Target (Vulkan)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.Comment">Percorso emulazione render target su Vulkan&#10;FBO - Framebuffer host&#10;FSI - Fragment shader interlock</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.any">Auto</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.fbo">FBO</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.fsi">FSI</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.Title">Readback Resolve</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.Comment">Controlla readback CPU dei risultati render-to-texture&#10;None - disabilita&#10;Fast - 1 frame di ritardo&#10;Full - preciso ma lento</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.none">Nessuno</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.fast">Veloce</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.full">Completo</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_x.Title">Scala Risoluzione X</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_x.Comment">Scala in pixel interi della larghezza per scalare la risoluzione di rendering</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_y.Title">Scala Risoluzione Y</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_y.Comment">Scala in pixel interi dell'altezza per scalare la risoluzione di rendering</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu_allow_invalid_fetch_constants.Title">Consenti Costanti Fetch Non Valide</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu_allow_invalid_fetch_constants.Comment">Consenti costanti fetch con tipo non valido&#10;Generalmente non sicuro ma può aggirare certi errori</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gamma_render_target_as_srgb.Title">Render Target Gamma come sRGB</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gamma_render_target_as_srgb.Comment">Usa output sRGB sull'host per blending corretto nello spazio colore lineare</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_lower_threshold.Title">Soglia Inferiore Occlusione</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_lower_threshold.Comment">Se -1 nessun conteggio campione viene scritto, i giochi potrebbero bloccarsi&#10;Altrimenti, il conteggio campione di ogni tile viene incrementato ad ogni EVENT_WRITE_ZPD</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_upper_threshold.Title">Soglia Superiore Occlusione</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_upper_threshold.Comment">Imposta a un numero maggiore della soglia inferiore&#10;Ignorato se la soglia inferiore è -1</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.use_fuzzy_alpha_epsilon.Title">Usa Epsilon Alpha Approssimativo</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.use_fuzzy_alpha_epsilon.Comment">Confronto approssimativo per i valori alpha per prevenire sfarfallio su NVIDIA</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.clear_memory_page_state.Title">Azzera Stato Pagine Memoria</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.clear_memory_page_state.Comment">Aggiorna lo stato delle pagine di memoria per abilitare i dati scritti dalla GPU</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.Title">Override Filtraggio Anisotropico</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.Comment">Forza il filtraggio anisotropico per le texture idonee&#10;Valori più alti mantengono texture più nitide a costo di maggiore larghezza di banda</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.-1">Nessun Override (Predefinito)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.0">Disabilita Filtraggio Anisotropico</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.1">1x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.2">2x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.3">4x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.4">8x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.5">16x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.async_shader_compilation.Title">Compilazione Shader Asincrona</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.async_shader_compilation.Comment">Compila shader in background eliminando gli stutter&#10;Può causare brevi artefatti visivi durante la creazione delle pipeline</sys:String>

    <!-- Config UI Settings - HID Options -->
    <sys:String x:Key="ConfigUiSettings.HID.hid.Title">Sistema di Input</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.Comment">Sistema di input da usare</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.any">Qualsiasi</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.nop">Nop</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.sdl">SDL</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.winkey">WinKey</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.xinput">XInput</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.Title">Modalità Tastiera</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.Comment">Modalità di funzionamento della tastiera:&#10;0 - Disabilitata&#10;1 - Abilitata&#10;2 - Passthrough (richiede controller connesso)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.0">Disabilitata</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.1">Abilitata</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.2">Passthrough</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_user_index.Title">Indice Utente Tastiera</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_user_index.Comment">Porta controller emulata dalla tastiera (0-3)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.left_stick_deadzone_percentage.Title">Deadzone Stick Sinistro (LS)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.left_stick_deadzone_percentage.Comment">Livello di deadzone per lo stick sinistro (0-100%)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.right_stick_deadzone_percentage.Title">Deadzone Stick Destro (RS)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.right_stick_deadzone_percentage.Comment">Livello di deadzone per lo stick destro (0-100%)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.vibration.Title">Vibrazione</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.vibration.Comment">Attiva/disattiva la vibrazione del controller</sys:String>

    <!-- Config UI Settings - HID.WinKey Options -->
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_a.Title">Pulsante A</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_a.Comment">Tasti da associare ad A, separati da spazi. Formato: codice virtuale (0x26), carattere (A-Z, 0-9), con modificatori (^ = Shift, _ = senza Shift). Es: "Q I" associa Q e I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_b.Title">Pulsante B</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_b.Comment">Tasti da associare a B, separati da spazi. Formato: codice virtuale (0x26), carattere (A-Z, 0-9), con modificatori (^ = Shift, _ = senza Shift). Es: "Q I" associa Q e I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_back.Title">Pulsante BACK</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_back.Comment">Tasti da associare a BACK, separati da spazi. Formato: codice virtuale (0x26), carattere (A-Z, 0-9), con modificatori. Es: "Q I" associa Q e I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_down.Title">D-Pad Giù</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_down.Comment">Tasti da associare a DPAD_DOWN, separati da spazi. Es: "^S" = Shift+S</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_left.Title">D-Pad Sinistra</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_left.Comment">Tasti da associare a DPAD_LEFT, separati da spazi. Es: "^A" = Shift+A</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_right.Title">D-Pad Destra</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_right.Comment">Tasti da associare a DPAD_RIGHT, separati da spazi. Es: "^D" = Shift+D</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_up.Title">D-Pad Su</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_up.Comment">Tasti da associare a DPAD_UP, separati da spazi. Es: "^W" = Shift+W</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_guide.Title">Pulsante Guide</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_guide.Comment">Tasti da associare a GUIDE, separati da spazi. Es: "0x08" = Backspace</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_shoulder.Title">LB (Left Bumper)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_shoulder.Comment">Tasti da associare a LEFT_SHOULDER, separati da spazi. Es: "Q I" associa Q e I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb.Title">Pressione Stick Sinistro (L3)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb.Comment">Tasti da associare a LEFT_THUMB_PRESSED, separati da spazi. Es: "Q I" associa Q e I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_down.Title">Thumbstick Sinistro Giù</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_down.Comment">Tasti da associare a LEFT_THUMB_DOWN, separati da spazi. Es: "_S" = S senza Shift</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_left.Title">Thumbstick Sinistro Sinistra</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_left.Comment">Tasti da associare a LEFT_THUMB_LEFT, separati da spazi. Es: "_A" = A senza Shift</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_right.Title">Thumbstick Sinistro Destra</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_right.Comment">Tasti da associare a LEFT_THUMB_RIGHT, separati da spazi. Es: "_D" = D senza Shift</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_up.Title">Thumbstick Sinistro Su</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_up.Comment">Tasti da associare a LEFT_THUMB_UP, separati da spazi. Es: "_W" = W senza Shift</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_trigger.Title">LT (Left Trigger)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_trigger.Comment">Tasti da associare a LEFT_TRIGGER, separati da spazi. Es: "Q I" associa Q e I allo stesso grilletto</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_shoulder.Title">RB (Right Bumper)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_shoulder.Comment">Tasti da associare a RIGHT_SHOULDER, separati da spazi. Es: "Q I" associa Q e I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb.Title">Pressione Stick Destro (R3)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb.Comment">Tasti da associare a RIGHT_THUMB_PRESSED, separati da spazi. Es: "Q I" associa Q e I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_down.Title">Thumbstick Destro Giù</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_down.Comment">Tasti da associare a RIGHT_THUMB_DOWN, separati da spazi. Es: "0x28" = Freccia Giù</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_left.Title">Thumbstick Destro Sinistra</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_left.Comment">Tasti da associare a RIGHT_THUMB_LEFT, separati da spazi. Es: "0x25" = Freccia Sinistra</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_right.Title">Thumbstick Destro Destra</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_right.Comment">Tasti da associare a RIGHT_THUMB_RIGHT, separati da spazi. Es: "0x27" = Freccia Destra</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_up.Title">Thumbstick Destro Su</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_up.Comment">Tasti da associare a RIGHT_THUMB_UP, separati da spazi. Es: "0x26" = Freccia Su</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_trigger.Title">RT (Right Trigger)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_trigger.Comment">Tasti da associare a RIGHT_TRIGGER, separati da spazi. Es: "E O" associa E e O allo stesso grilletto</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_start.Title">Pulsante START</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_start.Comment">Tasti da associare a START, separati da spazi. Es: "Q I" associa Q e I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_x.Title">Pulsante X</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_x.Comment">Tasti da associare a X, separati da spazi. Es: "Q I" associa Q e I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_y.Title">Pulsante Y</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_y.Comment">Tasti da associare a Y, separati da spazi. Es: "Q I" associa Q e I</sys:String>

    <!-- Config UI Settings - Kernel Options -->
    <sys:String x:Key="ConfigUiSettings.Kernel.apply_title_update.Title">Applica Aggiornamento Titolo</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.apply_title_update.Comment">Applica gli aggiornamenti del titolo</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.cl.Title">Riga di Comando</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.cl.Comment">Argomenti aggiuntivi della riga di comando forniti al guest</sys:String>

    <!-- Config UI Settings - Logging Options -->
    <sys:String x:Key="ConfigUiSettings.Logging.enable_console.Title">Abilita Console</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.enable_console.Comment">Apri una finestra console con la finestra principale</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.Title">Livello di Log</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.Comment">Livello massimo da registrare</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.option.0">Errore</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.option.1">Avviso</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.option.2">Info</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.option.3">Debug</sys:String>

    <!-- Config UI Settings - Memory Options -->
    <sys:String x:Key="ConfigUiSettings.Memory.protect_zero.Title">Proteggi Zero</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.protect_zero.Comment">Proteggi la pagina zero da letture e scritture</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.scribble_heap.Title">Scribble Heap</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.scribble_heap.Comment">Scrivi un valore specifico o casuale in tutta la memoria heap allocata</sys:String>

    <!-- Config UI Settings - Storage Options -->
    <sys:String x:Key="ConfigUiSettings.Storage.mount_cache.Title">Monta Cache</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_cache.Comment">Abilita il montaggio della cache</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_scratch.Title">Monta Scratch</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_scratch.Comment">Abilita il montaggio scratch</sys:String>

    <!-- Config UI Settings - UI Options -->
    <sys:String x:Key="ConfigUiSettings.UI.show_achievement_notification.Title">Mostra Notifica Obiettivi</sys:String>
    <sys:String x:Key="ConfigUiSettings.UI.show_achievement_notification.Comment">Mostra la notifica degli obiettivi sullo schermo</sys:String>

    <!-- Config UI Settings - Video Options -->
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.Title">Risoluzione Display Interna</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.Comment">Consenti ai giochi di renderizzare in una risoluzione specifica</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.0">640x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.1">640x576</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.2">720x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.3">720x576</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.4">800x600</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.5">848x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.6">1024x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.7">1152x864</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.8">1280x720</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.9">1280x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.10">1280x960</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.11">1280x1024</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.12">1360x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.13">1440x900</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.14">1680x1050</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.15">1920x540</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.16">1920x1080</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.17">Personalizzata (X/Y)</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_x.Title">Larghezza Risoluzione Personalizzata</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_x.Comment">Larghezza personalizzata per la risoluzione display interna&#10;NOTA: Richiede Risoluzione impostata su "Personalizzata (X/Y)"</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_y.Title">Altezza Risoluzione Personalizzata</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_y.Comment">Altezza personalizzata per la risoluzione display interna&#10;NOTA: Richiede Risoluzione impostata su "Personalizzata (X/Y)"</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.widescreen.Title">Widescreen</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.widescreen.Comment">Passa tra rapporto d'aspetto 16:9 e 4:3</sys:String>

    <!-- Config UI Settings - Vulkan Options -->
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_immediate.Title">Consenti Modalità Immediata</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_immediate.Comment">Consenti la modalità di presentazione immediata (1a priorità), latenza più bassa con possibile tearing</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_mailbox.Title">Consenti Modalità Mailbox</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_mailbox.Comment">Consenti la modalità mailbox (2a priorità), bassa latenza senza tearing</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_fifo_relaxed.Title">Consenti Modalità FIFO Rilassata</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_fifo_relaxed.Comment">Consenti la modalità FIFO rilassata (3a priorità), attende il vsync ma può avere tearing se il framerate non raggiunge il refresh rate</sys:String>

    <!-- Config UI Settings - Live/Netplay Options -->
    <sys:String x:Key="ConfigUiSettings.Live.api_address.Title">Indirizzo API</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.api_address.Comment">Indirizzo server Xenia (es., IP:PORTA)</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.discord_presence_user_index.Title">Indice Utente Discord Rich Presence</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.discord_presence_user_index.Comment">Indice profilo utente per Discord rich presence [0-3]</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.Title">Modalità Rete</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.Comment">Modalità di rete&#10;0 - Offline&#10;1 - Systemlink&#10;2 - Xbox Live</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.0">Offline</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.1">Systemlink</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.2">Xbox Live</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.upnp.Title">UPnP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.upnp.Comment">Forwarding porte automatico tramite UPnP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xhttp.Title">XHTTP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xhttp.Comment">Attiva/disattiva XHTTP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xlink_kai_systemlink_hack.Title">Hack SystemLink XLink Kai</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xlink_kai_systemlink_hack.Comment">Abilita hack per il supporto XLink Kai&#10;Potrebbe rompere alcuni giochi</sys:String>

    <!-- Config UI Settings - MouseHook Options -->
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_autoaim.Title">Disabilita Autoaim</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_autoaim.Comment">Disabilita l'autoaim nei giochi che lo supportano (GoldenEye, Perfect Dark, Saints Row, COD)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_fullscreen_esc_bind.Title">Disabilita ESC a Schermo Intero</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_fullscreen_esc_bind.Comment">Disabilita l'uscita dallo schermo intero premendo Escape</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.fov_sensitivity.Title">Sensibilità FOV</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.fov_sensitivity.Comment">Scala mouse quando il FOV viene ridotto (COD, DR, RDR e Giochi UE3)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_aim_turn_distance.Title">(GoldenEye/Perfect Dark)&#10;Distanza Rotazione Mira</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_aim_turn_distance.Comment">(GoldenEye/Perfect Dark) Distanza del mirino in modalità mira prima di ruotare la telecamera</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_debug_menu.Title">(GoldenEye)&#10;Menu Debug</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_debug_menu.Comment">(GoldenEye) Abilita il menu debug, accessibile con LB/1</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_gun_sway.Title">(GoldenEye/Perfect Dark)&#10;Oscillazione Arma</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_gun_sway.Comment">(GoldenEye/Perfect Dark) Abilita l'oscillazione dell'arma durante la rotazione</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_remove_blur.Title">(GoldenEye)&#10;Rimuovi Sfocatura</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_remove_blur.Comment">(GoldenEye) Rimuove la sfocatura a bassa risoluzione in modalità classica</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.internal_hook.Title">Hook Interno</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.internal_hook.Comment">Tecnica di hooking migliore per iniezione mouse superiore (Saints Row 1)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_x.Title">Inverti Asse X</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_x.Comment">Inverti l'asse X del mouse</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_y.Title">Inverti Asse Y</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_y.Comment">Inverti l'asse Y del mouse</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.menu_sensitivity.Title">(GoldenEye/Saints Row 1)&#10;Sensibilità Menu</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.menu_sensitivity.Comment">(GoldenEye/Saints Row 1) Sensibilità del mouse nei menu</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_snappy_wheel.Title">(Red Dead Redemption)&#10;Ruota Rapida</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_snappy_wheel.Comment">(Red Dead Redemption) Aggancia la ruota delle armi a incrementi di 45 gradi</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_turbo_gallop_horse.Title">(Red Dead Redemption)&#10;Galoppo Turbo</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_turbo_gallop_horse.Comment">(Red Dead Redemption) Abilita il galoppo turbo per cavalli e carrozze</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sensitivity.Title">Sensibilità Mouse</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sensitivity.Comment">Sensibilità del mouse</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.source_sniper_sensitivity.Title">Sensibilità Cecchino Source</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.source_sniper_sensitivity.Comment">Sensibilità del mirino cecchino del motore Source</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr1_increase_vehicle_rotation_limit.Title">(Saints Row 1)&#10;Limite Rotazione Veicolo</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr1_increase_vehicle_rotation_limit.Comment">(Saints Row 1) Modifica il limite di rotazione dei veicoli simile a quello a piedi</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_better_handbrake_cam.Title">(Saints Row 2)&#10;Camera Freno a Mano Migliore</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_better_handbrake_cam.Comment">(Saints Row 2) Separa la rotazione X dai veicoli durante la frenata a mano come in SR1</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_hold_fine_aim.Title">(Saints Row 2)&#10;Tieni Mira Fine</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_hold_fine_aim.Comment">(Saints Row 2) Cambia la mira fine (ADS) da toggle a pressione mantenuta</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_better_drive_cam.Title">(Saints Row 1 &amp; 2)&#10;Camera Guida Migliore</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_better_drive_cam.Comment">(Saints Row 1&amp;2) Separa la rotazione X dai veicoli quando il auto-centering è disabilitato</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_disable_shared_reload.Title">(Saints Row 1)&#10;Disabilita Ricarica Condivisa</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_disable_shared_reload.Comment">(Saints Row 1) Disabilita la ricarica delle armi premendo il pulsante interno (A)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.swap_wheel.Title">(Saints Row 1)&#10;Inverti Ruota</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.swap_wheel.Comment">Inverte le associazioni per la ruota delle armi e la direzione zoom mappa in Saints Row 1</sys:String>

    <!-- About Page -->
    <sys:String x:Key="AboutPage.App.Description">Uno strumento di gestione completo per Xenia Emulator. Installa, aggiorna e gestisci facilmente le diverse versioni dell'emulatore Xenia con un'interfaccia intuitiva.</sys:String>
    <sys:String x:Key="AboutPage.WebsiteButton.Text">Sito Web</sys:String>
    <sys:String x:Key="AboutPage.GithubButton.Text">GitHub</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesButton.Text">Controlla Aggiornamenti</sys:String>
    <sys:String x:Key="AboutPage.UpdateXeniaManagerButton.Text">Aggiorna Xenia Manager</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesFailed.Title">Controllo Aggiornamenti Fallito</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesFailed.Message">Si è verificato un errore durante il controllo degli aggiornamenti:&#10;{0}</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.Title">Aggiornamento Fallito</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.Message">Si è verificato un errore durante l'aggiornamento di Xenia Manager:&#10;{0}</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.NoReleaseInfo">Impossibile ottenere le informazioni sulla release. Riprova più tardi.</sys:String>
    <sys:String x:Key="AboutPage.DownloadingUpdate">Download aggiornamento</sys:String>
    <sys:String x:Key="AboutPage.ExtractingUpdate">Estrazione aggiornamento</sys:String>
    <sys:String x:Key="AboutPage.LicenseCredits.Text">Licenza e Crediti</sys:String>
    <sys:String x:Key="AboutPage.LicenseCredits.SideText">Informazioni legali e riconoscimenti</sys:String>
    <sys:String x:Key="AboutPage.License.Text">Questo software è concesso in licenza sotto la Licenza BSD-3-Clause.</sys:String>
    <sys:String x:Key="AboutPage.Xbox360Emulation.Header">Emulazione Xbox 360</sys:String>
    <sys:String x:Key="AboutPage.Libraries.Header">Librerie</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaProject.Title">Progetto Xenia</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaProject.ToolTip"> - Emulatore Xbox 360 originale</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaCanary.Title">Xenia Canary</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaCanary.ToolTip"> - Build sperimentale con le ultime funzionalità</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaNetplay.Title">Xenia Netplay</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaNetplay.ToolTip"> - Supporto gioco multiplayer</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaMousehook.Title">Xenia Mousehook</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaMousehook.ToolTip"> - Supporto tastiera e mouse</sys:String>
    <sys:String x:Key="AboutPage.Credits.AvaloniaUi.Title">Avalonia UI</sys:String>
    <sys:String x:Key="AboutPage.Credits.AvaloniaUi.ToolTip"> - Framework UI multipiattaforma con Fluent Design</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentAvalonia.Title">FluentAvalonia</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentAvalonia.ToolTip"> - Controlli e temi Fluent Design per Avalonia</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentIcons.Title">FluentIcons</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentIcons.ToolTip"> - Framework per le Fluent Symbol Icons</sys:String>
    <sys:String x:Key="AboutPage.Credits.NLog.Title">NLog</sys:String>
    <sys:String x:Key="AboutPage.Credits.NLog.ToolTip"> - Framework di logging flessibile per .NET</sys:String>
    <sys:String x:Key="AboutPage.Credits.Xbox360Toolkit.Title">Xbox 360 Toolkit</sys:String>
    <sys:String x:Key="AboutPage.Credits.Xbox360Toolkit.ToolTip"> - Analisi dettagli gioco</sys:String>
    <sys:String x:Key="AboutPage.Credits.SharpCompress.Title">SharpCompress</sys:String>
    <sys:String x:Key="AboutPage.Credits.SharpCompress.ToolTip"> - Gestione archivi e compressione</sys:String>
    <sys:String x:Key="AboutPage.Credits.ZstdSharp.Title">ZstdSharp</sys:String>
    <sys:String x:Key="AboutPage.Credits.ZstdSharp.ToolTip"> - Compressione Zstandard per .NET</sys:String>
    <sys:String x:Key="AboutPage.FooterNote.Text">Questa applicazione non è affiliata, approvata o sponsorizzata da Microsoft Corporation o dal Progetto Xenia. Tutti i marchi sono di proprietà dei rispettivi titolari.&#10;Xbox 360 è un marchio registrato di Microsoft Corporation.&#10;Xenia è un marchio registrato del Progetto Xenia.&#10;Qualsiasi riferimento a questi marchi è fatto esclusivamente per identificare compatibilità o funzionalità.&#10;Questo software è destinato esclusivamente a scopi educativi e informativi. Non contiene né distribuisce contenuti protetti da copyright. Gli utenti sono responsabili di garantire la conformità alle leggi applicabili.&#10;Questa applicazione è fornita "così com'è" senza garanzie di alcun tipo. Usare a proprio rischio.</sys:String>
    <sys:String x:Key="AboutPage.UseExperimentalBuild.Title">Usa Build Sperimentale</sys:String>
    <sys:String x:Key="AboutPage.UseExperimentalBuild.Description">Abilita per ricevere aggiornamenti con funzionalità sperimentali e accesso anticipato</sys:String>
    <sys:String x:Key="AboutPage.WebsiteButton.ToolTip">Apre il sito web di Xenia Manager</sys:String>
    <sys:String x:Key="AboutPage.GithubButton.ToolTip">Apre il Repository GitHub di Xenia Manager</sys:String>
    <sys:String x:Key="AboutPage.InfoBar.XeniaManagerUpdateAvailable.Message">È disponibile una versione più recente di Xenia Manager.</sys:String>
    <sys:String x:Key="AboutPage.InfoBar.NoXeniaManagerUpdateAvailable.Message">Stai attualmente usando l'ultima versione di Xenia Manager.</sys:String>

    <!-- Library Page - Drag and Drop -->
    <sys:String x:Key="LibraryPage.DragDrop.Title">Trascina i file per aggiungere giochi</sys:String>
    <sys:String x:Key="LibraryPage.DragDrop.Subtitle">Sono supportati i file .iso, .xex, .zar</sys:String>
