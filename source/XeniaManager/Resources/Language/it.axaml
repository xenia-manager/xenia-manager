<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- App global -->
    <sys:String x:Key="App.Title">Xenia Manager</sys:String>

    <!-- Welcome Dialog -->
    <sys:String x:Key="WelcomeDialog.Title">Benvenuto in Xenia Manager</sys:String>
    <sys:String x:Key="WelcomeDialog.Description">Seleziona il tema preferito per l'interfaccia:</sys:String>
    <sys:String x:Key="WelcomeDialog.ContinueButton">Continua</sys:String>

    <!-- Main View -->
    <sys:String x:Key="MainView.Navigation.OpenXenia">Apri Xenia</sys:String>
    <sys:String x:Key="MainView.Navigation.Library">Libreria Giochi</sys:String>
    <sys:String x:Key="MainView.Navigation.XeniaSettings">Impostazioni Xenia</sys:String>
    <sys:String x:Key="MainView.Navigation.ManagePage">Gestisci Xenia</sys:String>
    <sys:String x:Key="MainView.Navigation.About">Informazioni</sys:String>
    <sys:String x:Key="MainView.Navigation.Settings">Impostazioni</sys:String>
    <sys:String x:Key="MainView.Navigation.Error.Title">Errore di navigazione</sys:String>
    <sys:String x:Key="MainView.Navigation.Error.Message">Impossibile navigare alla pagina designata.&#10;{0}</sys:String>

    <!-- Library Page -->
    <sys:String x:Key="LibraryPage.Search.Watermark">Cerca...</sys:String>
    <sys:String x:Key="LibraryPage.Refresh.ToolTip">Ricarica la libreria giochi</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.Header">Modifica Vista Griglia</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.ToolTip">Mostra/Nascondi informazioni aggiuntive sulle copertine</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.Title.Header">Titolo Gioco</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.CompatibilityRating.Header">Valutazione Compatibilità</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.XeniaVersion.Header">Versione Xenia</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.XeniaVersion.ToolTip">Mostra l'icona della versione Xenia per ogni gioco</sys:String>
    <sys:String x:Key="LibraryPage.Options.DoubleClickLaunch.Header">Avvia con Doppio Click</sys:String>
    <sys:String x:Key="LibraryPage.Options.DoubleClickLaunch.ToolTip">Passa da singolo a doppio click per avviare i giochi</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Header">Scansiona Cartella</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.ToolTip">Scansiona la cartella selezionata alla ricerca di giochi&#10;Consulta la Wiki per maggiori dettagli su questa funzione</sys:String>
