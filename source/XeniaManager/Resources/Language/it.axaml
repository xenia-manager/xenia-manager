    <sys:String x:Key="FolderScanProgressDialog.Statistics.GamesFound">Giochi Trovati</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Button.Cancel">Annulla</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Button.Close">Chiudi</sys:String>

    <!-- Add Games Progress Dialog -->
    <sys:String x:Key="AddGamesProgressDialog.Title">Aggiunta Giochi alla Libreria</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Subtitle">Elaborazione dei file di gioco rilevati</sys:String>
    <sys:String x:Key="AddGamesProgressDialog.Statistics.Processed">Elaborati</sys:String>
