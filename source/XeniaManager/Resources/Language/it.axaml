    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Success.Message">Esportati con successo {0} collegamento/i di gioco.&#10;Fallite: {1}&#10;&#10;Esportazioni riuscite:&#10;{2}&#10;&#10;Esportazioni fallite:&#10;{3}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Error.Title">Esportazione Fallita</sys:String>
    <sys:String x:Key="LibraryPage.Options.ExportShortcuts.Error.Message">Si è verificato un errore durante l'esportazione dei collegamenti.&#10;{0}</sys:String>
