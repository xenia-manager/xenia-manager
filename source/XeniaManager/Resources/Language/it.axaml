    <sys:String x:Key="FolderScanProgressDialog.Status.Scanning">Scansione: {0}</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Status.Complete">Scansione completata! Trovati {0} gioco/i</sys:String>
