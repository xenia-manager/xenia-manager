    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Error.Message">Si è verificato un errore durante l'ottimizzazione delle impostazioni.&#10;{0}</sys:String>

    <!-- Remove Invalid Games -->
    <sys:String x:Key="LibraryPage.Options.RemoveInvalidGames.Header">Rimuovi Giochi Non Validi</sys:String>
