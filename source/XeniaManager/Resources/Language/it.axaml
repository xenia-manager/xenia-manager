    <sys:String x:Key="LibraryPage.Options.ScanDirectory.MissingStorageProvider.Message">Il provider di archiviazione non è disponibile.&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoXeniaInstalled.Title">Xenia Non Installato</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoXeniaInstalled.Message">Nessuna versione di Xenia è attualmente installata.&#10;Installa Xenia prima di continuare.</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.XeniaSelectionError.Title">Errore di Selezione Xenia</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.XeniaSelectionError.Message">Impossibile selezionare la versione di Xenia.&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.FolderPicker.Title">Seleziona Cartella da Scansionare</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Success.Title">Scansione Completata</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Success.Message">Aggiunti con successo {0} gioco/i alla libreria.</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoGamesFound.Title">Scansione Completata</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoGamesFound.Message">Nessun nuovo gioco trovato nella cartella selezionata.&#10;&#10;La cartella potrebbe non contenere file di gioco compatibili, oppure i giochi sono già presenti nella libreria.</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Error.Title">Scansione Fallita</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.Error.Message">Si è verificato un errore durante la scansione della cartella:&#10;&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.ScanError.Title">Errore di Scansione</sys:String>

    <!-- Folder Scan Progress Dialog -->
    <sys:String x:Key="FolderScanProgressDialog.Title">Scansione in Corso</sys:String>
    <sys:String x:Key="FolderScanProgressDialog.Subtitle">Attendi mentre cerchiamo i file di gioco</sys:String>
