    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Header">Aggiorna Valutazioni Compatibilità</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.ToolTip">Aggiorna le valutazioni di compatibilità per tutti i giochi della libreria dal database online</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Success.Title">Aggiornamento Completato</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Success.Message">Aggiornati con successo {0} gioco/i.&#10;Invariati: {1}&#10;Falliti: {2}&#10;&#10;Giochi aggiornati:&#10;{3}&#10;&#10;Giochi invariati:&#10;{4}&#10;&#10;Aggiornamenti falliti:&#10;{5}</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Error.Title">Aggiornamento Fallito</sys:String>
    <sys:String x:Key="LibraryPage.Options.UpdateCompatibilityRatings.Error.Message">Si è verificato un errore durante l'aggiornamento delle valutazioni.&#10;{0}</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Header">Ottimizza Giochi</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.ToolTip">Applica le impostazioni ottimizzate dal database online a tutti i giochi della libreria</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Success.Title">Ottimizzazione Completata</sys:String>
    <sys:String x:Key="LibraryPage.Options.OptimizeGameSettings.Success.Message">Ottimizzati con successo {0} gioco/i.&#10;Invariati: {1}&#10;Non trovati: {2}&#10;Falliti: {3}&#10;&#10;Giochi ottimizzati:&#10;{4}&#10;&#10;Giochi invariati:&#10;{5}&#10;&#10;Giochi senza impostazioni ottimizzate:&#10;{6}&#10;&#10;Ottimizzazioni fallite:&#10;{7}</sys:String>
