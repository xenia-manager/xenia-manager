    <sys:String x:Key="ConfigUiSettings.Kernel.cl.Title">Komut Satırı</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.cl.Comment">Misafire sağlanacak ek komut satırını belirtin</sys:String>

    <!-- Config UI Settings - Logging Options -->
    <sys:String x:Key="ConfigUiSettings.Logging.enable_console.Title">Konsolu Etkinleştir</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.enable_console.Comment">Ana pencereyle birlikte bir konsol penceresi açar</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.Title">Günlük Seviyesi</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.Comment">Günlüğe kaydedilecek maksimum seviye</sys:String>
