    <!-- Config UI Settings - APU Options -->
    <sys:String x:Key="ConfigUiSettings.APU.apu.Title">Ses Sistemi</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.Comment">Ses Sistemi</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.any">Herhangi</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.nop">Nop</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.sdl">SDL</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.xaudio2">XAudio2</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu_max_queued_frames.Title">Maksimum Ses Kuyruk Kareleri</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu_max_queued_frames.Comment">Ses gecikmesini azaltmak için maksimum arabelleklenmiş ses karelerini değiştirmeye olanak tanır&#10;Bu değeri düşürmek performans sorunlarına neden olabilir</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.mute.Title">Sesi Kapat</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.mute.Comment">Tüm ses çıkışını kapatır</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.enable_xmp.Title">XMP</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.enable_xmp.Comment">Müzik Çalar oynatmayı etkinleştirir&#10;Bazı oyunlarda müziği düzeltebilir</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xmp_default_volume.Title">XMP Varsayılan Ses Düzeyi</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xmp_default_volume.Comment">Oyun tarafından ayarlanmadıysa varsayılan müzik ses düzeyi</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_dedicated_xma_thread.Title">Özel XMA İş Parçacığı</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_dedicated_xma_thread.Comment">XMA kod çözmeyi ayrı bir iş parçacığında etkinleştirir&#10;Bu seçenek devre dışı bırakıldığında daha iyi sonuçlar ancak daha düşük performans beklenir</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_new_decoder.Title">XMA Ses Kod Çözücü</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_new_decoder.Comment">Yeni XMA ses kod çözme kullanımını etkinleştirir</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.Title">XMA Kod Çözücü</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.Comment">fake: Hiçbir ses kod çözülmez&#10;master: Xenia'nın temel sürümündeki kod çözücü ile aynı&#10;old: Birkaç iyileştirme ile master sürümünü temel alan kod çözücü&#10;new: Yeni nesil kod çözücü. En yüksek kararlılığı sağlar, ancak henüz tamamlanmamıştır</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.fake">Fake</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.master">Master</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.old">Eski</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.new">Yeni</sys:String>

    <!-- Config UI Settings - Content Options -->
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.Title">Lisans Maskesi</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.Comment">- Lisans Yok: Demo Modu&#10;- İlk Lisans: Genellikle Xbox Live Arcade oyunlarındaki tam sürüm lisansı&#10;- Tüm Lisanslar: Tüm olası lisanslar etkin, ancak bazı tanımsız davranışlara yol açabilir</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.0">Lisans Yok</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.1">İlk Lisans</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.-1">Tüm Lisanslar</sys:String>

    <!-- Config UI Settings - CPU Options -->
    <sys:String x:Key="ConfigUiSettings.CPU.break_on_unimplemented_instructions.Title">Uygulanmamış Talimatlarda Durdur</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.break_on_unimplemented_instructions.Comment">Uygulanmamış bir PowerPC talimatıyla karşılaşılırsa hata ayıklayıcıda durdur (veya hata ayıklayıcı bağlı değilse çök)</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disable_context_promotion.Title">Context Promotion'ı Devre Dışı Bırak</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disable_context_promotion.Comment">Context Promotion optimizasyonlarını devre dışı bırakır&#10;Bazı spor oyunları için gerekebilir, ancak performansı düşürür</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disassemble_functions.Title">Fonksiyonları Ters Derle</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disassemble_functions.Comment">Oluşturma sırasında fonksiyonları ters derle</sys:String>

    <!-- Config UI Settings - D3D12 Options -->
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_allow_variable_refresh_rate_and_tearing.Title">Değişken Yenileme Hızı ve Yırtılmaya İzin Ver</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_allow_variable_refresh_rate_and_tearing.Comment">Tam ekranda, destekleyen ekranlarda değişken yenileme hızı kullanımına izin verir&#10;VRR desteklemeyen ekranlarda bazı durumlarda ekran yırtılması oluşabilir</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.Title">Kuyruk Önceliği</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.Comment">Grafik (doğrudan) komut kuyruğu zamanlama önceliği&#10;0 - Normal&#10;1 - Yüksek&#10;2 - Yönetici yetkisi gerektiren ve sistem sorumluluğunu etkileyebilen Global Gerçek Zamanlı</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.0">Normal</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.1">Yüksek</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.2">Global Gerçek Zamanlı</sys:String>

    <!-- Config UI Settings - Display Options -->
    <sys:String x:Key="ConfigUiSettings.Display.fullscreen.Title">Tam Ekran</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.fullscreen.Comment">Emülatörün tam ekran başlatılıp başlatılmayacağı</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.present_letterbox.Title">Letterbox Gösterimi</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.present_letterbox.Comment">Kırpılacak overscan alanı kalmadığında görüntü etrafında çubuklar göstererek esnetme sırasında en boy oranını korur</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.Title">Kenar Yumuşatma</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.Comment">Oyunun görüntü çıkışına uygulanacak işlem sonrası kenar yumuşatma efekti</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.none">Hiçbiri</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.fxaa">FXAA</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.fxaa_extreme">FXAA Extreme</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.Title">Ölçekleme ve Keskinleştirme</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.Comment">Nihai ekran çıktısının yeniden örneklenmesi ve/veya keskinleştirilmesi için kullanılacak işlem sonrası efekt</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.bilinear">Bilinear</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.cas">CAS</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.fsr">FSR</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_sharpness_reduction.Title">FSR Keskinlik Azaltma</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_sharpness_reduction.Comment">AMD FidelityFX Super Resolution 1.0 (FSR) için keskinlik azaltma, durak cinsinden&#10;Daha düşük değer daha keskindir</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_cas_additional_sharpness.Title">CAS Ek Keskinlik</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_cas_additional_sharpness.Comment">AMD FidelityFX Contrast Adaptive Sharpening (CAS) için ek keskinlik, 0 ile 1 arasında&#10;Daha yüksek değer daha keskindir</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_max_upsampling_passes.Title">FSR Maksimum Üst Örnekleme Geçişi</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_max_upsampling_passes.Comment">Son geçişten sonra bilinear uzatmaya düşmeden önce AMD FidelityFX Super Resolution 1.0'da (FSR) gerçekleştirilen maksimum üst örnekleme geçişi sayısı</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_dither.Title">Dither</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_dither.Comment">Gradyanların daha pürüzsüz olması için nihai görüntü çıktısını dahili hassasiyetten kanal başına 8 bite dither uygular</sys:String>

    <!-- Config UI Settings - General Options -->
    <sys:String x:Key="ConfigUiSettings.General.allow_plugins.Title">Eklentilere İzin Ver</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.allow_plugins.Comment">plugins\\title_id\\plugin.xex konumundan eklenti/eğitici yüklenmesine izin verir&#10;Eklentiler, mod yapımında kullanılabilen homebrew xex modülleridir&#10;Bu özellik deneyseldir</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.discord.Title">Discord Rich Presence</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.discord.Comment">Discord rich presence'ı etkinleştirir</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.apply_patches.Title">Yamaları Uygula</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.apply_patches.Comment">Özel yama işlevselliğini etkinleştirir</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.controller_hotkeys.Title">Kontrolcü Kısayol Tuşları</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.controller_hotkeys.Comment">Xbox ve PS kontrolcüleri için kısayol tuşları</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.launch_module.Title">Başlatma Modülü</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.launch_module.Comment">default.xex veya oyun tarafından belirtilen modül yerine .iso veya paketten başlatılacak çalıştırılabilir dosya&#10;Varsayılan modülü başlatmak için boş bırakın</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.notification_sound_path.Title">Bildirim Sesi Yolu</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.notification_sound_path.Comment">Seçilen bildirim sesinin yolu (dosya adı dahil)&#10;NOT: Ses MUTLAKA wav formatında olmalıdır!</sys:String>

    <!-- Config UI Settings - GPU Options -->
    <sys:String x:Key="ConfigUiSettings.GPU.vsync.Title">VSync</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.vsync.Comment">VSYNC'i etkinleştirir</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.framerate_limit.Title">Kare Hızı Sınırı</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.framerate_limit.Comment">Saniye başına maksimum kare sayısı&#10;0 = Sınırsız kare&#10;0'a ayarlandığında ve VSYNC etkinken varsayılan 60'tır</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.Title">Grafik Sistemi</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.Comment">Kullanılacak grafik sistemi</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.any">Herhangi</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.d3d12">D3D12</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.vulkan">Vulkan</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.null">Null</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.Title">Render Hedef Yolu (D3D12)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.Comment">Direct3D 12'de kullanılacak render hedef öykünme yolu&#10;RTV - Host render hedefleri&#10;ROV - Rasterleştirici sıralı görünümler</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.any">Otomatik</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.rtv">RTV</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.rov">ROV</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.Title">Render Hedef Yolu (Vulkan)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.Comment">Vulkan'da kullanılacak render hedef öykünme yolu&#10;FBO - Host çerçeve arabellekleri&#10;FSI - Parça gölgelendirici kilidi</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.any">Otomatik</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.fbo">FBO</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.fsi">FSI</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.Title">Geri Okuma Çözümlemesi</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.Comment">Render-to-texture çözümleme sonuçlarının CPU tarafından geri okunmasını kontrol eder&#10;None - geri okumayı devre dışı bırak&#10;Fast - 1 kare gecikme&#10;Full - doğru ancak yavaş</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.none">Hiçbiri</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.fast">Hızlı</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.full">Tam</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_x.Title">Çizim Çözünürlük Ölçeği X</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_x.Comment">Oyun tarafından görülmeden render çözünürlüğünü ölçeklemek için kullanılan tam sayı piksel genişlik ölçeği</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_y.Title">Çizim Çözünürlük Ölçeği Y</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_y.Comment">Oyun tarafından görülmeden render çözünürlüğünü ölçeklemek için kullanılan tam sayı piksel yükseklik ölçeği</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu_allow_invalid_fetch_constants.Title">Geçersiz Fetch Sabitlerine İzin Ver</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu_allow_invalid_fetch_constants.Comment">Geçersiz türe sahip doku ve köşe fetch sabitlerine izin verir&#10;Genellikle güvensizdir ancak bazı oyunlarda fetch sabiti tür hatalarını atlamak için kullanılabilir</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gamma_render_target_as_srgb.Title">Gamma Render Hedefini sRGB Olarak Kullan</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gamma_render_target_as_srgb.Comment">Host doğru karıştırma ile parçalı doğrusal gamayı doğrudan yazamadığında, doğrusal renk uzayında kavramsal olarak doğru karıştırma için hostta sRGB çıktısı kullanır</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_lower_threshold.Title">Sorgu Oklüzyon Alt Eşiği</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_lower_threshold.Comment">-1 olarak ayarlanırsa hiçbir örnek sayısı yazılmaz, oyunlar takılabilir&#10;Aksi takdirde, her EVENT_WRITE_ZPD'de her karonun örnek sayısı bu sayı kadar artırılır</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_upper_threshold.Title">Sorgu Oklüzyon Üst Eşiği</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_upper_threshold.Comment">query_occlusion_sample_lower_threshold değerinden daha yüksek bir sayıya ayarlayın&#10;query_occlusion_sample_lower_threshold -1 olarak ayarlanmışsa bu değer yok sayılır</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.use_fuzzy_alpha_epsilon.Title">Fuzzy Alpha Epsilon Kullan</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.use_fuzzy_alpha_epsilon.Comment">NVIDIA ekran kartlarında titreşimi önlemek için alfa değerleri için yaklaşık karşılaştırma kullanır</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.clear_memory_page_state.Title">Bellek Sayfa Durumunu Temizle</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.clear_memory_page_state.Comment">GPU tarafından yazılan verileri etkinleştirmek için bellek sayfalarının durumunu yeniler</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.Title">Anizotropik Filtreleme Geçersiz Kılma</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.Comment">Uygun dokular için anizotropik filtrelemeyi (AF) zorlar&#10;Daha yüksek değerler GPU bant genişliği pahasına dokuları eğik açılarda daha keskin tutar&#10;Nadir durumlarda AF'yi zorlamak görsel bozulmalara neden olabilir</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.-1">Geçersiz Kılma Yok (Varsayılan)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.0">Anizotropik Filtrelemeyi Devre Dışı Bırak</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.1">1x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.2">2x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.3">4x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.4">8x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.5">16x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.async_shader_compilation.Title">Eşzamansız Shader Derleme</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.async_shader_compilation.Comment">Shader'ları derler ve ardışık düzenleri arka plan iş parçacıklarında eşzamansız olarak oluşturur&#10;Shader derleme takılmasını ortadan kaldırır ancak ardışık düzenler oluşturulurken kısa süreli görüntü bozulmalarına neden olabilir&#10;Devre dışı bırakıldığında, ardışık düzenler eşzamanlı olarak oluşturulur, bu da takılmaya neden olur ancak görsel bozulma olmaz</sys:String>

    <!-- Config UI Settings - HID Options -->
    <sys:String x:Key="ConfigUiSettings.HID.hid.Title">Giriş Sistemi</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.Comment">Kullanılacak giriş sistemi</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.any">Herhangi</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.nop">Nop</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.sdl">SDL</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.winkey">WinKey</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.xinput">XInput</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.Title">Klavye Modu</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.Comment">Kullanıcının klavye çalışma modunu belirlemesine olanak tanır:&#10;0 - Devre Dışı&#10;1 - Etkin&#10;2 - Kontrolcü bağlı olmasını gerektiren geçiş modu</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.0">Devre Dışı</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.1">Etkin</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.2">Geçişli</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_user_index.Title">Klavye Kullanıcı Dizini</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_user_index.Comment">Klavyenin öykündüğü kontrolcü bağlantı noktası (0-3)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.left_stick_deadzone_percentage.Title">Sol Stick Ölü Bölge</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.left_stick_deadzone_percentage.Comment">Sol stick için ölü bölge seviyesini tanımlar (%0-100)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.right_stick_deadzone_percentage.Title">Sağ Stick Ölü Bölge</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.right_stick_deadzone_percentage.Comment">Sağ stick için ölü bölge seviyesini tanımlar (%0-100)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.vibration.Title">Titreşim</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.vibration.Comment">Kontrolcü titreşimini aç/kapat</sys:String>

    <!-- Config UI Settings - HID.WinKey Options -->
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_a.Title">A Tuşu</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_a.Comment">A'ya bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "Q I" hem Q hem de I tuşunu bağlar</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_b.Title">B Tuşu</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_b.Comment">B'ye bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "Q I" hem Q hem de I tuşunu bağlar</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_back.Title">BACK Tuşu</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_back.Comment">BACK'e bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "Q I" hem Q hem de I tuşunu bağlar</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_down.Title">D-Pad Aşağı</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_down.Comment">DPAD_DOWN'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "^S" Shift+S anlamına gelir</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_left.Title">D-Pad Sol</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_left.Comment">DPAD_LEFT'e bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "^A" Shift+A anlamına gelir</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_right.Title">D-Pad Sağ</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_right.Comment">DPAD_RIGHT'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "^D" Shift+D anlamına gelir</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_up.Title">D-Pad Yukarı</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_up.Comment">DPAD_UP'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "^W" Shift+W anlamına gelir</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_guide.Title">Guide Tuşu</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_guide.Comment">GUIDE'e bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "0x08" Backspace'tir</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_shoulder.Title">Sol Omuz</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_shoulder.Comment">LEFT_SHOULDER'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "Q I" hem Q hem de I tuşunu bağlar</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb.Title">Sol Thumbstick Basma</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb.Comment">LEFT_THUMB_PRESSED'e bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "Q I" hem Q hem de I tuşunu bağlar</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_down.Title">Sol Thumbstick Aşağı</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_down.Comment">LEFT_THUMB_DOWN'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "_S" Shift'siz S anlamına gelir</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_left.Title">Sol Thumbstick Sol</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_left.Comment">LEFT_THUMB_LEFT'e bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "_A" Shift'siz A anlamına gelir</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_right.Title">Sol Thumbstick Sağ</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_right.Comment">LEFT_THUMB_RIGHT'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "_D" Shift'siz D anlamına gelir</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_up.Title">Sol Thumbstick Yukarı</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_up.Comment">LEFT_THUMB_UP'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "_W" Shift'siz W anlamına gelir</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_trigger.Title">Sol Tetik</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_trigger.Comment">LEFT_TRIGGER'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "Q I" hem Q hem de I tuşunu aynı tetiğe bağlar</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_shoulder.Title">Sağ Omuz</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_shoulder.Comment">RIGHT_SHOULDER'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "Q I" hem Q hem de I tuşunu bağlar</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb.Title">Sağ Thumbstick Basma</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb.Comment">RIGHT_THUMB_PRESSED'e bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "Q I" hem Q hem de I tuşunu bağlar</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_down.Title">Sağ Thumbstick Aşağı</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_down.Comment">RIGHT_THUMB_DOWN'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "0x28" Aşağı Ok'tur</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_left.Title">Sağ Thumbstick Sol</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_left.Comment">RIGHT_THUMB_LEFT'e bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "0x25" Sol Ok'tur</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_right.Title">Sağ Thumbstick Sağ</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_right.Comment">RIGHT_THUMB_RIGHT'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "0x27" Sağ Ok'tur</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_up.Title">Sağ Thumbstick Yukarı</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_up.Comment">RIGHT_THUMB_UP'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "0x26" Yukarı Ok'tur</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_trigger.Title">Sağ Tetik</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_trigger.Comment">RIGHT_TRIGGER'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "E O" hem E hem de O tuşunu aynı tetiğe bağlar</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_start.Title">START Tuşu</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_start.Comment">START'a bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "Q I" hem Q hem de I tuşunu bağlar</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_x.Title">X Tuşu</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_x.Comment">X'e bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "Q I" hem Q hem de I tuşunu bağlar</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_y.Title">Y Tuşu</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_y.Comment">Y'ye bağlanacak tuşların listesi, boşlukla ayrılmış. Biçim: Sanal tuş kodu (0x26), tek karakter (A-Z, 0-9), değiştiricilerle birlikte (^ Shift gerektirir, _ Shift gerektirmez). Örnek: "Q I" hem Q hem de I tuşunu bağlar</sys:String>

    <!-- Config UI Settings - Kernel Options -->
    <sys:String x:Key="ConfigUiSettings.Kernel.apply_title_update.Title">Title Update Uygula</sys:String>
