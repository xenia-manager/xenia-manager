    <sys:String x:Key="XeniaSettingsPage.ResetSettings.Failure.Message">'{0}' yapılandırma dosyası sıfırlanamadı: {1}</sys:String>
    <sys:String x:Key="XeniaSettingsPage.OpenInEditor.NoSelection.Title">Yapılandırma Seçilmedi</sys:String>
    <sys:String x:Key="XeniaSettingsPage.OpenInEditor.NoSelection.Message">Düzenleyicide açmadan önce lütfen bir yapılandırma dosyası seçin.</sys:String>
    <sys:String x:Key="XeniaSettingsPage.OpenInEditor.Failure.Title">Düzenleyicide Açma Başarısız</sys:String>
    <sys:String x:Key="XeniaSettingsPage.OpenInEditor.Failure.Message">'{0}' yapılandırma dosyası açılamadı: {1}</sys:String>
    <sys:String x:Key="XeniaSettingsPage.SaveSettings.Success.Title">Ayarlar Kaydedildi</sys:String>
    <sys:String x:Key="XeniaSettingsPage.SaveSettings.Success.Message">Yapılandırma ayarları başarıyla kaydedildi.</sys:String>

