    <sys:String x:Key="ConfigUiSettings.Logging.log_level.option.1">Uyarı</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.option.2">Bilgi</sys:String>
    <sys:String x:Key="ConfigUiSettings.Logging.log_level.option.3">Hata Ayıklama</sys:String>

    <!-- Config UI Settings - Memory Options -->
    <sys:String x:Key="ConfigUiSettings.Memory.protect_zero.Title">Sıfırı Koru</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.protect_zero.Comment">Sıfır sayfasını okuma ve yazmalara karşı korur</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.scribble_heap.Title">Heap Karalama</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.scribble_heap.Comment">Tüm ayrılmış heap belleğine belirli veya rastgele bir değer yazar</sys:String>

    <!-- Config UI Settings - Storage Options -->
    <sys:String x:Key="ConfigUiSettings.Storage.mount_cache.Title">Önbelleği Bağla</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_cache.Comment">Önbellek bağlamayı etkinleştirir</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_scratch.Title">Scratch Bağla</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_scratch.Comment">Scratch bağlamayı etkinleştirir</sys:String>

