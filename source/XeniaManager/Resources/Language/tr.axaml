    <sys:String x:Key="ConfigUiSettings.UI.show_achievement_notification.Title">Başarım Bildirimini Göster</sys:String>
    <sys:String x:Key="ConfigUiSettings.UI.show_achievement_notification.Comment">Ekranda başarım bildirimini gösterir</sys:String>

    <!-- Config UI Settings - Video Options -->
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.Title">Dahili Ekran Çözünürlüğü</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.Comment">Farklı çözünürlükleri destekleyen oyunların belirli bir çözünürlükte render edilmesine izin verir</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.0">640x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.1">640x576</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.2">720x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.3">720x576</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.4">800x600</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.5">848x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.6">1024x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.7">1152x864</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.8">1280x720</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.9">1280x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.10">1280x960</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.11">1280x1024</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.12">1360x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.13">1440x900</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.14">1680x1050</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.15">1920x540</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.16">1920x1080</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.17">Özel (X/Y)</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_x.Title">Özel Çözünürlük Genişliği</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_x.Comment">Dahili ekran çözünürlüğü için özel genişlik&#10;NOT: Etkili olması için Dahili Ekran Çözünürlüğü "Özel (X/Y)" olarak ayarlanmalıdır</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_y.Title">Özel Çözünürlük Yüksekliği</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_y.Comment">Dahili ekran çözünürlüğü için özel yükseklik&#10;NOT: Etkili olması için Dahili Ekran Çözünürlüğü "Özel (X/Y)" olarak ayarlanmalıdır</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.widescreen.Title">Geniş Ekran</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.widescreen.Comment">16:9 ve 4:3 en boy oranı arasında geçiş yapar</sys:String>

    <!-- Config UI Settings - Vulkan Options -->
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_immediate.Title">Anında Sunum Moduna İzin Ver</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_immediate.Comment">Kullanılabilir olduğunda, belirli durumlarda yırtılma olasılığı ile en düşük gecikmeyi sunan anında sunum moduna (1. öncelik) izin verir</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_mailbox.Title">Mailbox Sunum Moduna İzin Ver</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_mailbox.Comment">Kullanılabilir olduğunda, yırtılma olasılığı olmadan düşük gecikme sunan mailbox sunum moduna (2. öncelik) izin verir</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_fifo_relaxed.Title">FIFO Relaxed Sunum Moduna İzin Ver</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_fifo_relaxed.Comment">Kullanılabilir olduğunda, host ekran dikey senkronizasyonunu bekleyen, ancak kareler host ekran yenileme hızını karşılamazsa yırtılma ile sunulabilen relaxed FIFO sunum moduna (3. öncelik) izin verir</sys:String>

    <!-- Config UI Settings - Live/Netplay Options -->
    <sys:String x:Key="ConfigUiSettings.Live.api_address.Title">API Adresi</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.api_address.Comment">Xenia sunucu adresi (örn. IP:PORT)</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.discord_presence_user_index.Title">Discord Rich Presence Kullanıcı Dizini</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.discord_presence_user_index.Comment">Discord rich presence için kullanılan kullanıcı profil dizini [0-3]</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.Title">Ağ Modu</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.Comment">Ağ modu&#10;0 - Çevrimdışı&#10;1 - Systemlink&#10;2 - Xbox Live</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.0">Çevrimdışı</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.1">Systemlink</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.2">Xbox Live</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.upnp.Title">UPnP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.upnp.Comment">UPnP kullanarak otomatik bağlantı noktası yönlendirme</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xhttp.Title">XHTTP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xhttp.Comment">XHTTP'yi açar/kapatır</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xlink_kai_systemlink_hack.Title">XLink Kai SystemLink Hilesi</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xlink_kai_systemlink_hack.Comment">XLink Kai desteği için hileleri etkinleştirir&#10;Bazı oyunları bozabilir</sys:String>

    <!-- Config UI Settings - MouseHook Options -->
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_autoaim.Title">Otomatik Nişanı Devre Dışı Bırak</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_autoaim.Comment">Destekleyen oyunlarda otomatik nişanı devre dışı bırakır (GoldenEye, Perfect Dark, Saints Row, COD)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_fullscreen_esc_bind.Title">Tam Ekran ESC Tuş Atamasını Devre Dışı Bırak</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_fullscreen_esc_bind.Comment">Tam ekrandayken escape tuşu ile tam ekrandan çıkışı devre dışı bırakır</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.fov_sensitivity.Title">FOV Hassasiyeti</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.fov_sensitivity.Comment">FOV düşürüldüğünde fare ölçeği (COD, DR, RDR ve UE3 Oyunları)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_aim_turn_distance.Title">(GoldenEye/Perfect Dark)&#10;Nişan Dönüş Mesafesi</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_aim_turn_distance.Comment">(GoldenEye/Perfect Dark) Kamera dönmeden önce nişan modunda artı imlecinin hareket edebileceği mesafe</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_debug_menu.Title">(GoldenEye)&#10;Hata Ayıklama Menüsü</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_debug_menu.Comment">(GoldenEye) LB/1 ile erişilebilen hata ayıklama menüsünü etkinleştirir</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_gun_sway.Title">(GoldenEye/Perfect Dark)&#10;Silah Sallanması</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_gun_sway.Comment">(GoldenEye/Perfect Dark) Kamera döndürüldükçe silah sallanmasını etkinleştirir</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_remove_blur.Title">(GoldenEye)&#10;Bulanıklığı Kaldır</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_remove_blur.Comment">(GoldenEye) Klasik grafik modundayken düşük çözünürlüklü bulanıklığı kaldırır</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.internal_hook.Title">Dahili Hook</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.internal_hook.Comment">Daha iyi fare enjeksiyonu sonuçları için daha iyi hook tekniği kullanır (Saints Row 1)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_x.Title">X Eksenini Ters Çevir</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_x.Comment">Fare X eksenini ters çevirir</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_y.Title">Y Eksenini Ters Çevir</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_y.Comment">Fare Y eksenini ters çevirir</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.menu_sensitivity.Title">(GoldenEye/Saints Row 1)&#10;Menü Hassasiyeti</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.menu_sensitivity.Comment">(GoldenEye/Saints Row 1) Menülerdeyken fare hassasiyeti</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_snappy_wheel.Title">(Red Dead Redemption)&#10;Hızlı Silah Çemberi</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_snappy_wheel.Comment">(Red Dead Redemption) Silah çemberini 45 derecelik artışlarla sabitler</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_turbo_gallop_horse.Title">(Red Dead Redemption)&#10;Turbo Dörtnal</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_turbo_gallop_horse.Comment">(Red Dead Redemption) Atlar ve arabalar için turbo dörtnalı etkinleştirir</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sensitivity.Title">Fare Hassasiyeti</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sensitivity.Comment">Fare hassasiyeti</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.source_sniper_sensitivity.Title">Source Nişancı Hassasiyeti</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.source_sniper_sensitivity.Comment">Source motoru nişancı dürbünü hassasiyeti</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr1_increase_vehicle_rotation_limit.Title">(Saints Row 1)&#10;Araç Dönüş Limiti</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr1_increase_vehicle_rotation_limit.Comment">(Saints Row 1) Araç dikey dönüş limitini çoğunlukla yaya ile aynı olacak şekilde yamalar</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_better_handbrake_cam.Title">(Saints Row 2)&#10;Daha İyi El Freni Kamerası</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_better_handbrake_cam.Comment">(Saints Row 2) SR1'e benzer şekilde el freni yaparken X dönüşünü araçlardan ayırır</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_hold_fine_aim.Title">(Saints Row 2)&#10;Basılı Tutarak Hassas Nişan</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_hold_fine_aim.Comment">(Saints Row 2) Hassas nişanı (ADS) aç/kapa modundan basılı tutma moduna geçirir</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_better_drive_cam.Title">(Saints Row 1 ve 2)&#10;Daha İyi Sürüş Kamerası</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_better_drive_cam.Comment">(Saints Row 1 ve 2) Otomatik ortalama devre dışıyken X dönüşünü araçlardan ayırır</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_disable_shared_reload.Title">(Saints Row 1)&#10;Paylaşımlı Yeniden Doldurmayı Devre Dışı Bırak</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_disable_shared_reload.Comment">(Saints Row 1) Dahili (A) tuşuna basıldığında silahların yeniden doldurulmasını devre dışı bırakır</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.swap_wheel.Title">(Saints Row 1)&#10;Çember Değişimi</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.swap_wheel.Comment">Saints Row 1'de silah çemberi ve harita yakınlaştırma yönü için tuş atamalarını değiştirir</sys:String>

    <!-- About Page -->
    <sys:String x:Key="AboutPage.App.Description">Xenia Emulator için kapsamlı bir yönetim aracı. Sezgisel arayüzü sayesinde Xenia emülatörünün farklı sürümlerini kolayca kurun, güncelleyin ve yönetin.</sys:String>
    <sys:String x:Key="AboutPage.WebsiteButton.Text">Web Sitesi</sys:String>
    <sys:String x:Key="AboutPage.GithubButton.Text">GitHub</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesButton.Text">Güncellemeleri Denetle</sys:String>
    <sys:String x:Key="AboutPage.UpdateXeniaManagerButton.Text">Xenia Manager'ı Güncelle</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesFailed.Title">Güncelleme denetimi başarısız oldu</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesFailed.Message">Güncellemeler denetlenirken bir hata oluştu:&#10;{0}</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.Title">Güncelleme başarısız oldu</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.Message">Xenia Manager güncellenirken bir hata oluştu:&#10;{0}</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.NoReleaseInfo">Sürüm bilgileri alınamadı. Lütfen daha sonra tekrar deneyin.</sys:String>
    <sys:String x:Key="AboutPage.DownloadingUpdate">Güncelleme indiriliyor</sys:String>
    <sys:String x:Key="AboutPage.ExtractingUpdate">Güncelleme çıkartılıyor</sys:String>
    <sys:String x:Key="AboutPage.LicenseCredits.Text">Lisans &amp; Emeği Geçenler</sys:String>
    <sys:String x:Key="AboutPage.LicenseCredits.SideText">Yasal bilgiler ve teşekkürler</sys:String>
    <sys:String x:Key="AboutPage.License.Text">Bu yazılım, BSD-3-Clause Lisansı kapsamında lisanslanmıştır.</sys:String>
    <sys:String x:Key="AboutPage.Xbox360Emulation.Header">Xbox 360 Emülasyonu</sys:String>
    <sys:String x:Key="AboutPage.Libraries.Header">Kütüphaneler</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaProject.Title">Xenia Project</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaProject.ToolTip"> - Orijinal Xbox 360 emülatörü</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaCanary.Title">Xenia Canary</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaCanary.ToolTip"> - En son özellikleri içeren deneysel sürümü</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaNetplay.Title">Xenia Netplay</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaNetplay.ToolTip"> - Çok oyunculu oyun desteği</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaMousehook.Title">Xenia Mousehook</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaMousehook.ToolTip"> - Klavye &amp; Fare desteği</sys:String>
    <sys:String x:Key="AboutPage.Credits.AvaloniaUi.Title">Avalonia UI</sys:String>
    <sys:String x:Key="AboutPage.Credits.AvaloniaUi.ToolTip"> - Fluent Design'a sahip, platformlar arası kullanıcı arayüzü çatısı</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentAvalonia.Title">FluentAvalonia</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentAvalonia.ToolTip"> - Avalonia için Fluent Design denetimleri ve temaları</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentIcons.Title">FluentIcons</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentIcons.ToolTip"> - Fluent Sembol Simgelerini kullanmak için bir çatı</sys:String>
    <sys:String x:Key="AboutPage.Credits.NLog.Title">NLog</sys:String>
    <sys:String x:Key="AboutPage.Credits.NLog.ToolTip"> - .NET için esnek bir günlükleme çatısı</sys:String>
    <sys:String x:Key="AboutPage.Credits.Xbox360Toolkit.Title">Xbox 360 Toolkit</sys:String>
    <sys:String x:Key="AboutPage.Credits.Xbox360Toolkit.ToolTip"> - Oyun bilgilerinin ayrıştırılması</sys:String>
    <sys:String x:Key="AboutPage.Credits.SharpCompress.Title">SharpCompress</sys:String>
    <sys:String x:Key="AboutPage.Credits.SharpCompress.ToolTip"> - Arşiv ve sıkıştırma işlemleri</sys:String>
    <sys:String x:Key="AboutPage.Credits.ZstdSharp.Title">#NOTTRANSLATED#</sys:String>
    <sys:String x:Key="AboutPage.Credits.ZstdSharp.ToolTip">#NOTTRANSLATED#</sys:String>
    <sys:String x:Key="AboutPage.FooterNote.Text">Bu uygulama, Microsoft Corporation veya Xenia Project ile hiçbir şekilde bağlantılı değildir, onlar tarafından desteklenmemekte veya sponsorluğu yapılmamaktadır. Tüm ticari markalar, logolar ve marka adları ilgili sahiplerinin mülkiyetindedir.&#10;Xbox 360, Microsoft Corporation'ın Amerika Birleşik Devletleri ve/veya diğer ülkelerdeki tescilli ticari markasıdır.&#10;Xenia, Xenia Project'in tescilli ticari markasıdır.&#10;Bu ve diğer ticari markalara yapılan tüm atıflar yalnızca uyumluluk veya işlevselliği belirtmek amacıyla yapılmıştır ve ticari marka sahipleriyle herhangi bir bağlantı ya da onlar tarafından onaylandığı anlamına gelmez.&#10;Bu yazılım yalnızca eğitim ve bilgilendirme amaçlıdır. Microsoft Corporation'a veya herhangi bir üçüncü tarafa ait telif hakkıyla korunan içerikleri içermez ya da dağıtmaz. Kullanıcılar, bu yazılımı kullanımlarının telif hakkı ve lisans yasaları da dahil olmak üzere yürürlükteki tüm yasalara uygun olmasını sağlamaktan tamamen sorumludur.&#10;Bu uygulamanın tescilli yazılım veya ürün yazılımı (firmware) çalıştırmak ya da bunlarla etkileşim kurmak amacıyla kullanılması, ilgili Son Kullanıcı Lisans Sözleşmelerinin (EULA) sınırları içinde gerçekleştirilmelidir. Bu uygulamanın geliştiricileri ve dağıtıcıları hiçbir şekilde korsanlığı desteklemez veya teşvik etmez.&#10;Bu uygulama, açık veya zımni hiçbir garanti verilmeden "olduğu gibi" sunulmaktadır. Kullanım riski tamamen size aittir.</sys:String>
    <sys:String x:Key="AboutPage.UseExperimentalBuild.Title">Deneysel Sürümü Kullan</sys:String>
    <sys:String x:Key="AboutPage.UseExperimentalBuild.Description">Deneysel özellik güncellemelerini almak ve yeni özelliklere erken erişmek için etkinleştirin</sys:String>
    <sys:String x:Key="AboutPage.WebsiteButton.ToolTip">Xenia Manager web sitesini açar</sys:String>
    <sys:String x:Key="AboutPage.GithubButton.ToolTip">Xenia Manager GitHub deposunu açar</sys:String>
    <sys:String x:Key="AboutPage.InfoBar.XeniaManagerUpdateAvailable.Message">Xenia Manager'ın daha yeni bir sürümü mevcut.</sys:String>
    <sys:String x:Key="AboutPage.InfoBar.NoXeniaManagerUpdateAvailable.Message">Şu anda Xenia Manager'ın en güncel sürümünü kullanıyorsunuz.</sys:String>

