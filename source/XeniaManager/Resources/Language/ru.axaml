    <sys:String x:Key="XeniaSettingsPage.ResetSettings.Failure.Message">Не удалось сбросить файл конфигурации '{0}': {1}</sys:String>
    <sys:String x:Key="XeniaSettingsPage.OpenInEditor.NoSelection.Title">Конфигурация не выбрана</sys:String>
    <sys:String x:Key="XeniaSettingsPage.OpenInEditor.NoSelection.Message">Пожалуйста, выберите файл конфигурации перед открытием в редакторе.</sys:String>
    <sys:String x:Key="XeniaSettingsPage.OpenInEditor.Failure.Title">Ошибка открытия в редакторе</sys:String>
    <sys:String x:Key="XeniaSettingsPage.OpenInEditor.Failure.Message">Не удалось открыть файл конфигурации '{0}': {1}</sys:String>
    <sys:String x:Key="XeniaSettingsPage.SaveSettings.Success.Title">Настройки сохранены</sys:String>
    <sys:String x:Key="XeniaSettingsPage.SaveSettings.Success.Message">Настройки конфигурации успешно сохранены.</sys:String>

    <!-- Config UI Settings - Section Display Names -->
    <sys:String x:Key="ConfigUiSettings.Section.APU">Аудио</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.Content">Контент</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.CPU">ЦП</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.D3D12">D3D12</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.Display">Дисплей</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.General">Общие</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.GPU">ГП</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.HID">HID</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.HID.WinKey">Привязки WinKey</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.Kernel">Ядро</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.Memory">Память</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.Storage">Хранилище</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.UI">Интерфейс</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.Video">Видео</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.Vulkan">Vulkan</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.Live">Netplay</sys:String>
    <sys:String x:Key="ConfigUiSettings.Section.MouseHook">MouseHook</sys:String>

    <!-- Config UI Settings - APU Options -->
    <sys:String x:Key="ConfigUiSettings.APU.apu.Title">Аудиосистема</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.Comment">Аудиосистема</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.any">Любая</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.nop">Nop</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.sdl">SDL</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu.option.xaudio2">XAudio2</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu_max_queued_frames.Title">Максимальное количество буферизированных аудиокадров</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.apu_max_queued_frames.Comment">Позволить изменить максимальное количество буферизированных аудиокадров для уменьшения задержки звука&#10;Уменьшение этого значения может вызвать проблемы с производительностью</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.mute.Title">Отключить звук</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.mute.Comment">Отключить весь вывод звука</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.enable_xmp.Title">XMP</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.enable_xmp.Comment">Включить воспроизведение музыкального плеера&#10;Это может исправить музыку в некоторых играх</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xmp_default_volume.Title">Громкость XMP по умолчанию</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xmp_default_volume.Comment">Громкость музыки по умолчанию, если игра не устанавливает её</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_dedicated_xma_thread.Title">Выделенный поток XMA</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_dedicated_xma_thread.Comment">Включить декодирование XMA в отдельном потоке&#10;При отключенной опции ожидайте лучших результатов, но более низкой производительности</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_new_decoder.Title">Аудиодекодер XMA</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.use_new_decoder.Comment">Включает использование нового декодирования аудио XMA</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.Title">Декодер XMA</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.Comment">fake: Аудио не будет декодироваться&#10;master: Версия декодера точно как в базовой версии Xenia&#10;old: Декодер на основе мастер-версии с несколькими улучшениями&#10;new: Новая версия декодера. Обеспечивает наивысшую стабильность, но еще не завершена</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.fake">Fake</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.master">Master</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.old">Old</sys:String>
    <sys:String x:Key="ConfigUiSettings.APU.xma_decoder.option.new">New</sys:String>

    <!-- Config UI Settings - Content Options -->
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.Title">Маска лицензии</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.Comment">- Нет лицензии: Демо-режим&#10;- Первая лицензия: Обычная лицензия полной версии в играх Xbox Live Arcade&#10;- Все лицензии: Включены все возможные лицензии, но это может привести к неопределенному поведению</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.0">Нет лицензий</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.1">Первая лицензия</sys:String>
    <sys:String x:Key="ConfigUiSettings.Content.license_mask.option.-1">Все лицензии</sys:String>

    <!-- Config UI Settings - CPU Options -->
    <sys:String x:Key="ConfigUiSettings.CPU.break_on_unimplemented_instructions.Title">Остановиться на нереализованных инструкциях</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.break_on_unimplemented_instructions.Comment">Переключиться на отладчик хоста (или аварийно завершить работу, если отладчик не подключен) при обнаружении нереализованной инструкции PowerPC</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disable_context_promotion.Title">Отключить продвижение контекста</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disable_context_promotion.Comment">Отключить оптимизацию продвижения контекста&#10;Это может понадобиться для некоторых спортивных игр, но снизит производительность</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disassemble_functions.Title">Дизассемблировать функции</sys:String>
    <sys:String x:Key="ConfigUiSettings.CPU.disassemble_functions.Comment">Дизассемблировать функции во время генерации</sys:String>

    <!-- Config UI Settings - D3D12 Options -->
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_allow_variable_refresh_rate_and_tearing.Title">Разрешить переменную частоту обновления и разрывы</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_allow_variable_refresh_rate_and_tearing.Comment">В полноэкранном режиме разрешить использование переменной частоты обновления на поддерживающих её дисплеях&#10;На дисплеях без поддержки VRR в некоторых случаях могут возникать разрывы изображения</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.Title">Приоритет очереди</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.Comment">Приоритет планирования очереди команд графики (прямой)&#10;0 - Обычный&#10;1 - Высокий&#10;2 - Глобальный реального времени, требует прав администратора и может повлиять на отзывчивость системы</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.0">Обычный</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.1">Высокий</sys:String>
    <sys:String x:Key="ConfigUiSettings.D3D12.d3d12_queue_priority.option.2">Глобальный реального времени</sys:String>

    <!-- Config UI Settings - Display Options -->
    <sys:String x:Key="ConfigUiSettings.Display.fullscreen.Title">Полноэкранный режим</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.fullscreen.Comment">Запускать ли эмулятор в полноэкранном режиме</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.present_letterbox.Title">Показать Letterbox</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.present_letterbox.Comment">Сохранять соотношение сторон при растяжении, отображая полосы вокруг изображения, когда нет области переразвертки для обрезки</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.Title">Сглаживание</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.Comment">Эффект постобработки сглаживания для применения к выходному изображению игры</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.none">Нет</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.fxaa">FXAA</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_antialiasing.option.fxaa_extreme">FXAA Extreme</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.Title">Масштабирование и повышение резкости</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.Comment">Эффект постобработки для передискретизации и/или повышения резкости конечного выходного изображения</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.bilinear">Билинейное</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.cas">CAS</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_scaling_and_sharpening.option.fsr">FSR</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_sharpness_reduction.Title">Уменьшение резкости FSR</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_sharpness_reduction.Comment">Уменьшение резкости для AMD FidelityFX Super Resolution 1.0 (FSR), в стопах&#10;Меньше значение — резче</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_cas_additional_sharpness.Title">Дополнительная резкость CAS</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_cas_additional_sharpness.Comment">Дополнительная резкость для AMD FidelityFX Contrast Adaptive Sharpening (CAS), от 0 до 1&#10;Больше значение — резче</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_max_upsampling_passes.Title">Макс. количество проходов повышения частоты FSR</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_ffx_fsr_max_upsampling_passes.Comment">Максимальное количество проходов повышения частоты, выполняемых в AMD FidelityFX Super Resolution 1.0 (FSR), перед возвратом к билинейному растяжению после последнего прохода</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_dither.Title">Дизеринг</sys:String>
    <sys:String x:Key="ConfigUiSettings.Display.postprocess_dither.Comment">Применять дизеринг к конечному выходному изображению из внутренней точности до 8 бит на канал для более плавных градиентов</sys:String>

    <!-- Config UI Settings - General Options -->
    <sys:String x:Key="ConfigUiSettings.General.allow_plugins.Title">Разрешить плагины</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.allow_plugins.Comment">Разрешить загрузку плагинов/тренеров из plugins\\title_id\\plugin.xex&#10;Плагины — это самодельные xex-модули, которые можно использовать для создания модов&#10;Эта функция экспериментальная</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.discord.Title">Discord Rich Presence</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.discord.Comment">Включить Discord Rich Presence</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.apply_patches.Title">Применять патчи</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.apply_patches.Comment">Включает функциональность пользовательских патчей</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.controller_hotkeys.Title">Горячие клавиши контроллера</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.controller_hotkeys.Comment">Горячие клавиши для контроллеров Xbox и PS</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.launch_module.Title">Модуль запуска</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.launch_module.Comment">Исполняемый файл для запуска из .iso или пакета вместо default.xex или модуля, указанного игрой&#10;Оставьте пустым для запуска модуля по умолчанию</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.notification_sound_path.Title">Путь к звуку уведомлений</sys:String>
    <sys:String x:Key="ConfigUiSettings.General.notification_sound_path.Comment">Путь (включая имя файла) к выбранному звуку уведомления&#10;ПРИМЕЧАНИЕ: Звук ДОЛЖЕН быть в формате wav!</sys:String>

    <!-- Config UI Settings - GPU Options -->
    <sys:String x:Key="ConfigUiSettings.GPU.vsync.Title">Вертикальная синхронизация</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.vsync.Comment">Включить VSYNC</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.framerate_limit.Title">Ограничение частоты кадров</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.framerate_limit.Comment">Максимальное количество кадров в секунду&#10;0 = Неограниченно&#10;По умолчанию 60, если установлено 0 и включена VSYNC</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.Title">Графическая система</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.Comment">Используемая графическая система</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.any">Любая</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.d3d12">D3D12</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.vulkan">Vulkan</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu.option.null">Null</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.Title">Путь цели рендеринга (D3D12)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.Comment">Путь эмуляции цели рендеринга для использования в Direct3D 12&#10;RTV - Цели рендеринга хоста&#10;ROV - Представления с упорядочением растеризатора</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.any">Авто</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.rtv">RTV</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_d3d12.option.rov">ROV</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.Title">Путь цели рендеринга (Vulkan)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.Comment">Путь эмуляции цели рендеринга для использования в Vulkan&#10;FBO - Буферы кадров хоста&#10;FSI - Блокировка фрагментных шейдеров</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.any">Авто</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.fbo">FBO</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.render_target_path_vulkan.option.fsi">FSI</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.Title">Обратное чтение разрешения</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.Comment">Управляет обратным чтением ЦП результатов разрешения рендеринга в текстуру&#10;Нет - отключить обратное чтение&#10;Быстро - задержка в 1 кадр&#10;Полное - точно, но медленно</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.none">Нет</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.fast">Быстро</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.readback_resolve.option.full">Полно</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_x.Title">Масштаб разрешения отрисовки X</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_x.Comment">Целочисленный масштаб ширины в пикселях, используемый для непрозрачного масштабирования разрешения рендеринга для игры</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_y.Title">Масштаб разрешения отрисовки Y</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.draw_resolution_scale_y.Comment">Целочисленный масштаб высоты в пикселях, используемый для непрозрачного масштабирования разрешения рендеринга для игры</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu_allow_invalid_fetch_constants.Title">Разрешить недопустимые константы выборки</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gpu_allow_invalid_fetch_constants.Comment">Разрешить константы выборки текстуры и вершин с недопустимым типом&#10;Обычно небезопасно, но может использоваться для обхода ошибок типа констант выборки в некоторых играх</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gamma_render_target_as_srgb.Title">Цель рендеринга гаммы как sRGB</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.gamma_render_target_as_srgb.Comment">Когда хост не может напрямую записывать кусочно-линейную гамму с правильным смешиванием, использовать вывод sRGB на хосте для концептуально правильного смешивания в линейном цветовом пространстве</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_lower_threshold.Title">Нижний порог выборки окклюзии запроса</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_lower_threshold.Comment">Если установлено -1, количество выборок не записывается, игры могут зависать&#10;В противном случае количество выборок каждого тайла будет увеличиваться на это число при каждом EVENT_WRITE_ZPD</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_upper_threshold.Title">Верхний порог выборки окклюзии запроса</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.query_occlusion_sample_upper_threshold.Comment">Установите большее число, чем query_occlusion_sample_lower_threshold&#10;Это значение игнорируется, если query_occlusion_sample_lower_threshold установлено в -1</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.use_fuzzy_alpha_epsilon.Title">Использовать нечеткое альфа-эпсилон</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.use_fuzzy_alpha_epsilon.Comment">Использовать приблизительное сравнение для альфа-значений, чтобы предотвратить мерцание на видеокартах NVIDIA</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.clear_memory_page_state.Title">Очистить состояние страниц памяти</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.clear_memory_page_state.Comment">Обновить состояние страниц памяти для включения данных, записанных графическим процессором</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.Title">Переопределение анизотропной фильтрации</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.Comment">Принудительно включать анизотропную фильтрацию (AF) для подходящих текстур&#10;Более высокие значения сохраняют текстуры более четкими под наклонными углами за счет пропускной способности GPU&#10;В редких случаях принудительное включение AF может привести к визуальным артефактам</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.-1">Без переопределения (по умолчанию)</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.0">Отключить анизотропную фильтрацию</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.1">1x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.2">2x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.3">4x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.4">8x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.anisotropic_override.option.5">16x</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.async_shader_compilation.Title">Асинхронная компиляция шейдеров</sys:String>
    <sys:String x:Key="ConfigUiSettings.GPU.async_shader_compilation.Comment">Компилировать шейдеры и создавать конвейеры асинхронно в фоновых потоках&#10;Устранение заикания при компиляции шейдеров, но может вызывать кратковременные визуальные артефакты во время создания конвейеров&#10;При отключении конвейеры создаются синхронно, что вызывает заикания, но не вызывает визуальных артефактов</sys:String>

    <!-- Config UI Settings - HID Options -->
    <sys:String x:Key="ConfigUiSettings.HID.hid.Title">Система ввода</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.Comment">Используемая система ввода</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.any">Любая</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.nop">Nop</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.sdl">SDL</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.winkey">WinKey</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.hid.option.xinput">XInput</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.Title">Режим клавиатуры</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.Comment">Позволить пользователю указать режим работы клавиатуры:&#10;0 - Отключен&#10;1 - Включен&#10;2 - Сквозной режим, требующий подключения контроллера</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.0">Отключен</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.1">Включен</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_mode.option.2">Сквозной</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_user_index.Title">Индекс пользователя клавиатуры</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.keyboard_user_index.Comment">Порт контроллера, который эмулирует клавиатуру (0-3)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.left_stick_deadzone_percentage.Title">Мертвая зона левого стика</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.left_stick_deadzone_percentage.Comment">Определить уровень мертвой зоны для левого стика (0-100%)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.right_stick_deadzone_percentage.Title">Мертвая зона правого стика</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.right_stick_deadzone_percentage.Comment">Определить уровень мертвой зоны для правого стика (0-100%)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.vibration.Title">Вибрация</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.vibration.Comment">Включить/выключить вибрацию контроллера</sys:String>

    <!-- Config UI Settings - HID.WinKey Options -->
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_a.Title">Кнопка A</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_a.Comment">Список клавиш для привязки к A, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "Q I" привязывает и Q, и I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_b.Title">Кнопка B</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_b.Comment">Список клавиш для привязки к B, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "Q I" привязывает и Q, и I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_back.Title">Кнопка BACK</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_back.Comment">Список клавиш для привязки к BACK, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "Q I" привязывает и Q, и I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_down.Title">D-Pad Вниз</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_down.Comment">Список клавиш для привязки к DPAD_DOWN, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "^S" означает Shift+S</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_left.Title">D-Pad Влево</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_left.Comment">Список клавиш для привязки к DPAD_LEFT, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "^A" означает Shift+A</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_right.Title">D-Pad Вправо</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_right.Comment">Список клавиш для привязки к DPAD_RIGHT, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "^D" означает Shift+D</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_up.Title">D-Pad Вверх</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_dpad_up.Comment">Список клавиш для привязки к DPAD_UP, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "^W" означает Shift+W</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_guide.Title">Кнопка Guide</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_guide.Comment">Список клавиш для привязки к GUIDE, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "0x08" — Backspace</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_shoulder.Title">Левая верхняя кнопка (LB)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_shoulder.Comment">Список клавиш для привязки к LEFT_SHOULDER, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "Q I" привязывает и Q, и I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb.Title">Нажатие левого стика</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb.Comment">Список клавиш для привязки к LEFT_THUMB_PRESSED, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "Q I" привязывает и Q, и I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_down.Title">Левый стик Вниз</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_down.Comment">Список клавиш для привязки к LEFT_THUMB_DOWN, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "_S" означает S без Shift</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_left.Title">Левый стик Влево</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_left.Comment">Список клавиш для привязки к LEFT_THUMB_LEFT, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "_A" означает A без Shift</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_right.Title">Левый стик Вправо</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_right.Comment">Список клавиш для привязки к LEFT_THUMB_RIGHT, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "_D" означает D без Shift</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_up.Title">Левый стик Вверх</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_thumb_up.Comment">Список клавиш для привязки к LEFT_THUMB_UP, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "_W" означает W без Shift</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_trigger.Title">Левый триггер</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_left_trigger.Comment">Список клавиш для привязки к LEFT_TRIGGER, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "Q I" привязывает и Q, и I к одному триггеру</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_shoulder.Title">Правая верхняя кнопка (RB)</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_shoulder.Comment">Список клавиш для привязки к RIGHT_SHOULDER, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "Q I" привязывает и Q, и I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb.Title">Нажатие правого стика</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb.Comment">Список клавиш для привязки к RIGHT_THUMB_PRESSED, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "Q I" привязывает и Q, и I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_down.Title">Правый стик Вниз</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_down.Comment">Список клавиш для привязки к RIGHT_THUMB_DOWN, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "0x28" — стрелка вниз</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_left.Title">Правый стик Влево</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_left.Comment">Список клавиш для привязки к RIGHT_THUMB_LEFT, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "0x25" — стрелка влево</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_right.Title">Правый стик Вправо</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_right.Comment">Список клавиш для привязки к RIGHT_THUMB_RIGHT, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "0x27" — стрелка вправо</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_up.Title">Правый стик Вверх</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_thumb_up.Comment">Список клавиш для привязки к RIGHT_THUMB_UP, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "0x26" — стрелка вверх</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_trigger.Title">Правый триггер</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_right_trigger.Comment">Список клавиш для привязки к RIGHT_TRIGGER, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "E O" привязывает и E, и O к одному триггеру</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_start.Title">Кнопка START</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_start.Comment">Список клавиш для привязки к START, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "Q I" привязывает и Q, и I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_x.Title">Кнопка X</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_x.Comment">Список клавиш для привязки к X, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "Q I" привязывает и Q, и I</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_y.Title">Кнопка Y</sys:String>
    <sys:String x:Key="ConfigUiSettings.HID.WinKey.keybind_y.Comment">Список клавиш для привязки к Y, разделенных пробелами. Формат: виртуальный код клавиши (0x26), одиночный символ (A-Z, 0-9), с модификаторами (^ требует Shift, _ требует отсутствия Shift). Пример: "Q I" привязывает и Q, и I</sys:String>

    <!-- Config UI Settings - Kernel Options -->
    <sys:String x:Key="ConfigUiSettings.Kernel.apply_title_update.Title">Применить обновление игры</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.apply_title_update.Comment">Применять обновления игры</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.cl.Title">Командная строка</sys:String>
    <sys:String x:Key="ConfigUiSettings.Kernel.cl.Comment">Указать дополнительную командную строку для гостевой системы</sys:String>

    <!-- Config UI Settings - Memory Options -->
    <sys:String x:Key="ConfigUiSettings.Memory.protect_zero.Title">Защита нулевой страницы</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.protect_zero.Comment">Защищать нулевую страницу от чтения и записи</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.scribble_heap.Title">Заполнение кучи</sys:String>
    <sys:String x:Key="ConfigUiSettings.Memory.scribble_heap.Comment">Записывать определенное или случайное значение во всю выделенную память кучи</sys:String>

    <!-- Config UI Settings - Storage Options -->
    <sys:String x:Key="ConfigUiSettings.Storage.mount_cache.Title">Монтировать кэш</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_cache.Comment">Включить монтирование кэша</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_scratch.Title">Монтировать Scratch</sys:String>
    <sys:String x:Key="ConfigUiSettings.Storage.mount_scratch.Comment">Включить монтирование Scratch</sys:String>

