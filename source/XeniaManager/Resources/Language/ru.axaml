    <sys:String x:Key="LibraryPage.Options.ScanDirectory.NoXeniaInstalled.Message">Ни одна из версий Xenia в данный момент не установлена.&#10;Пожалуйста, установите Xenia перед продолжением.</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.XeniaSelectionError.Title">Ошибка выбора Xenia</sys:String>
    <sys:String x:Key="LibraryPage.Options.ScanDirectory.XeniaSelectionError.Message">Ошибка при выборе версии Xenia&#10;{0}</sys:String>
