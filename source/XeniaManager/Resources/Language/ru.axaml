    <sys:String x:Key="ConfigUiSettings.UI.show_achievement_notification.Title">Показывать уведомления о достижениях</sys:String>
    <sys:String x:Key="ConfigUiSettings.UI.show_achievement_notification.Comment">Показывать уведомление о достижении на экране</sys:String>

    <!-- Config UI Settings - Video Options -->
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.Title">Внутреннее разрешение дисплея</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.Comment">Позволить играм, поддерживающим разные разрешения, рендерить в определенном разрешении</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.0">640x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.1">640x576</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.2">720x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.3">720x576</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.4">800x600</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.5">848x480</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.6">1024x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.7">1152x864</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.8">1280x720</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.9">1280x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.10">1280x960</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.11">1280x1024</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.12">1360x768</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.13">1440x900</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.14">1680x1050</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.15">1920x540</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.16">1920x1080</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution.option.17">Пользовательское (X/Y)</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_x.Title">Пользовательская ширина разрешения</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_x.Comment">Пользовательская ширина для внутреннего разрешения дисплея&#10;ПРИМЕЧАНИЕ: Требуется установить «Внутреннее разрешение дисплея» в «Пользовательское (X/Y)», чтобы вступило в силу</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_y.Title">Пользовательская высота разрешения</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.internal_display_resolution_y.Comment">Пользовательская высота для внутреннего разрешения дисплея&#10;ПРИМЕЧАНИЕ: Требуется установить «Внутреннее разрешение дисплея» в «Пользовательское (X/Y)», чтобы вступило в силу</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.widescreen.Title">Широкоэкранный режим</sys:String>
    <sys:String x:Key="ConfigUiSettings.Video.widescreen.Comment">Выбор между форматом 16:9 и 4:3</sys:String>

    <!-- Config UI Settings - Vulkan Options -->
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_immediate.Title">Разрешить немедленный режим презентации</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_immediate.Comment">Если доступно, разрешить немедленный режим презентации (1-й приоритет), обеспечивающий наименьшую задержку с возможностью разрыва изображения в некоторых случаях</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_mailbox.Title">Разрешить режим презентации Mailbox</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_mailbox.Comment">Если доступно, разрешить режим презентации Mailbox (2-й приоритет), обеспечивающий низкую задержку без возможности разрыва изображения</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_fifo_relaxed.Title">Разрешить расслабленный режим презентации FIFO</sys:String>
    <sys:String x:Key="ConfigUiSettings.Vulkan.vulkan_allow_present_mode_fifo_relaxed.Comment">Если доступно, разрешить расслабленный режим презентации «первым пришел — первым ушел» (3-й приоритет), который вызывает ожидание вертикальной синхронизации дисплея хоста, но может создавать разрывы, если кадры не соответствуют частоте обновления дисплея хоста</sys:String>

    <!-- Config UI Settings - Live/Netplay Options -->
    <sys:String x:Key="ConfigUiSettings.Live.api_address.Title">Адрес API</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.api_address.Comment">Адрес сервера Xenia (например, IP:PORT)</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.discord_presence_user_index.Title">Индекс пользователя Discord Rich Presence</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.discord_presence_user_index.Comment">Индекс профиля пользователя, используемый для Discord Rich Presence [0-3]</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.Title">Сетевой режим</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.Comment">Сетевой режим&#10;0 - Вне сети&#10;1 - Systemlink&#10;2 - Xbox Live</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.0">Вне сети</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.1">Systemlink</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.network_mode.option.2">Xbox Live</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.upnp.Title">UPnP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.upnp.Comment">Автоматически перенаправлять порты с помощью UPnP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xhttp.Title">XHTTP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xhttp.Comment">Включить/выключить XHTTP</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xlink_kai_systemlink_hack.Title">XLink Kai SystemLink Hack</sys:String>
    <sys:String x:Key="ConfigUiSettings.Live.xlink_kai_systemlink_hack.Comment">Включить хаки для поддержки XLink Kai&#10;Может нарушить работу некоторых игр</sys:String>

    <!-- Config UI Settings - MouseHook Options -->
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_autoaim.Title">Отключить автоприцеливание</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_autoaim.Comment">Отключить автоприцеливание в играх, которые его поддерживают (GoldenEye, Perfect Dark, Saints Row, COD)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_fullscreen_esc_bind.Title">Отключить привязку ESC для выхода из полноэкранного режима</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.disable_fullscreen_esc_bind.Comment">Отключает выход из полноэкранного режима при нажатии Escape</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.fov_sensitivity.Title">Чувствительность при изменении FOV</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.fov_sensitivity.Comment">Масштаб мыши при уменьшенном поле зрения (COD, DR, RDR и игры на UE3)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_aim_turn_distance.Title">(GoldenEye/Perfect Dark)&#10;Расстояние поворота при прицеливании</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_aim_turn_distance.Comment">(GoldenEye/Perfect Dark) Расстояние, на которое прицел может двигаться в режиме прицеливания перед поворотом камеры</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_debug_menu.Title">(GoldenEye)&#10;Отладочное меню</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_debug_menu.Comment">(GoldenEye) Включить отладочное меню, доступное с помощью LB/1</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_gun_sway.Title">(GoldenEye/Perfect Dark)&#10;Раскачка оружия</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_gun_sway.Comment">(GoldenEye/Perfect Dark) Включить раскачку оружия при повороте камеры</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_remove_blur.Title">(GoldenEye)&#10;Убрать размытие</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.ge_remove_blur.Comment">(GoldenEye) Убрать низкокачественное размытие в режиме классической графики</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.internal_hook.Title">Внутренний хук</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.internal_hook.Comment">Использовать лучшую технику хука для лучшей эмуляции мыши (Saints Row 1)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_x.Title">Инвертировать ось X</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_x.Comment">Инвертировать ось X мыши</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_y.Title">Инвертировать ось Y</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.invert_y.Comment">Инвертировать ось Y мыши</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.menu_sensitivity.Title">(GoldenEye/Saints Row 1)&#10;Чувствительность в меню</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.menu_sensitivity.Comment">(GoldenEye/Saints Row 1) Чувствительность мыши в меню</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_snappy_wheel.Title">(Red Dead Redemption)&#10;Быстрое колесо</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_snappy_wheel.Comment">(Red Dead Redemption) Привязать колесо выбора оружия с шагом в 45 градусов</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_turbo_gallop_horse.Title">(Red Dead Redemption)&#10;Турбо-галоп</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.rdr_turbo_gallop_horse.Comment">(Red Dead Redemption) Включает турбо-галоп для лошадей и экипажей</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sensitivity.Title">Чувствительность мыши</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sensitivity.Comment">Чувствительность мыши</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.source_sniper_sensitivity.Title">Чувствительность снайперского прицела Source</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.source_sniper_sensitivity.Comment">Чувствительность снайперского прицела в движке Source</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr1_increase_vehicle_rotation_limit.Title">(Saints Row 1)&#10;Лимит поворота транспорта</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr1_increase_vehicle_rotation_limit.Comment">(Saints Row 1) Изменяет лимит вертикального поворота транспорта, чтобы он был таким же, как и при нахождении на ногах</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_better_handbrake_cam.Title">(Saints Row 2)&#10;Улучшенная камера ручника</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_better_handbrake_cam.Comment">(Saints Row 2) Отвязать вращение по X от транспорта при использовании ручника, как в SR1</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_hold_fine_aim.Title">(Saints Row 2)&#10;Удерживать для точного прицеливания</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr2_hold_fine_aim.Comment">(Saints Row 2) Переключение точного прицеливания (ADS) с режима переключения на удержание</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_better_drive_cam.Title">(Saints Row 1 &amp; 2)&#10;Улучшенная камера вождения</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_better_drive_cam.Comment">(Saints Row 1&amp;2) Отвязать вращение по X от транспорта, когда автовыравнивание отключено</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_disable_shared_reload.Title">(Saints Row 1)&#10;Отключить общую перезарядку</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.sr_disable_shared_reload.Comment">(Saints Row 1) Отключить перезарядку оружия при нажатии внутренней кнопки (A)</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.swap_wheel.Title">(Saints Row 1)&#10;Поменять колесо</sys:String>
    <sys:String x:Key="ConfigUiSettings.MouseHook.swap_wheel.Comment">Меняет местами привязки для колеса выбора оружия и направления масштабирования карты в Saints Row 1</sys:String>

    <!-- About Page -->
    <sys:String x:Key="AboutPage.App.Description">Полноценный инструмент управления эмулятором Xenia. Легко устанавливайте, обновляйте и управляйте различными версиями эмулятора Xenia с интуитивно понятным интерфейсом.</sys:String>
    <sys:String x:Key="AboutPage.WebsiteButton.Text">Вебсайт</sys:String>
    <sys:String x:Key="AboutPage.GithubButton.Text">GitHub</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesButton.Text">Проверить обновления</sys:String>
    <sys:String x:Key="AboutPage.UpdateXeniaManagerButton.Text">Обновить Xenia Manager</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesFailed.Title">Не удалось проверить обновления</sys:String>
    <sys:String x:Key="AboutPage.CheckForUpdatesFailed.Message">Произошла ошибка при проверке обновлений:&#10;{0}</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.Title">Ошибка обновления</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.Message">Произошла ошибка при обновлении Xenia Manager:&#10;{0}</sys:String>
    <sys:String x:Key="AboutPage.UpdateFailed.NoReleaseInfo">Не удалось получить информацию о релизе. Пожалуйста, попробуйте позже.</sys:String>
    <sys:String x:Key="AboutPage.DownloadingUpdate">Загрузка обновления</sys:String>
    <sys:String x:Key="AboutPage.ExtractingUpdate">Распаковка обновления</sys:String>
    <sys:String x:Key="AboutPage.LicenseCredits.Text">Лицензия и благодарности</sys:String>
    <sys:String x:Key="AboutPage.LicenseCredits.SideText">Юридическая информация и признания</sys:String>
    <sys:String x:Key="AboutPage.License.Text">Это программное обеспечение лицензировано в соответствии с лицензией BSD-3-Clause.</sys:String>
    <sys:String x:Key="AboutPage.Xbox360Emulation.Header">Эмуляция Xbox 360</sys:String>
    <sys:String x:Key="AboutPage.Libraries.Header">Библиотеки</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaProject.Title">Xenia Project</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaProject.ToolTip">Оригинальный эмулятор Xbox 360</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaCanary.Title">Xenia Canary</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaCanary.ToolTip">Экспериментальная сборка с новейшими функциями</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaNetplay.Title">Xenia Netplay</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaNetplay.ToolTip">Поддержка многопользовательской игры</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaMousehook.Title">Xenia Mousehook</sys:String>
    <sys:String x:Key="AboutPage.Credits.XeniaMousehook.ToolTip">Поддержка клавиатуры и мыши</sys:String>
    <sys:String x:Key="AboutPage.Credits.AvaloniaUi.Title">Avalonia UI</sys:String>
    <sys:String x:Key="AboutPage.Credits.AvaloniaUi.ToolTip">Кроссплатформенный фреймворк пользовательского интерфейса с Fluent Design</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentAvalonia.Title">FluentAvalonia</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentAvalonia.ToolTip">Элементы управления и темы Fluent Design для Avalonia</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentIcons.Title">FluentIcons</sys:String>
    <sys:String x:Key="AboutPage.Credits.FluentIcons.ToolTip">Фреймворк для использования Fluent Symbol Icons</sys:String>
    <sys:String x:Key="AboutPage.Credits.NLog.Title">NLog</sys:String>
    <sys:String x:Key="AboutPage.Credits.NLog.ToolTip">Гибкий фреймворк для ведения журналов для .NET</sys:String>
    <sys:String x:Key="AboutPage.Credits.Xbox360Toolkit.Title">Xbox 360 Toolkit</sys:String>
    <sys:String x:Key="AboutPage.Credits.Xbox360Toolkit.ToolTip">Анализ данных об играх</sys:String>
    <sys:String x:Key="AboutPage.Credits.Tomlyn.Title">Tomlyn</sys:String>
    <sys:String x:Key="AboutPage.Credits.Tomlyn.ToolTip">Парсер конфигурационных файлов TOML</sys:String>
    <sys:String x:Key="AboutPage.Credits.SharpCompress.Title">SharpCompress</sys:String>
    <sys:String x:Key="AboutPage.Credits.SharpCompress.ToolTip">Обработка архивов и сжатия</sys:String>
    <sys:String x:Key="AboutPage.FooterNote.Text">Это приложение никоим образом не связано, не одобрено и не спонсируется Microsoft Corporation или Xenia Project. Все товарные знаки, логотипы и фирменные наименования являются собственностью соответствующих владельцев.&#10;Xbox 360 является зарегистрированным товарным знаком Microsoft Corporation в США и/или других странах.&#10;Xenia является зарегистрированным товарным знаком Xenia Project.&#10;Любые ссылки на эти или другие товарные знаки сделаны исключительно для целей идентификации совместимости или функциональности и не подразумевают какой-либо связи с владельцами товарных знаков или их одобрения.&#10;Это программное обеспечение предназначено только для образовательных и информационных целей. Оно не содержит и не распространяет никакой контент, защищенный авторским правом и принадлежащий Microsoft Corporation или любой третьей стороне. Пользователи несут единоличную ответственность за обеспечение соответствия их использования этого программного обеспечения всем применимым законам, включая законы об авторском праве и лицензировании.&#10;Любое использование этого приложения для запуска или взаимодействия с проприетарным программным обеспечением или прошивкой должно осуществляться в рамках соответствующих лицензионных соглашений с конечным пользователем (EULA). Разработчики и распространители этого приложения не одобряют и не поддерживают пиратство в какой-либо форме.&#10;Это приложение предоставляется «как есть» без каких-либо гарантий, явных или подразумеваемых. Используйте на свой страх и риск.</sys:String>
    <sys:String x:Key="AboutPage.UseExperimentalBuild.Title">Использовать экспериментальную сборку</sys:String>
    <sys:String x:Key="AboutPage.UseExperimentalBuild.Description">Включите, чтобы получать обновления экспериментальных функций и ранний доступ к новым возможностям</sys:String>
    <sys:String x:Key="AboutPage.WebsiteButton.ToolTip">Открывает веб-сайт Xenia Manager</sys:String>
    <sys:String x:Key="AboutPage.GithubButton.ToolTip">Открывает репозиторий Xenia Manager на GitHub</sys:String>
    <sys:String x:Key="AboutPage.InfoBar.XeniaManagerUpdateAvailable.Message">Доступна новая версия Xenia Manager.</sys:String>
    <sys:String x:Key="AboutPage.InfoBar.NoXeniaManagerUpdateAvailable.Message">У вас установлена последняя версия Xenia Manager.</sys:String>
