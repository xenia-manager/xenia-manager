    <sys:String x:Key="MainView.Navigation.Error.Message">Не удалось перейти на страницу.&#10;{0}</sys:String>

    <!-- Library Page -->
    <sys:String x:Key="LibraryPage.Search.Watermark">Поиск...</sys:String>
    <sys:String x:Key="LibraryPage.Options.EditGridView.Header">Редактировать вид сетки</sys:String>
